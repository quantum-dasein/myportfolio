<div class="growth-observatory" data-growth-observatory>
  <canvas aria-hidden="true"></canvas>
  <div class="growth-axis" aria-hidden="true"><span>BASELINE</span><span>LAUNCH + 03 WEEKS</span></div>
  <div class="growth-core" aria-hidden="true">
    <span>GA4</span>
    <b>LIVE SIGNAL</b>
  </div>
  <div class="growth-caption" aria-hidden="true">ORGANIC ACQUISITION / REAL DATA</div>
</div>

<style>
  .growth-observatory {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    background:
      radial-gradient(circle at 50% 50%, rgba(255,255,255,.075), transparent 28%),
      linear-gradient(rgba(255,255,255,.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.028) 1px, transparent 1px),
      rgba(2, 3, 5, 0.76);
    background-size: auto, 4rem 4rem, 4rem 4rem, auto;
    isolation: isolate;
  }

  .growth-observatory::before,
  .growth-observatory::after {
    content: "";
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }

  .growth-observatory::before {
    inset: 0;
    background: linear-gradient(90deg, rgba(2,3,5,.72), transparent 22%, transparent 78%, rgba(2,3,5,.72));
  }

  .growth-observatory::after {
    left: 50%;
    top: 50%;
    width: min(34rem, 55vw);
    aspect-ratio: 1;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 4rem rgba(255,255,255,.018), 0 0 0 8rem rgba(255,255,255,.012);
  }

  canvas { width: 100%; height: 100%; display: block; }

  .growth-axis,
  .growth-caption,
  .growth-core {
    position: absolute;
    z-index: 3;
    font-family: var(--font-inter);
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .growth-axis {
    left: 1.2rem;
    right: 1.2rem;
    bottom: 1rem;
    display: flex;
    justify-content: space-between;
    color: rgba(var(--rgb-text), .38);
    font-size: .56rem;
  }

  .growth-axis::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.38), transparent);
  }

  .growth-core {
    left: 50%;
    top: 50%;
    display: grid;
    place-items: center;
    width: 7.2rem;
    aspect-ratio: 1;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 50%;
    color: rgba(var(--rgb-text), .58);
    font-size: .52rem;
    transform: translate(-50%, -50%);
    backdrop-filter: blur(8px);
  }

  .growth-core span {
    align-self: end;
    color: #fff;
    font: 500 1.6rem/1 var(--font-display);
    letter-spacing: 0;
  }

  .growth-core b { align-self: start; font-weight: 500; }

  .growth-caption {
    top: 1.2rem;
    left: 1.2rem;
    color: rgba(var(--rgb-text), .48);
    font-size: .58rem;
  }

  @media (max-width: 760px) {
    .growth-observatory::after { width: 18rem; }
    .growth-core { width: 5.8rem; }
    .growth-caption { max-width: 13rem; line-height: 1.6; }
  }
</style>

<script>
  import * as THREE from "three";
  import gsap from "gsap";

  class GrowthObservatory {
    root: HTMLElement;
    canvas: HTMLCanvasElement;
    renderer: THREE.WebGLRenderer;
    scene: THREE.Scene;
    camera: THREE.PerspectiveCamera;
    rig = new THREE.Group();
    pillars: THREE.Mesh[] = [];
    particles!: THREE.Points;
    raf = 0;
    visible = false;
    pointer = new THREE.Vector2();
    observer: IntersectionObserver;
    resizeObserver: ResizeObserver;

    constructor(root: HTMLElement) {
      this.root = root;
      this.canvas = root.querySelector("canvas")!;
      this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, alpha: true, antialias: true });
      this.renderer.setPixelRatio(Math.min(devicePixelRatio || 1, 1.5));
      this.renderer.outputColorSpace = THREE.SRGBColorSpace;
      this.scene = new THREE.Scene();
      this.scene.fog = new THREE.FogExp2(0x030405, .055);
      this.camera = new THREE.PerspectiveCamera(42, 1, .1, 80);
      this.camera.position.set(0, 3.2, 10.5);
      this.camera.lookAt(0, .6, 0);
      this.scene.add(this.rig);
      this.build();

      this.observer = new IntersectionObserver(([entry]) => {
        this.visible = entry.isIntersecting;
        if (this.visible) {
          this.animateIn();
          this.tick();
        } else cancelAnimationFrame(this.raf);
      }, { rootMargin: "180px" });
      this.observer.observe(root);

      this.resizeObserver = new ResizeObserver(() => this.resize());
      this.resizeObserver.observe(root);
      root.addEventListener("pointermove", this.onPointer, { passive: true });
      root.addEventListener("pointerleave", this.onLeave, { passive: true });
      this.resize();
    }

    build() {
      this.scene.add(new THREE.AmbientLight(0xffffff, .48));
      const key = new THREE.PointLight(0xffffff, 13, 24);
      key.position.set(2, 7, 5);
      this.scene.add(key);
      const rim = new THREE.PointLight(0x9aa7b2, 8, 20);
      rim.position.set(-5, 2, -2);
      this.scene.add(rim);

      const grid = new THREE.GridHelper(18, 24, 0x87919a, 0x30353a);
      grid.material.transparent = true;
      grid.material.opacity = .18;
      grid.position.y = -1.9;
      this.rig.add(grid);

      const heights = [1.1, 4.1, 3.45];
      const xs = [-2.7, 0, 2.7];
      heights.forEach((height, index) => {
        const geometry = new THREE.BoxGeometry(1.05, height, 1.05, 1, 8, 1);
        const material = new THREE.MeshPhysicalMaterial({
          color: index === 0 ? 0x777f86 : 0xdde3e7,
          metalness: .84,
          roughness: .2,
          transmission: index === 0 ? .08 : .18,
          transparent: true,
          opacity: .88,
        });
        const pillar = new THREE.Mesh(geometry, material);
        pillar.position.set(xs[index], -1.9 + height / 2, 0);
        pillar.scale.y = .02;
        pillar.userData.height = height;
        this.pillars.push(pillar);
        this.rig.add(pillar);

        const edge = new THREE.LineSegments(
          new THREE.EdgesGeometry(geometry),
          new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: .38 }),
        );
        pillar.add(edge);
      });

      const curve = new THREE.CatmullRomCurve3([
        new THREE.Vector3(-4.6, -1.1, .2),
        new THREE.Vector3(-2.7, .2, .35),
        new THREE.Vector3(0, 2.8, .1),
        new THREE.Vector3(2.7, 2.15, -.05),
        new THREE.Vector3(4.8, 3.55, -.3),
      ]);
      const tube = new THREE.Mesh(
        new THREE.TubeGeometry(curve, 96, .025, 6, false),
        new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: .9 }),
      );
      this.rig.add(tube);

      const ringMaterial = new THREE.MeshBasicMaterial({ color: 0xcbd4da, transparent: true, opacity: .16, side: THREE.DoubleSide });
      [3.4, 4.4].forEach((radius, i) => {
        const ring = new THREE.Mesh(new THREE.RingGeometry(radius, radius + .012, 160), ringMaterial.clone());
        ring.rotation.x = Math.PI / 2.45 + i * .16;
        ring.rotation.z = i * .7;
        this.rig.add(ring);
      });

      const positions = new Float32Array(520 * 3);
      for (let i = 0; i < 520; i++) {
        const r = 2.8 + Math.random() * 4.8;
        const a = Math.random() * Math.PI * 2;
        positions[i * 3] = Math.cos(a) * r;
        positions[i * 3 + 1] = (Math.random() - .5) * 7;
        positions[i * 3 + 2] = Math.sin(a) * r - 1;
      }
      const dust = new THREE.BufferGeometry();
      dust.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      this.particles = new THREE.Points(dust, new THREE.PointsMaterial({
        color: 0xe5ebef,
        size: .035,
        transparent: true,
        opacity: .52,
        depthWrite: false,
      }));
      this.rig.add(this.particles);
    }

    animateIn() {
      if (this.root.dataset.played === "true") return;
      this.root.dataset.played = "true";
      gsap.to(this.pillars.map((pillar) => pillar.scale), {
        y: 1,
        duration: 1.4,
        ease: "power4.out",
        stagger: .14,
      });
      gsap.fromTo(this.rig.rotation, { y: -.22 }, { y: 0, duration: 1.7, ease: "power3.out" });
    }

    onPointer = (event: PointerEvent) => {
      const rect = this.root.getBoundingClientRect();
      this.pointer.set((event.clientX - rect.left) / rect.width - .5, (event.clientY - rect.top) / rect.height - .5);
    };

    onLeave = () => this.pointer.set(0, 0);

    resize() {
      const rect = this.root.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      this.renderer.setSize(rect.width, rect.height, false);
      this.camera.aspect = rect.width / rect.height;
      this.camera.updateProjectionMatrix();
    }

    tick = () => {
      if (!this.visible) return;
      const t = performance.now() * .00016;
      this.rig.rotation.y += (this.pointer.x * .26 - this.rig.rotation.y) * .035;
      this.rig.rotation.x += (-this.pointer.y * .12 - this.rig.rotation.x) * .035;
      this.particles.rotation.y = t;
      this.particles.rotation.x = Math.sin(t) * .08;
      this.renderer.render(this.scene, this.camera);
      this.raf = requestAnimationFrame(this.tick);
    };
  }

  document.querySelectorAll<HTMLElement>("[data-growth-observatory]").forEach((root) => new GrowthObservatory(root));
</script>
