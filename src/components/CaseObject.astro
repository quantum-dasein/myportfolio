---
interface Props {
  variant: "bridge" | "fidic";
}

const { variant } = Astro.props;
---

<rb-case-object data-variant={variant} aria-hidden="true"></rb-case-object>

<style>
  rb-case-object {
    position: absolute;
    inset: -16% -14%;
    z-index: 2;
    pointer-events: none;
    opacity: 0.92;
  }

  rb-case-object canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }
</style>

<script>
  import * as THREE from "three";
  import gsap from "gsap";

  class CaseObject extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private scene?: THREE.Scene;
    private camera?: THREE.PerspectiveCamera;
    private group = new THREE.Group();
    private observer?: IntersectionObserver;
    private active = true;
    private mouse = new THREE.Vector2();
    private targetMouse = new THREE.Vector2();
    private tick = (t: number) => this.render(t);
    private disposables: Array<{ dispose: () => void }> = [];

    connectedCallback() {
      this.scene = new THREE.Scene();
      this.camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
      this.camera.position.set(0, 0, 8);
      this.scene.add(this.group);
      this.scene.add(new THREE.AmbientLight(0xaeb8c8, 1.05));
      const key = new THREE.PointLight(0x9bbed2, 10, 20);
      key.position.set(-2.6, 2.4, 4.4);
      this.scene.add(key);
      const fill = new THREE.PointLight(0x5c3a6e, 7, 18);
      fill.position.set(2.4, -1.8, 4.2);
      this.scene.add(fill);
      this.build(this.dataset.variant === "fidic" ? "fidic" : "bridge");

      this.renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: "high-performance" });
      this.renderer.setClearColor(0x000000, 0);
      this.appendChild(this.renderer.domElement);
      this.resize();

      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointer, { passive: true });
      this.observer = new IntersectionObserver(([entry]) => {
        this.active = Boolean(entry?.isIntersecting);
      });
      this.observer.observe(this);
      gsap.ticker.add(this.tick);
    }

    disconnectedCallback() {
      gsap.ticker.remove(this.tick);
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointer);
      this.observer?.disconnect();
      this.disposables.forEach((item) => item.dispose());
      this.renderer?.dispose();
      this.renderer?.domElement.remove();
    }

    private material(color: number, opacity = 0.42, emissive = 0.08) {
      const mat = new THREE.MeshPhysicalMaterial({
        color,
        emissive: color,
        emissiveIntensity: emissive,
        roughness: 0.42,
        metalness: 0.26,
        transparent: true,
        opacity,
        clearcoat: 1,
        clearcoatRoughness: 0.18,
        side: THREE.DoubleSide,
      });
      this.disposables.push(mat);
      return mat;
    }

    private edge(mesh: THREE.Mesh, color: number, opacity = 0.62) {
      const geo = new THREE.EdgesGeometry(mesh.geometry);
      const mat = new THREE.LineBasicMaterial({ color, transparent: true, opacity });
      const lines = new THREE.LineSegments(geo, mat);
      lines.position.copy(mesh.position);
      lines.rotation.copy(mesh.rotation);
      lines.scale.copy(mesh.scale);
      this.group.add(lines);
      this.disposables.push(geo, mat);
    }

    private build(kind: "bridge" | "fidic") {
      const primary = kind === "bridge" ? 0x9bbed2 : 0xb09ac2;
      const secondary = kind === "bridge" ? 0x314b66 : 0x493454;
      const chrome = this.material(primary, 0.76, 0.14);
      const dark = this.material(secondary, 0.82, 0.06);
      const atmosphere = this.material(primary, 0.12, 0.34);
      const lineMat = new THREE.LineBasicMaterial({ color: primary, transparent: true, opacity: 0.5 });
      this.disposables.push(lineMat);

      const planetGeo = new THREE.IcosahedronGeometry(kind === "bridge" ? 1.35 : 1.48, 8);
      const planet = new THREE.Mesh(planetGeo, dark);
      planet.rotation.z = kind === "bridge" ? -0.22 : 0.14;
      this.group.add(planet);
      this.disposables.push(planetGeo);

      const atmoGeo = new THREE.SphereGeometry(kind === "bridge" ? 1.52 : 1.68, 64, 32);
      const atmo = new THREE.Mesh(atmoGeo, atmosphere);
      this.group.add(atmo);
      this.disposables.push(atmoGeo);

      const ringCount = kind === "bridge" ? 3 : 5;
      for (let i = 0; i < ringCount; i++) {
        const radius = (kind === "bridge" ? 1.72 : 1.86) + i * 0.18;
        const ring = new THREE.LineLoop(
          new THREE.BufferGeometry().setFromPoints(
            new Array(220).fill(0).map((_, n) => {
              const a = (n / 220) * Math.PI * 2;
              return new THREE.Vector3(Math.cos(a) * radius, Math.sin(a) * radius * (0.42 + i * 0.035), 0);
            }),
          ),
          lineMat.clone(),
        );
        ring.rotation.x = 0.95 + i * 0.08;
        ring.rotation.y = -0.32 + i * 0.055;
        ring.rotation.z = i * 0.34;
        this.group.add(ring);
        this.disposables.push(ring.geometry, ring.material as THREE.Material);
      }

      const satelliteGeo = kind === "bridge" ? new THREE.ConeGeometry(0.08, 0.28, 4) : new THREE.BoxGeometry(0.22, 0.035, 0.32);
      for (let i = 0; i < (kind === "bridge" ? 7 : 10); i++) {
        const a = (i / (kind === "bridge" ? 7 : 10)) * Math.PI * 2;
        const r = 2.05 + (i % 3) * 0.26;
        const sat = new THREE.Mesh(satelliteGeo, i % 2 ? chrome : dark);
        sat.position.set(Math.cos(a) * r, Math.sin(a) * 0.62, Math.sin(a) * r * 0.28);
        sat.rotation.set(a * 0.2, a, a * 0.4);
        this.group.add(sat);
      }
      this.disposables.push(satelliteGeo);
    }

    private onPointer = (event: PointerEvent) => {
      const rect = this.getBoundingClientRect();
      this.targetMouse.set(
        ((event.clientX - rect.left) / rect.width) * 2 - 1,
        -(((event.clientY - rect.top) / rect.height) * 2 - 1),
      );
    };

    private resize = () => {
      if (!this.renderer || !this.camera) return;
      const rect = this.getBoundingClientRect();
      const w = Math.max(1, rect.width);
      const h = Math.max(1, rect.height);
      const dpr = Math.min(devicePixelRatio || 1, 1.75);
      this.renderer.setPixelRatio(dpr);
      this.renderer.setSize(w, h, false);
      this.camera.aspect = w / h;
      this.camera.updateProjectionMatrix();
    };

    private render(time: number) {
      if (!this.active || !this.renderer || !this.scene || !this.camera) return;
      this.mouse.lerp(this.targetMouse, 0.06);
      this.group.rotation.y = time * 0.12 + this.mouse.x * 0.32;
      this.group.rotation.x = -0.12 + this.mouse.y * 0.22 + Math.sin(time * 0.5) * 0.035;
      this.group.rotation.z = Math.sin(time * 0.25) * 0.035;
      this.group.position.y = Math.sin(time * 0.45) * 0.08;
      this.renderer.render(this.scene, this.camera);
    }
  }

  if (!customElements.get("rb-case-object")) {
    customElements.define("rb-case-object", CaseObject);
  }
</script>
