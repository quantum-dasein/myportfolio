  .branch { position: absolute; left: 50%; top: 50%; width: 72%; height: 38%; border: 1px solid rgba(255,255,255,.16); border-radius: 50%; transform: translate(-50%,-50%) rotate(var(--r)); }
  .branch-a { --r: 0deg; } .branch-b { --r: 60deg; } .branch-c { --r: 120deg; }
  .code-orbit em { position: absolute; color: rgba(var(--rgb-text),.55); font: normal .56rem/1 var(--font-inter); letter-spacing: .13em; }
  .code-orbit em:nth-of-type(1) { left: 8%; top: 28%; }
