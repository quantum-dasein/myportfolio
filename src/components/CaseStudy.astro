---
import Layout from "../layouts/Layout.astro";
import BridgeDataScene from "./BridgeDataScene.astro";
import { useTranslations, type UIKey } from "../i18n/utils";

interface CaseItem {
  label: string;
  value: string;
  translated?: boolean;
}

interface Props {
  id: "bridge" | "fidic";
  image: string;
  nextHref: string;
  liveUrl?: string;
  stack: string;
  year: string;
}

const { id, image, nextHref, liveUrl, stack, year } = Astro.props;
const isBridge = id === "bridge";
const liveHost = liveUrl ? new URL(liveUrl).hostname.replace(/^www\./, "") : "";
const t = useTranslations();
const tk = (key: string) => t(key as UIKey);

const key = (part: string) => `case.${id}.${part}`;
const titleKey = key("title");
const items: CaseItem[] = [
  { label: "case.role", value: key("role.value"), translated: true },
  { label: "case.stack", value: stack },
  { label: "case.year", value: year },
  { label: "case.scope", value: key("scope.value"), translated: true },
];
const highlights = [1, 2, 3].map((n) => key(`highlight.${n}`));
const process = [1, 2, 3].map((n) => key(`process.${n}`));
const bridgeMetrics = [
  { value: "+780%", key: "case.bridge.metric.organic", detail: "5 -> 44", fill: "100%" },
  { value: "+626.67%", key: "case.bridge.metric.users", detail: "109", fill: "82%" },
  { value: "+645.69%", key: "case.bridge.metric.events", detail: "865", fill: "88%" },
  { value: "04", key: "case.bridge.metric.markets", detail: "UZ / US / AT / PL", fill: "64%" },
];
const bridgeWorkflow = [
  { no: "01", key: "case.bridge.workflow.human", tool: "Cinema 4D / After Effects" },
  { no: "02", key: "case.bridge.workflow.gemini", tool: "Gemini" },
  { no: "03", key: "case.bridge.workflow.claude", tool: "Claude" },
  { no: "04", key: "case.bridge.workflow.cursor", tool: "Cursor / Codex" },
];
const bridgeSystems = [
  { no: "01", title: "case.bridge.system.positioning.title", text: "case.bridge.system.positioning.text", meta: "MARKET / TRUST" },
  { no: "02", title: "case.bridge.system.content.title", text: "case.bridge.system.content.text", meta: "RU / EN / UZ" },
  { no: "03", title: "case.bridge.system.search.title", text: "case.bridge.system.search.text", meta: "SCHEMA / HREFLANG" },
  { no: "04", title: "case.bridge.system.universe.title", text: "case.bridge.system.universe.text", meta: "THREE.JS / 08 NODES" },
];
const fidicMetrics = [
  { value: "109", label: "case.fidic.metric.routes", meta: "ASTRO ROUTES" },
  { value: "105", label: "case.fidic.metric.articles", meta: "EXPERT MDX" },
  { value: "09", label: "case.fidic.metric.books", meta: "FIDIC LIBRARY" },
  { value: "15", label: "case.fidic.metric.tools", meta: "TOOLS + CALCULATORS" },
  { value: "03", label: "case.fidic.metric.languages", meta: "RU / EN / UZ" },
];
const fidicLayers = [
  { no: "01", key: "case.fidic.layer.knowledge", meta: "105 / MDX" },
  { no: "02", key: "case.fidic.layer.books", meta: "09 / CONTRACTS" },
  { no: "03", key: "case.fidic.layer.tools", meta: "10 / WORKFLOWS" },
  { no: "04", key: "case.fidic.layer.calculators", meta: "05 / MODELS" },
  { no: "05", key: "case.fidic.layer.ai", meta: "SERVERLESS / AI" },
  { no: "06", key: "case.fidic.layer.trust", meta: "CERTIFY / VERIFY" },
];
const seoTitle = isBridge
  ? "Bridge Consult Case Study | SEO & Astro by Rodion Belousov"
  : "FIDIC.uz Case Study | Content, SEO & Astro by Rodion Belousov";
const seoDescription = isBridge
  ? "How Rodion Belousov built Bridge Consult's multilingual Astro and Three.js website, technical SEO system and 780% organic search growth."
  : "Inside Rodion Belousov's solo build of FIDIC.uz: 109 Astro routes, 105 expert articles, technical SEO, contract tools and multilingual content.";
const seoKeywords = isBridge
  ? ["Bridge Consult case study", "Astro case study", "Three.js website", "technical SEO Austria", "multilingual website development", "AI-assisted web development"]
  : ["FIDIC knowledge platform", "FIDIC SEO", "Astro content platform", "technical SEO case study", "multilingual content architecture", "contract management tools"];
const caseSchema = {
  "@type": "CreativeWork",
  "@id": `https://rodionbelousov.studio/work/${isBridge ? "bridge-consult" : "fidic"}#project`,
  name: tk(titleKey),
  headline: seoTitle,
  description: seoDescription,
  image: new URL(image, "https://rodionbelousov.studio").toString(),
  dateCreated: "2026",
  inLanguage: ["en", "de-AT"],
  creator: { "@id": "https://rodionbelousov.studio/#rodion-belousov" },
  url: liveUrl,
  keywords: seoKeywords.join(", "),
  about: isBridge
    ? ["Infrastructure consulting", "Technical SEO", "Astro", "Three.js", "Multilingual content"]
    : ["FIDIC contracts", "Knowledge management", "Technical SEO", "Astro", "Content architecture"],
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  image={image}
  imageAlt={`${tk(titleKey)} digital marketing, technical SEO and creative web development case study`}
  pageType="article"
  keywords={seoKeywords}
  structuredData={caseSchema}
  theme={id}
>
  <article class="case" data-case-page>
    <section class="case-hero">
      <div class="case-bg" aria-hidden="true">
        <img src={image} alt="" />
      </div>

      <div class="u-container case-hero-inner">
        <a class="back-link" href="/en/#work" data-locale-hash="#work" data-case-back data-i18n="case.back" data-magnetic>{t("case.back")}</a>

        <div class="case-title-wrap">
          <span class="case-kicker" data-i18n={key("kicker")}>
            {tk(key("kicker"))}
          </span>
          <h1 class="case-title"><a href={liveUrl} target="_blank" rel="noopener" data-i18n={titleKey}>{tk(titleKey)}</a></h1>
          <p class="case-subtitle" data-reveal data-i18n={key("subtitle")}>{tk(key("subtitle"))}</p>
          {liveUrl && <a class="case-live-url" href={liveUrl} target="_blank" rel="noopener"><span>{liveHost}</span><b>LIVE <i class="ui-arrow" aria-hidden="true"></i></b></a>}
        </div>

        <div class:list={["case-visual", `case-visual-${id}`]} data-reveal style={`--case-image:url('${image}')`}>
          <span class="visual-depth visual-depth-a" aria-hidden="true"></span>
          <span class="visual-depth visual-depth-b" aria-hidden="true"></span>
          <div class="case-screen" data-magnetic>
            <img src={image} alt={`${tk(titleKey)} digital marketing and web development case study`} loading="eager" fetchpriority="high" />
            <span class="screen-index">{id === "bridge" ? "BC / 01" : "FIDIC / 02"}</span>
            <span class="screen-status">LIVE SYSTEM / 2026</span>
            <a class="screen-live" href={liveUrl} target="_blank" rel="noopener" aria-label={`${tk("case.visit")}: ${tk(titleKey)}`}><span class="ui-arrow" aria-hidden="true"></span></a>
          </div>
          <span class="visual-orbit" aria-hidden="true"></span>
        </div>
      </div>
    </section>

    {!isBridge && (
      <section class="fidic-platform" aria-labelledby="fidic-platform-title">
        <div class="u-container fidic-platform-head">
          <span class="chapter-label">PRODUCT ECOSYSTEM / SOLO BUILD / 2026</span>
          <h2 id="fidic-platform-title" data-i18n="case.fidic.platform.title">{tk("case.fidic.platform.title")}</h2>
          <p data-i18n="case.fidic.platform.text">{tk("case.fidic.platform.text")}</p>
        </div>
        <div class="u-container fidic-atlas" data-reveal>
          <div class="fidic-core" aria-hidden="true">
            <span>FIDIC</span><b>.UZ</b><small>KNOWLEDGE OS</small>
            <i></i><i></i><i></i>
          </div>
          <div class="fidic-metrics">
            {fidicMetrics.map((metric, index) => (
              <article class={`fidic-metric fidic-metric-${index + 1}`} data-kinetic>
                <span>{metric.meta}</span><strong>{metric.value}</strong><p data-i18n={metric.label}>{tk(metric.label)}</p>
              </article>
            ))}
          </div>
        </div>
        <div class="u-container fidic-layers">
          {fidicLayers.map((layer) => (
            <article data-kinetic>
              <span>{layer.no}</span><small>{layer.meta}</small>
              <h3 data-i18n={`${layer.key}.title`}>{tk(`${layer.key}.title`)}</h3>
              <p data-i18n={`${layer.key}.text`}>{tk(`${layer.key}.text`)}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    {isBridge && (
      <section class="bridge-impact" aria-labelledby="bridge-impact-title">
        <div class="u-container impact-head">
          <span class="chapter-label">GA4 / EARLY LAUNCH SIGNAL</span>
          <h2 id="bridge-impact-title" data-i18n="case.bridge.impact.title">{tk("case.bridge.impact.title")}</h2>
          <p data-i18n="case.bridge.impact.text">{tk("case.bridge.impact.text")}</p>
        </div>

        <div class="u-container impact-stage" data-reveal>
          <BridgeDataScene />
          <div class="metric-grid">
            {bridgeMetrics.map((metric, index) => (
              <article class:list={["metric", `metric-${index + 1}`]} data-kinetic>
                <span class="metric-no">0{index + 1}</span>
                <strong>{metric.value}</strong>
                <p data-i18n={metric.key}>{tk(metric.key)}</p>
                <div class="metric-track" aria-hidden="true"><i style={`--fill:${metric.fill}`}></i></div>
                <small>{metric.detail}</small>
              </article>
            ))}
          </div>
        </div>
        <div class="u-container impact-proofline" data-reveal>
          <span>GA4 / VERIFIED LAUNCH WINDOW</span>
          <p data-i18n="case.bridge.impact.note">{tk("case.bridge.impact.note")}</p>
          <b>BASELINE -> WEEK 03</b>
        </div>
      </section>
    )}

    <section class="case-strip">
      <div class="u-container case-strip-inner">
        {
          items.map((item) => (
            <div class="case-stat" data-kinetic>
              <span data-i18n={item.label}>{tk(item.label)}</span>
              {item.translated ? (
                <strong data-i18n={item.value}>{tk(item.value)}</strong>
              ) : (
                <strong>{item.value}</strong>
              )}
            </div>
          ))
        }
      </div>
    </section>

    {isBridge && (
      <section class="bridge-system-map">
        <div class="u-container system-map-head">
          <span class="chapter-label">ONE MONTH / TWO LAUNCHES / 2026</span>
          <h2 data-i18n="case.bridge.system.title">{tk("case.bridge.system.title")}</h2>
          <p data-i18n="case.bridge.system.text">{tk("case.bridge.system.text")}</p>
        </div>
        <div class="u-container system-rail">
          {bridgeSystems.map((item) => (
            <article data-kinetic>
              <span class="system-no">{item.no}</span>
              <span class="system-meta">{item.meta}</span>
              <h3 data-i18n={item.title}>{tk(item.title)}</h3>
              <p data-i18n={item.text}>{tk(item.text)}</p>
              <i aria-hidden="true"></i>
            </article>
          ))}
        </div>
      </section>
    )}

    {isBridge && (
      <section class="bridge-build-system">
        <div class="u-container build-head">
          <span class="chapter-label">HUMAN DIRECTION / AI LEVERAGE</span>
          <h2 data-i18n="case.bridge.workflow.title">{tk("case.bridge.workflow.title")}</h2>
          <p data-i18n="case.bridge.workflow.text">{tk("case.bridge.workflow.text")}</p>
        </div>
        <div class="u-container workflow-grid">
          {bridgeWorkflow.map((item) => (
            <article data-kinetic>
              <span>{item.no}</span>
              <strong>{item.tool}</strong>
              <p data-i18n={item.key}>{tk(item.key)}</p>
            </article>
          ))}
        </div>
        <div class="u-container proof-grid">
          <a class="proof-node proof-code" href="https://github.com/quantum-dasein/bridge-astro" target="_blank" rel="noopener" data-kinetic>
            <div class="proof-top"><span>PUBLIC REPOSITORY</span><b>ASTRO 6 / OPEN SOURCE</b></div>
            <div class="code-orbit" aria-hidden="true">
              <span class="code-core">BC</span>
              <i class="branch branch-a"></i><i class="branch branch-b"></i><i class="branch branch-c"></i>
              <em>CONTENT</em><em>SEO</em><em>WEBGL</em>
            </div>
            <div class="proof-bottom"><span>MODULAR BUILD / AUTOMATED SITEMAP</span><b>OPEN GITHUB -></b></div>
          </a>
          <a class="proof-node proof-universe" href="https://www.bridgeconsult.uz/EN/projects.html" target="_blank" rel="noopener" data-kinetic>
            <div class="proof-top"><span>THREE.JS PROJECT UNIVERSE</span><b>08 INFRASTRUCTURE NODES</b></div>
            <div class="mini-universe" aria-hidden="true">
              <span class="planet"></span>
              {Array.from({ length: 8 }).map((_, index) => <i style={`--i:${index}`}></i>)}
            </div>
            <div class="proof-bottom"><span>DRAG / ROTATE / EXPLORE</span><b>ENTER LIVE SCENE -></b></div>
          </a>
        </div>
      </section>
    )}

    <section class="case-body">
      <div class="u-container case-body-grid">
        <aside class="case-index" data-reveal>
          <span>{id === "bridge" ? "BC/01" : "FIDIC/02"}</span>
          <p>{stack}</p>
        </aside>

        <div class="case-main">
          <section class="case-chapter">
            <span class="chapter-label" data-i18n="case.problem">{t("case.problem")}</span>
            <p data-kinetic data-i18n={key("problem.text")}>{tk(key("problem.text"))}</p>
          </section>

          <section class="case-chapter">
            <span class="chapter-label" data-i18n="case.solution">{t("case.solution")}</span>
            <p data-kinetic data-i18n={key("solution.text")}>{tk(key("solution.text"))}</p>
          </section>

          <section class="case-chapter">
            <span class="chapter-label" data-i18n="case.outcome">{t("case.outcome")}</span>
            <p data-kinetic data-i18n={key("outcome.text")}>{tk(key("outcome.text"))}</p>
          </section>
        </div>
      </div>
    </section>

    <section class="case-highlights">
      <div class="u-container case-highlight-grid">
        <div>
          <span class="chapter-label" data-i18n="case.highlights">{t("case.highlights")}</span>
          <h2 data-sy-reveal="words" data-i18n={key("mantra")}>{tk(key("mantra"))}</h2>
        </div>

        <div class="highlight-list">
          {
            highlights.map((highlight, index) => (
              <article data-kinetic>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <p data-i18n={highlight}>{tk(highlight)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="case-process">
      <div class="u-container">
        <span class="chapter-label" data-i18n="case.process">{t("case.process")}</span>
        <div class="process-list">
          {
            process.map((row, index) => (
              <article data-kinetic>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <p data-i18n={row}>{tk(row)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="case-visual-language">
      <div class="u-container visual-language-inner">
        <div>
          <span class="chapter-label" data-i18n="case.visual">{t("case.visual")}</span>
          <p data-kinetic data-i18n={key("visual.text")}>{tk(key("visual.text"))}</p>
        </div>
        <div class="specimen" data-reveal>
          <div class="specimen-axis"><span>VISUAL SYSTEM / 04</span><b>{isBridge ? "BRIDGE CONSULT" : "FIDIC.UZ"}</b></div>
          <span class="specimen-module specimen-module-a"><b>01</b><em>EDITORIAL GRID</em></span>
          <span class="specimen-module specimen-module-b"><b>02</b><em>{isBridge ? "NOIR GLASS" : "CONTRACT ATLAS"}</em></span>
          <span class="specimen-module specimen-module-c"><b>03</b><em>{isBridge ? "CHROME SIGNAL" : "FIDIC GOLD"}</em></span>
          <i class="specimen-orbit" aria-hidden="true"></i>
        </div>
      </div>
    </section>

    <section class="case-next">
      <div class="u-container next-inner">
        {liveUrl && (
          <a class="case-button secondary" href={liveUrl} target="_blank" rel="noopener" data-magnetic>
            <span data-i18n="case.visit">{t("case.visit")}</span>
            <span class="ui-arrow" aria-hidden="true"></span>
          </a>
        )}
        <a class="case-button" href={nextHref} data-case-link data-magnetic>
          <span data-i18n="case.next">{t("case.next")}</span>
          <span aria-hidden="true">-></span>
        </a>
      </div>
    </section>
  </article>
</Layout>

<style>
  .case {
    --case-accent: 204, 180, 132;
    position: relative;
    overflow: clip;
    background:
      radial-gradient(circle at 78% 12%, rgba(var(--rgb-cosmic-pink), 0.1), transparent 24rem),
      radial-gradient(circle at 28% 28%, rgba(var(--rgb-accent), 0.08), transparent 28rem),
      linear-gradient(180deg, rgba(2, 3, 5, 0.96), rgba(2, 3, 5, 0.98) 45%, rgba(2, 3, 5, 0.96)),
      #020305;
  }

  :global(body.case-theme-fidic) .case { --case-accent: 219, 169, 73; }

  .case-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .case-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.22;
    transform: scale(1.03);
  }

  .case-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 76% 36%, rgba(var(--rgb-accent), 0.18), transparent 24%),
      linear-gradient(90deg, rgba(3, 4, 11, 0.96), rgba(3, 4, 11, 0.56) 52%, rgba(3, 4, 11, 0.9)),
      linear-gradient(180deg, rgba(3, 4, 11, 0.38), var(--color-bg));
  }

  .case-bg img,
  .case-screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(22rem, 0.72fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    min-height: 100svh;
    padding: 8rem 0 5rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
      padding-top: 7rem;
    }
  }

  .back-link {
    position: absolute;
    top: 5.6rem;
    left: 0;
    color: var(--color-text-alt);
    font-size: var(--font-size-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;

    &:hover {
      color: var(--color-accent);
    }
  }

  .case-kicker,
  .chapter-label {
    display: inline-block;
    color: var(--color-accent);
    font-size: var(--font-size-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .case-title {
    max-width: 9ch;
    margin: 1.3rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 8.5vw, 8.8rem);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .case-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(90deg, rgba(var(--case-accent), .92), rgba(255,255,255,.9));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 2px;
    transition: background-size .65s var(--ease-out-expo), color .35s ease;
  }

  .case-title a:hover { color: rgb(var(--case-accent)); background-size: 100% 2px; }

  .case-live-url {
    display: flex;
    width: min(25rem, 100%);
    justify-content: space-between;
    margin-top: 1.6rem;
    padding-bottom: .65rem;
    border-bottom: 1px solid rgba(var(--case-accent), .5);
    color: rgba(var(--rgb-text), .72);
    font-size: .68rem;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .case-live-url b { color: rgb(var(--case-accent)); font-weight: 500; }

  .case-subtitle {
    max-width: 44rem;
    margin: 2rem 0 0;
    color: rgba(var(--rgb-text), 0.72);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.55;
  }

  .case-visual {
    position: relative;
    min-height: clamp(31rem, 52vw, 43rem);
    perspective: 1400px;
    isolation: isolate;
  }

  .case-screen {
    position: absolute;
    inset: 3% 6% 3% 9%;
    z-index: 1;
    overflow: hidden;
    border: 1px solid rgba(var(--case-accent), 0.46);
    background:
      linear-gradient(135deg, rgba(var(--rgb-accent), 0.12), transparent 34%),
      var(--color-elev);
    transform: rotateY(-7deg) rotateX(2deg) translateZ(2rem);
    opacity: 1;
    box-shadow:
      0 0 5rem rgba(var(--rgb-accent), 0.1),
      0 3rem 8rem rgba(0, 0, 0, 0.58),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    animation: case-portal-float 7s ease-in-out infinite alternate;
  }

  .case-screen img { object-position: center; }

  .case-screen::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 74% 22%, rgba(var(--case-accent), .2), transparent 23%),
      linear-gradient(180deg, transparent 42%, rgba(0, 0, 0, 0.44));
    pointer-events: none;
  }

  .visual-depth {
    position: absolute;
    z-index: 0;
    inset: 9% 1% 9% 16%;
    border: 1px solid rgba(var(--case-accent), .16);
    background: var(--case-image) center/cover;
    opacity: .16;
    filter: saturate(.55) contrast(1.12);
    transform: translateZ(-5rem) rotateY(-11deg);
  }

  .visual-depth-b { inset: 15% -3% 15% 22%; opacity: .08; transform: translateZ(-9rem) rotateY(-15deg); }

  .visual-orbit {
    position: absolute;
    z-index: 3;
    left: 48%;
    top: 50%;
    width: 118%;
    aspect-ratio: 1;
    border: 1px solid rgba(var(--case-accent), .22);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotateX(72deg);
    pointer-events: none;
    animation: portal-orbit 12s linear infinite;
  }

  .visual-orbit::after {
    content: "";
    position: absolute;
    left: 18%; top: 4%;
    width: .42rem; aspect-ratio: 1;
    border-radius: 50%;
    background: rgb(var(--case-accent));
    box-shadow: 0 0 1.5rem rgba(var(--case-accent), .9);
  }

  .screen-index,
  .screen-status,
