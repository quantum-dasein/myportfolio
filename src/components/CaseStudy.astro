  }

  [data-kinetic] {
    --mx: 50%;
    --my: 50%;
    opacity: 0;
    transform: translateY(34px) rotateX(5deg) scale(.985);
    transform-origin: center bottom;
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }

  @media (max-width: 1050px) {
    .case-hero-inner { grid-template-columns: minmax(0, 1fr) minmax(19rem, .72fr); gap: 2rem; }
    .case-title { font-size: clamp(4rem, 9.5vw, 7rem); }
    .workflow-grid,
    .system-rail { grid-template-columns: repeat(2, minmax(0, 1fr)); }
