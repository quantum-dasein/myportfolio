    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1rem;
    border: 1px solid rgba(var(--rgb-accent), 0.5);
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.01));
    backdrop-filter: blur(12px);
    box-shadow: 0 1.5rem 3rem rgba(0,0,0,.32);
  }

  .specimen-module b { font: 500 .62rem/1 var(--font-inter); color: rgba(var(--rgb-text),.55); }
  .specimen-module em { font: normal .62rem/1 var(--font-inter); color: #fff; letter-spacing: .12em; }

  .specimen-module-a {
    inset: 12% 42% 18% 12%;
  }

  .specimen-module-b {
    inset: 24% 18% 34% 52%;
  }

  .specimen-module-c {
    inset: 62% 12% 12% 36%;
  }

  .specimen-orbit {
    position: absolute;
    z-index: 2;
    left: 50%;
    top: 55%;
    width: 72%;
    aspect-ratio: 1;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 50%;
    transform: translate(-50%,-50%) rotateX(68deg);
    animation: specimen-spin 9s linear infinite;
  }

  .specimen-orbit::after {
    content: "";
    position: absolute;
    left: 14%;
    top: 4%;
    width: .42rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 1.2rem #fff;
  }

  @keyframes specimen-spin { to { transform: translate(-50%,-50%) rotateX(68deg) rotateZ(360deg); } }

  .next-inner {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .case-button {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 3.2rem;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    background: var(--color-text);
    color: var(--color-black);
    transition:
      transform 0.35s var(--ease-out-expo),
      background 0.35s var(--ease-out-expo);
  }

  .case-button.secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-line);
  }

  .case-button:hover {
    transform: translateY(-2px);
    background: var(--color-accent);
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
  }

  [data-kinetic] {
    --mx: 50%;
    --my: 50%;
    opacity: 0;
    transform: translateY(34px) rotateX(5deg) scale(.985);
    transform-origin: center bottom;
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }

  @media (max-width: 1050px) {
    .case-hero-inner { grid-template-columns: minmax(0, 1fr) minmax(19rem, .72fr); gap: 2rem; }
    .case-title { font-size: clamp(4rem, 9.5vw, 7rem); }
    .workflow-grid,
    .system-rail { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .fidic-layers { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .metric strong { font-size: clamp(2rem, 5.2vw, 3.4rem); }
  }

  @media (max-width: 760px) {
    .case-hero { min-height: auto; }
    .case-hero-inner { grid-template-columns: 1fr; min-height: auto; padding: 8.5rem 0 4rem; }
    .case-title {
      max-width: 100%;
      font-size: clamp(3.25rem, 16.5vw, 5.15rem);
      line-height: .92;
      overflow-wrap: anywhere;
    }
    .case-subtitle { margin-top: 1.35rem; font-size: 1.05rem; line-height: 1.48; }
    .case-visual { min-height: 31rem; }
    .case-screen { inset: 0 8%; transform: none; }
    .impact-head,
    .build-head,
    .system-map-head,
    .fidic-platform-head,
    .proof-grid { grid-template-columns: 1fr; }
    .workflow-grid,
    .system-rail { grid-template-columns: 1fr; }
    .metric-grid {
      inset: 10rem .7rem 7.5rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: repeat(2, 1fr);
      gap: .55rem;
    }
    .metric { min-height: 0; padding: .82rem; backdrop-filter: none; }
    .metric strong { margin-top: .85rem; font-size: clamp(1.45rem, 7vw, 2.4rem); }
    .metric p { margin: .42rem 0 .7rem; font-size: .76rem; }
    .metric-track { margin-bottom: .55rem; }
    .impact-stage { min-height: 48rem; margin-top: 2rem; }
    .impact-proofline { grid-template-columns: 1fr; gap: .7rem; }
    .impact-proofline p { text-align: left; }
    .impact-proofline b { text-align: left; }
    .system-rail article { min-height: 18rem; }
    .proof-grid a { min-height: 18rem; }
    .proof-node { min-height: 25rem !important; }
    .proof-top,
    .proof-bottom { align-items: flex-start; flex-direction: column; }
    .fidic-atlas { min-height: 48rem; }
    .fidic-core { top: 43%; }
    .fidic-metrics { inset: .7rem; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: .55rem; align-content: end; }
    .fidic-metric { position: relative; inset: auto !important; width: auto; min-height: 8rem; backdrop-filter: none; }
    .fidic-metric-5 { grid-column: 1 / -1; }
    .fidic-layers { grid-template-columns: 1fr; }
    .fidic-layers article { min-height: 15rem; }
  }

  @media (max-width: 520px) {
    .case-hero-inner { padding-top: 7.25rem; }
    .case-title { font-size: clamp(3rem, 16vw, 4.25rem); }
    .case-live-url { font-size: .58rem; letter-spacing: .1em; }
    .case-visual { min-height: 26rem; }
    .case-screen { inset-inline: 2%; }

    .impact-head h2,
    .build-head h2,
    .system-map-head h2,
    .fidic-platform-head h2 {
      max-width: 100%;
      font-size: clamp(2.55rem, 12.2vw, 3.55rem);
      line-height: .96;
      text-wrap: balance;
    }

    .impact-head > p,
    .build-head > p,
    .system-map-head > p,
    .fidic-platform-head > p { font-size: 1rem; line-height: 1.5; }

    .impact-stage { min-height: 70rem; }
    .metric-grid {
      inset: 7rem .35rem 5.5rem;
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, minmax(0, 1fr));
      gap: .55rem;
    }
    .metric-2,
    .metric-3,
    .metric-4 { grid-column: 1; grid-row: auto; align-self: stretch; }
    .metric { min-height: 0; padding: .9rem 1rem; }
    .metric strong { margin-top: .65rem; font-size: clamp(2rem, 10.8vw, 2.75rem); white-space: nowrap; }
    .metric p { margin-block: .4rem .65rem; font-size: .82rem; }

    .fidic-atlas { min-height: 66rem; }
    .fidic-core { top: 25%; width: 9rem; }
    .fidic-metrics {
      inset: auto .55rem .55rem;
      grid-template-columns: 1fr;
      align-content: end;
    }
    .fidic-metric,
    .fidic-metric-5 { grid-column: auto; min-height: 7.25rem; }
    .fidic-metric strong { margin-top: .55rem; font-size: 2rem; }

    .case-chapter p,
    .visual-language-inner p,
    .highlight-list article,
    .process-list article { overflow-wrap: break-word; }
  }

  @media (pointer: coarse) {
    .case-screen { animation-duration: 11s; }
    .visual-orbit,
    .fidic-atlas::before,
    .fidic-atlas::after { animation-duration: 26s; }
    .metric,
    .fidic-metric,
    .case-strip,
    .case-stat,
    .case-chapter p,
    .visual-language-inner p,
    .highlight-list article,
    .process-list article,
    .specimen-module { backdrop-filter: none; }
    .metric::after { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
    }
    [data-kinetic] { opacity: 1; transform: none; }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const reveal = gsap.utils.toArray<HTMLElement>("[data-reveal]");
  const kinetic = gsap.utils.toArray<HTMLElement>("[data-kinetic]");

  if (reduced) {
    gsap.set([...reveal, ...kinetic], { opacity: 1, y: 0, rotateX: 0, scale: 1 });
  } else {
    ScrollTrigger.batch(reveal, {
      start: "top 88%",
      once: true,
      onEnter: (batch) =>
        gsap.to(batch, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power3.out",
          stagger: 0.08,
          overwrite: true,
        }),
      onEnterBack: (batch) => gsap.set(batch, { opacity: 1, y: 0 }),
    });

    ScrollTrigger.batch(kinetic, {
      start: "top 91%",
      once: true,
      onEnter: (batch) => batch.forEach((card, index) => {
        gsap.to(card, {
          opacity: 1,
          y: 0,
          rotateX: 0,
          scale: 1,
          duration: 1.05,
          delay: index * .055,
          ease: "power4.out",
          clearProps: "willChange",
        });
        const children = Array.from(card.children).filter((child) => !(child as HTMLElement).classList.contains("metric-track"));
        if (children.length) {
          gsap.fromTo(children, { opacity: 0, y: 12 }, {
            opacity: 1,
            y: 0,
            duration: .72,
            delay: .18 + index * .055,
            stagger: .045,
            ease: "power3.out",
          });
        }
        card.querySelectorAll<HTMLElement>(".metric-track i").forEach((track) => {
          gsap.to(track, { scaleX: 1, duration: 1.3, delay: .35 + index * .07, ease: "power3.out" });
        });
      }),
      onEnterBack: (batch) => gsap.set(batch, { opacity: 1, y: 0, rotateX: 0, rotateY: 0, scale: 1 }),
    });

    gsap.timeline({ defaults: { ease: "power4.out" }, delay: .08 })
      .fromTo(".case-screen", {
        clipPath: "inset(47% 0 47% 0 round 6px)",
        rotateY: -14,
        rotateX: 5,
        scale: .92,
      }, {
        clipPath: "inset(0% 0 0% 0 round 6px)",
        rotateY: -5,
        rotateX: 1,
        scale: 1,
        duration: 1.35,
      })
      .fromTo(".case-screen img", { scale: 1.16, filter: "brightness(.25)" }, { scale: 1, filter: "brightness(1)", duration: 1.5 }, "<")
      .fromTo(".case-kicker, .case-title, .case-subtitle", { opacity: 0, y: 28 }, { opacity: 1, y: 0, duration: .9, stagger: .09 }, .22);

    gsap.to(".case-bg img", {
      yPercent: 10,
      ease: "none",
      scrollTrigger: {
        trigger: ".case-hero",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });

    if (matchMedia("(hover: hover) and (pointer: fine)").matches) {
      kinetic.forEach((card) => {
        const xTo = gsap.quickTo(card, "rotateY", { duration: .55, ease: "power3.out" });
        const yTo = gsap.quickTo(card, "rotateX", { duration: .55, ease: "power3.out" });
        const liftTo = gsap.quickTo(card, "y", { duration: .45, ease: "power3.out" });
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const nx = (event.clientX - rect.left) / rect.width;
          const ny = (event.clientY - rect.top) / rect.height;
          card.style.setProperty("--mx", `${nx * 100}%`);
          card.style.setProperty("--my", `${ny * 100}%`);
          xTo((nx - .5) * 5);
          yTo((.5 - ny) * 4);
          liftTo(-4);
        }, { passive: true });
        card.addEventListener("pointerleave", () => {
          xTo(0); yTo(0); liftTo(0);
        }, { passive: true });
      });
    }
  }
</script>
