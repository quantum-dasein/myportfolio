  .planet { width: 11rem; background: radial-gradient(circle at 37% 30%, rgba(255,255,255,.2), rgba(255,255,255,.025) 42%, #020304 72%); animation: planet-breathe 4s ease-in-out infinite alternate; }
  .mini-universe > i { position:absolute; left:50%; top:50%; width:.42rem; aspect-ratio:1; border-radius:50%; background:#fff; box-shadow:0 0 1rem #fff; transform:translate(-50%,-50%) rotate(calc(var(--i) * 45deg)) translateX(clamp(7rem, 15vw, 11rem)); }
  @keyframes planet-breathe { to { box-shadow: 0 0 7rem rgba(255,255,255,.18), inset 0 0 3rem rgba(255,255,255,.1); transform: translate(-50%,-50%) scale(1.035); } }

