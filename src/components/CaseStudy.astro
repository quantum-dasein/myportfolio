    backdrop-filter: blur(12px);
  }

  .specimen span:nth-child(1) {
    inset: 12% 42% 18% 12%;
  }

  .specimen span:nth-child(2) {
    inset: 24% 18% 34% 52%;
  }

  .specimen span:nth-child(3) {
