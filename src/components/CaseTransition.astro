<div class="case-transition" data-case-transition-root aria-hidden="true">
  <div class="case-transition__veil" data-case-transition-veil></div>
  <div class="case-transition__rays" data-case-transition-rays></div>
</div>

<style>
  .case-transition {
    position: fixed;
    inset: 0;
    z-index: 500;
    overflow: hidden;
    pointer-events: none;
    visibility: hidden;
  }

  .case-transition.is-active,
  :global(html.rb-case-arriving) .case-transition { visibility: visible; }

  .case-transition__veil,
  .case-transition__rays { position: absolute; inset: 0; }

  .case-transition__veil {
    opacity: 0;
    background:
      radial-gradient(circle at var(--tx, 50%) var(--ty, 50%), rgba(255,255,255,.18) 0 1px, transparent 18%),
      radial-gradient(circle at var(--tx, 50%) var(--ty, 50%), rgba(150,165,176,.18), transparent 34%),
      #020304;
  }

  :global(html.rb-case-arriving) .case-transition__veil { opacity: 1; }

  .case-transition__rays {
    opacity: 0;
    background: repeating-conic-gradient(from 0deg at var(--tx, 50%) var(--ty, 50%), transparent 0deg 5.6deg, rgba(225,232,236,.2) 5.8deg 5.9deg);
    mask-image: radial-gradient(circle at var(--tx, 50%) var(--ty, 50%), transparent 0 8%, #000 25%, transparent 76%);
    transform: scale(.3) rotate(-8deg);
  }

  .case-transition__aperture {
    position: fixed;
    left: var(--x);
    top: var(--y);
    width: var(--w);
    height: var(--h);
    border: 1px solid rgba(255,255,255,.72);
    border-radius: 6px;
    background: rgba(8,10,12,.28);
    box-shadow: 0 0 0 1px rgba(255,255,255,.08), 0 0 5rem rgba(205,220,230,.18);
    transform-origin: center;
  }

  .case-transition__aperture::before,
  .case-transition__aperture::after {
    content: "";
    position: absolute;
    inset: -1rem;
    border: 1px solid rgba(255,255,255,.22);
    border-radius: inherit;
  }

  .case-transition__aperture::after { inset: -2rem; opacity: .42; }

  .case-transition__label {
    position: fixed;
    left: var(--container-offset);
    bottom: var(--container-offset);
    margin: 0;
    color: #f7f9fa;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 6.5rem);
    font-weight: 500;
    line-height: .94;
    opacity: 0;
  }
</style>

<script>
  import gsap from "gsap";

  const root = document.querySelector<HTMLElement>("[data-case-transition-root]")!;
  const veil = root.querySelector<HTMLElement>("[data-case-transition-veil]")!;
  const rays = root.querySelector<HTMLElement>("[data-case-transition-rays]")!;
  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const casePage = document.querySelector<HTMLElement>("[data-case-page]");
  let running = false;
  let completingBack = false;

  const normalize = (value: string) => {
    try {
      const url = new URL(value, location.href);
      return `${url.origin}${url.pathname}${url.search}${url.hash}`;
    } catch { return value; }
  };

  const originMatches = () => {
    const origin = sessionStorage.getItem("rb-case-origin");
    if (!origin) return false;
    const a = new URL(origin, location.href);
    return a.origin === location.origin && a.pathname === location.pathname;
  };

  const reset = () => {
    running = false;
    root.classList.remove("is-active");
    root.querySelectorAll(".case-transition__aperture, .case-transition__label").forEach((node) => node.remove());
    gsap.killTweensOf([veil, rays]);
    gsap.set(veil, { opacity: 0 });
    gsap.set(rays, { opacity: 0, scale: .3, rotation: -8 });
    document.documentElement.classList.remove("rb-case-arriving");
  };

  const revealDestination = (clearOrigin = false) => {
    running = true;
    root.classList.add("is-active");
    gsap.set(veil, { opacity: 1 });
    gsap.set(rays, { opacity: .55, scale: .5, rotation: -8 });
    gsap.timeline({
      onComplete: () => {
        reset();
        if (clearOrigin) {
          sessionStorage.removeItem("rb-case-origin");
          sessionStorage.removeItem("rb-case-sector");
        }
      },
    })
      .to(rays, { opacity: 0, scale: 1.45, rotation: 7, duration: .9, ease: "power3.out" }, 0)
      .to(veil, { opacity: 0, duration: .78, ease: "power2.out" }, .14);
  };

  const closeCurrent = (complete: () => void) => {
    if (reduced) { complete(); return; }
    gsap.killTweensOf([veil, rays]);
    running = true;
    root.classList.add("is-active");
    gsap.timeline({ onComplete: complete })
      .to(rays, { opacity: .7, scale: 1.25, rotation: 5, duration: .72, ease: "power3.in" }, 0)
      .to(veil, { opacity: 1, duration: .58, ease: "power2.in" }, .08);
  };

  function runTransition(card: HTMLElement, href: string) {
    if (running) return;
    if (reduced) { location.assign(href); return; }

    running = true;
    sessionStorage.setItem("rb-case-origin", normalize(location.href));
    const rect = card.getBoundingClientRect();
    const title = card.querySelector("h3")?.textContent?.trim() || card.textContent?.trim() || "Case Study";
    const aperture = document.createElement("div");
    const label = document.createElement("p");
    aperture.className = "case-transition__aperture";
    label.className = "case-transition__label";
    label.textContent = title;

    root.style.setProperty("--tx", `${rect.left + rect.width / 2}px`);
    root.style.setProperty("--ty", `${rect.top + rect.height / 2}px`);
    aperture.style.setProperty("--x", `${rect.left}px`);
    aperture.style.setProperty("--y", `${rect.top}px`);
    aperture.style.setProperty("--w", `${rect.width}px`);
    aperture.style.setProperty("--h", `${rect.height}px`);
    root.append(aperture, label);
    root.classList.add("is-active");

    const scale = Math.max(innerWidth / Math.max(rect.width, 1), innerHeight / Math.max(rect.height, 1)) * 1.45;
    gsap.timeline({
      defaults: { ease: "power3.inOut" },
      onComplete: () => {
        sessionStorage.setItem("rb-case-arrive", title);
        location.assign(href);
      },
    })
      .to(aperture, { scale, rotation: 2, borderRadius: "50%", duration: .64 }, 0)
      .to(rays, { opacity: .6, scale: 1.3, rotation: 8, duration: .58 }, .08)
      .to(veil, { opacity: 1, duration: .46 }, .2)
      .to(label, { opacity: 1, y: -10, duration: .3 }, .2);
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    const back = target.closest<HTMLAnchorElement>("a[data-case-back]");
    if (back && casePage && sessionStorage.getItem("rb-case-origin")) {
      event.preventDefault();
      history.back();
      return;
    }

    const link = target.closest<HTMLAnchorElement>("a[data-case-link]");
    if (!link) return;
    const url = new URL(link.href, location.href);
    if (url.origin !== location.origin) return;
    event.preventDefault();
    runTransition(link.closest<HTMLElement>(".work-card") ?? link, url.href);
  });

  const arriving = sessionStorage.getItem("rb-case-arrive");
  if (arriving) {
    sessionStorage.removeItem("rb-case-arrive");
    revealDestination(false);
    if (casePage && sessionStorage.getItem("rb-case-origin") && !history.state?.rbCaseGuard) {
      history.pushState({ rbCaseGuard: true }, "", location.href);
    }
  } else if (!casePage && originMatches()) {
    revealDestination(true);
  }

  addEventListener("popstate", () => {
    if (!casePage || completingBack || !sessionStorage.getItem("rb-case-origin")) return;
    completingBack = true;
    running = false;
    closeCurrent(() => history.back());
  });

  addEventListener("pageshow", (event) => {
    if (!event.persisted) return;
    reset();
    if (!casePage && originMatches()) revealDestination(true);
  });
</script>
