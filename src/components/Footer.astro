---
import type { Link } from "../types";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  lang?: Lang;
}

const { logoUrl, logoAlt, links, lang = "en" } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<sy-footer>
  <footer id="contact">
    <div class="finale">
      <div class="terrain terrain-back" aria-hidden="true"></div>
      <div class="terrain terrain-front" aria-hidden="true"></div>
      <span class="signal-line line-a" aria-hidden="true"></span>
      <span class="signal-line line-b" aria-hidden="true"></span>
      <span class="signal-line line-c" aria-hidden="true"></span>
      <span class="final-orb orb-a" aria-hidden="true"></span>
      <span class="final-orb orb-b" aria-hidden="true"></span>
      <span class="final-orb orb-c" aria-hidden="true"></span>

      <div class="finale-card" id="contact-cta" data-reveal>
        <span class="finale-eyebrow" data-i18n="footer.cta.eyebrow">{t("footer.cta.eyebrow")}</span>
        <h2 data-sy-reveal="words" data-i18n="footer.cta.title">{t("footer.cta.title")}</h2>
        <a class="project-link" href="mailto:rodionbelousov@protonmail.com" data-cursor="OPEN" data-magnetic>
          <span class="project-icon css-arrow css-arrow-up" aria-hidden="true"></span>
          <span data-i18n="footer.cta.button">{t("footer.cta.button")}</span>
          <span class="project-rule" aria-hidden="true"></span>
          <span class="project-arrow css-arrow" aria-hidden="true"></span>
        </a>
      </div>
    </div>

    <div class="footer-main">
      <div class="brand-cell">
        <a class="brand-mark" href={logoUrl} aria-label={logoAlt} data-case-exit data-locale-home>
          <img src="/brand/rodion-belousov-rb-monogram.png" alt="" width="869" height="878" loading="lazy" />
        </a>
        <div>
          <a class="logo" href={logoUrl} data-case-exit data-locale-home><span>Rodion Belousov</span><span class="dot">.studio</span></a>
          <p data-i18n="footer.tagline">{t("footer.tagline")}</p>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        {
          links.map((link) => (
            <a href={link.url} data-i18n={link.i18n} data-case-exit data-locale-hash={link.url.startsWith("/#") ? link.url.slice(1) : undefined}>{link.title}</a>
          ))
        }
        <a href="https://www.behance.net/gallery/146849483/Meine-3D-Projekte" target="_blank" rel="noopener">Behance</a>
        <a href="https://www.linkedin.com/in/rodion-belousov-413040228/" target="_blank" rel="me noopener">LinkedIn</a>
        <a href="https://github.com/quantum-dasein" target="_blank" rel="noopener">GitHub</a>
      </nav>

      <a class="archive-control" href="/gallery" data-tunnel data-cursor="ENTER">
        <span data-i18n="nav.gallery">{t("nav.gallery")}</span><span class="css-arrow css-arrow-up" aria-hidden="true"></span>
      </a>
    </div>

    <!-- ── Machine room: live telemetry strip ──────────────────────────────── -->
    <div class="machine" aria-hidden="true">
      <div class="machine-cell">
        <span class="machine-key">Status</span>
        <span class="machine-val"><i class="pulse"></i><span data-i18n="footer.status">{t("footer.status")}</span></span>
      </div>
      <div class="machine-cell">
        <span class="machine-key">Vienna</span>
        <span class="machine-val"><b data-vienna-clock>--:--:--</b> CET</span>
      </div>
      <div class="machine-cell">
        <span class="machine-key">Coord</span>
        <span class="machine-val">48.2082° N / 16.3738° E</span>
      </div>
      <div class="machine-cell">
        <span class="machine-key">Build</span>
        <span class="machine-val">ASTRO / THREE / GSAP</span>
      </div>
    </div>

    <!-- ── Giant wordmark ──────────────────────────────────────────────────── -->
    <div class="wordmark" aria-hidden="true"><span>RODION BELOUSOV</span></div>

    <div class="footer-base">
      <p>© {year} Rodion Belousov · <span data-i18n="footer.rights">{t("footer.rights")}</span></p>
    </div>
  </footer>
</sy-footer>

<style>
  sy-footer { --footer-accent: 220, 226, 230; --footer-deep: 2, 3, 4; position: relative; z-index: 2; display: block; color: var(--color-text); font-family: var(--font-inter); }

  footer {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,.09);
    background: rgb(var(--footer-deep));
  }

  .finale {
    position: relative;
    display: grid;
    min-height: 700px;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 34%, rgba(var(--footer-accent),.13), transparent 27rem),
      linear-gradient(180deg, rgb(var(--footer-deep)), rgba(var(--footer-accent),.035) 64%, #010102);
  }

  .finale::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: .5;
    background-image: radial-gradient(circle, rgba(255,255,255,.72) 0 1px, transparent 1.3px);
    background-size: 8rem 8rem;
    mask-image: radial-gradient(circle at 50% 40%, #000, transparent 76%);
  }

  .terrain {
    position: absolute;
    left: -15%;
    width: 130%;
    height: 45%;
    bottom: -13%;
    background-image:
      linear-gradient(rgba(255,255,255,.2) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.18) 1px, transparent 1px);
    background-size: 1rem 1rem;
    mask-image: radial-gradient(ellipse at 50% 70%, #000 8%, rgba(0,0,0,.8) 42%, transparent 76%);
    transform: perspective(560px) rotateX(62deg) rotateZ(-2deg);
    transform-origin: bottom;
    animation: terrain-drift 14s ease-in-out infinite alternate;
  }

  .terrain-back { bottom: 9%; opacity: .42; transform: perspective(640px) rotateX(67deg) rotateZ(2deg) scale(.86); }
  .terrain-front { opacity: .62; }

  .signal-line {
    position: absolute;
    bottom: 22%;
    width: 1px;
    height: 26%;
    background: linear-gradient(transparent, rgba(255,255,255,.38));
  }
  .signal-line::after { content: ""; position: absolute; left: -2px; bottom: 100%; width: 5px; aspect-ratio: 1; border-radius: 50%; background: #fff; box-shadow: 0 0 1rem #fff; }
  .line-a { left: 21%; height: 31%; }
  .line-b { right: 20%; height: 38%; }
  .line-c { right: 8%; height: 24%; }

  .final-orb {
    position: absolute;
    border: 1px solid rgba(255,255,255,.13);
    border-radius: 50%;
    background:
      radial-gradient(circle at 32% 24%, rgba(255,255,255,.62) 0 .6%, rgba(255,255,255,.18) 2%, transparent 10%),
      radial-gradient(circle at 38% 30%, rgba(255,255,255,.15), transparent 24%),
      radial-gradient(circle at 60% 68%, #030304, #151719 44%, #030304 72%);
    box-shadow: inset -2rem -2rem 4rem rgba(0,0,0,.68), inset 1rem 1rem 2rem rgba(255,255,255,.09), 0 2rem 5rem rgba(0,0,0,.7), 0 0 5rem rgba(255,255,255,.1);
    filter: brightness(1.28);
    animation: orb-float 8s ease-in-out infinite;
  }
  .orb-a { left: 2%; bottom: 5%; width: clamp(180px, 18vw, 280px); }
  .orb-b { right: 10%; bottom: 12%; width: clamp(90px, 8vw, 130px); animation-delay: -3s; }
  .orb-c { right: 7%; top: 8%; width: clamp(100px, 9vw, 145px); animation-delay: -5s; opacity: .86; }

  .finale-card {
    position: relative;
    z-index: 4;
    width: min(920px, calc(100% - 48px));
    padding: clamp(32px, 3.4vw, 54px);
    border: 1px solid rgba(var(--footer-accent),.34);
    border-radius: 8px;
    background:
      radial-gradient(circle at 32% 12%, rgba(255,255,255,.075), transparent 19rem),
      linear-gradient(145deg, rgba(255,255,255,.055), rgba(255,255,255,.008)),
      rgba(3,4,5,.74);
    backdrop-filter: blur(24px) saturate(.75);
    box-shadow: 0 3rem 8rem rgba(0,0,0,.66), inset 0 1px rgba(var(--footer-accent),.15), 0 0 6rem rgba(var(--footer-accent),.06);
    scroll-margin-top: 7rem;
  }

  .finale-eyebrow {
    display: block;
    color: rgba(var(--rgb-text), .66);
    font-size: .63rem;
    letter-spacing: .22em;
    text-transform: uppercase;
  }

  .finale-card h2 {
    max-width: 14ch;
    margin: 1.5rem 0 2.4rem;
    color: #f8fafa;
    font-family: var(--font-display);
    font-size: clamp(52px, 4.3vw, 78px);
    font-weight: 500;
    line-height: .92;
    letter-spacing: 0;
  }

  .project-link {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    gap: 1rem;
    align-items: center;
    color: #fff;
    font-size: .92rem;
  }

  .project-icon {
    display: grid;
    width: 3.5rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid rgba(255,255,255,.42);
    border-radius: 50%;
    border-color: rgba(var(--footer-accent),.55);
    box-shadow: 0 0 1.5rem rgba(var(--footer-accent),.2);
  }
  .css-arrow {
    position: relative;
    display: inline-block;
    width: 1.05rem;
    height: 1.05rem;
  }
  .css-arrow::before {
    content: "";
    position: absolute;
    left: .08rem;
    top: 50%;
    width: .82rem;
    height: 1px;
    background: currentColor;
    transform: translateY(-50%);
  }
  .css-arrow::after {
    content: "";
    position: absolute;
    right: .08rem;
    top: 50%;
    width: .38rem;
    height: .38rem;
    border-top: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transform: translateY(-50%) rotate(45deg);
  }
  .css-arrow-up { transform: rotate(-45deg); }
  .project-rule { height: 1px; background: linear-gradient(90deg, rgba(255,255,255,.18), rgba(255,255,255,.58)); }
  .project-arrow { font-size: 1.2rem; }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 8.5rem;
    border-block: 1px solid rgba(255,255,255,.1);
  }
  .footer-main > * { padding: 1.8rem clamp(1.5rem, 5vw, 5rem); }
  .footer-main > * + * { border-left: 1px solid rgba(255,255,255,.1); }

  .brand-cell { display: flex; align-items: center; gap: 1.4rem; }
  .brand-mark {
    display: grid;
    flex: 0 0 4.5rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid rgba(255,255,255,.32);
    border-radius: 50%;
    box-shadow: 0 0 1.8rem rgba(255,255,255,.06);
  }
  .brand-mark img { width: 76%; height: 76%; object-fit: contain; filter: brightness(1.06) contrast(1.08); }
  .logo { color: #fff; font-family: var(--font-display); font-size: 1rem; }
  .logo .dot { color: rgba(var(--rgb-text), .52); }
  .brand-cell p { margin: .5rem 0 0; color: rgba(var(--rgb-text),.48); font-size: .55rem; letter-spacing: .14em; text-transform: uppercase; }

  .footer-nav { display: flex; align-items: center; justify-content: center; gap: clamp(1rem, 2.2vw, 2.2rem); flex-wrap: wrap; }
  .footer-nav a { color: rgba(var(--rgb-text), .64); font-size: .82rem; white-space: nowrap; transition: color .3s ease; }
  .footer-nav a:hover { color: #fff; }

  .archive-control {
    display: none;
    align-self: center;
    justify-self: center;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    min-width: 13rem;
    padding: 1rem 1.2rem;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 999px;
    color: #fff;
    font-size: .62rem;
    letter-spacing: .15em;
    text-transform: uppercase;
    box-shadow: 0 0 2rem rgba(255,255,255,.05);
  }

  /* ── Machine room ──────────────────────────────────────────────────────── */
  .machine {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid rgba(255, 255, 255, .1);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .machine-cell {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    padding: 1.15rem clamp(1.5rem, 5vw, 5rem);
  }
  .machine-cell + .machine-cell { border-left: 1px solid rgba(255, 255, 255, .1); }

  .machine-key {
    color: rgba(var(--rgb-text), .34);
    font-size: .54rem;
    letter-spacing: .22em;
    text-transform: uppercase;
  }

  .machine-val {
    display: flex;
    align-items: center;
    gap: .45rem;
    color: rgba(var(--rgb-text), .78);
    font-size: .68rem;
    letter-spacing: .08em;
    font-variant-numeric: tabular-nums;
  }
  .machine-val b { color: #fff; font-weight: 400; }

  .pulse {
    width: .4rem;
    height: .4rem;
    border-radius: 50%;
    background: #7dffa4;
    box-shadow: 0 0 .6rem #7dffa4;
    animation: machine-pulse 2s ease-in-out infinite;
  }

  @keyframes machine-pulse {
    0%, 100% { opacity: .35; }
    50% { opacity: 1; }
  }

  /* ── Giant wordmark ────────────────────────────────────────────────────── */
  .wordmark {
    overflow: hidden;
    padding: clamp(1.5rem, 3vw, 2.5rem) 0 0;
    line-height: .78;
    text-align: center;
  }

  .wordmark span {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    /* sized so the full 15-character wordmark always fits the viewport —
       a rem cap let it outgrow the screen and clipped the final letters */
    font-size: clamp(1.5rem, 11.4vw, 13rem);
    letter-spacing: -0.04em;
    white-space: nowrap;
    color: transparent;
    background: linear-gradient(180deg, rgba(255, 255, 255, .34), rgba(255, 255, 255, .045) 62%, transparent);
    background-clip: text;
    -webkit-background-clip: text;
    transform: translateY(12%);
  }

  .footer-base {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.6rem clamp(1.5rem, 5vw, 5rem);
    color: rgba(var(--rgb-text), .46);
    font-size: .65rem;
  }
  .footer-base p { margin: 0; }
  .footer-base div { display: flex; gap: 1rem; }

  @keyframes terrain-drift { to { transform: perspective(560px) rotateX(62deg) rotateZ(1deg) translateX(1.5%); } }
  @keyframes orb-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-1.2rem); } }

  @media (max-width: 900px) {
    .footer-main { grid-template-columns: 1fr; }
    .footer-main > * + * { border-left: 0; border-top: 1px solid rgba(255,255,255,.1); }
    .footer-nav { flex-wrap: wrap; }
    .archive-control { margin-block: 1.2rem; }

    .machine { grid-template-columns: repeat(2, 1fr); }
    .machine-cell:nth-child(3) { border-left: 0; }
    .machine-cell:nth-child(n + 3) { border-top: 1px solid rgba(255,255,255,.1); }
  }

  @media (max-width: 600px) {
    .finale { min-height: 590px; }
    .finale-card { width: calc(100% - 2rem); padding: 1.5rem; backdrop-filter: none; }
    .finale-card h2 { margin-block: 1.1rem 1.8rem; font-size: clamp(2.3rem, 12vw, 3.2rem); line-height: .96; }
    .project-link { grid-template-columns: auto 1fr auto; }
    .project-rule { display: none; }
    .orb-a { left: -25%; }
    .brand-cell { padding-inline: 1.5rem; }
    .brand-mark { flex-basis: 3.8rem; }
    .footer-nav { gap: 1rem 1.4rem; padding-block: 1.3rem; }
    .footer-base { flex-direction: column; align-items: center; text-align: center; }
  }

  @media (max-width: 900px), (pointer: coarse) {
    .terrain,
    .final-orb { animation: none; }
    .finale::before { opacity: .32; }
  }

  @media (prefers-reduced-motion: reduce) {
    .terrain, .final-orb { animation: none; }
    .pulse { animation: none; opacity: 1; }
  }
</style>

<script>
  // Live Vienna clock — setInterval (not rAF) so it keeps ticking reliably.
  const clock = document.querySelector<HTMLElement>("[data-vienna-clock]");
  if (clock) {
    const fmt = new Intl.DateTimeFormat("en-GB", {
      timeZone: "Europe/Vienna",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
    const tick = () => (clock.textContent = fmt.format(new Date()));
    tick();
    setInterval(tick, 1000);
  }
</script>
