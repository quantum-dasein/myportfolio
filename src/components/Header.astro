---
import type { Link } from "../types";
import type { Lang } from "../i18n/utils";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: Link[];
  cta?: Link;
  lang?: Lang;
  localeLinks?: Partial<Record<Lang, string>>;
  logoTunnel?: boolean;
}

const { logoUrl, logoAlt, links, cta, lang = "en", localeLinks, logoTunnel = false } = Astro.props;
---

<header>
  <sy-head>
    <div class="inner u-container">
      <div class="wrapper">
        <a class="logo" href={logoUrl} data-case-exit data-tunnel={logoTunnel ? "" : undefined}>
          <span class="mark">Rodion Belousov</span><span class="dot">.studio</span>
        </a>

        {
          links.length ? (
            <div class="menu">
              <ul>
                {links.map((l) => (
                  <li>
                    <a href={l.url} data-i18n={l.i18n} data-overlay={l.overlay} data-case-exit>
                      {l.title}
                    </a>
                  </li>
                ))}
              </ul>
              {cta ? (
                <a class="menu-cta" href={cta.url} data-tunnel={cta.tunnel ? "" : undefined} data-i18n={cta.i18n}>
                  {cta.title}
                </a>
              ) : null}
            </div>
          ) : null
        }

        <div class="buttons">
          <!-- Motion mode: Full ⇄ Calm (keeps the composition, mutes the noise) -->
          <button type="button" class="calm-toggle" data-calm-toggle aria-pressed="false" title="Calm mode — reduce motion & effects">
            CALM
          </button>

          <!-- Studio ambience — off by default, never autoplays -->
          <button type="button" class="sound-toggle" data-sound-toggle aria-pressed="false" aria-label="Toggle sound" title="Studio ambience">
            <span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          </button>

          <!-- Language switcher -->
          <div class="lang" role="group" aria-label="Language">
            {localeLinks ? (
              <>
                <a href={localeLinks.en} data-lang-route="en" class:list={{ "is-active": lang === "en" }} aria-current={lang === "en" ? "page" : undefined}>EN</a>
                <a href={localeLinks.de} data-lang-route="de" class:list={{ "is-active": lang === "de" }} aria-current={lang === "de" ? "page" : undefined}>DE</a>
              </>
            ) : (
              <>
                <button type="button" data-lang="en" aria-pressed="true"><span data-i18n="lang.en">EN</span></button>
                <button type="button" data-lang="de" aria-pressed="false"><span data-i18n="lang.de">DE</span></button>
              </>
            )}
          </div>

          {
            cta ? (
              <a class="nav-cta" href={cta.url} data-tunnel={cta.tunnel ? "" : undefined} data-magnetic data-cursor="ENTER">
                <span data-i18n={cta.i18n}>{cta.title}</span>
              </a>
            ) : null
          }

          {
            links.length ? (
              <button type="button" class="toggle" aria-label="Toggle menu">
                <span class="u-sr-only">Toggle menu</span>
                <span aria-hidden>
                  <span />
                  <span />
                  <span />
                </span>
              </button>
            ) : null
          }
        </div>
      </div>
    </div>
  </sy-head>
</header>

<style>
  sy-head {
    --br: 1.25rem;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50; /* above gallery UI (10); below overlays (60) & preloader (100) */
    color: var(--color-text);
    margin: 0 auto;
    transition: transform 0.3s var(--ease-out-cubic);
    transform: translate3d(0, 0, 0);
    will-change: transform;

    :global(body.is-nav-hidden) & {
      transform: translate3d(0, -100%, 0);
    }

    /* scroll-triggered frosted backdrop */
    &::after {
      content: "";
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: -1;
      background: rgba(2, 2, 3, 0.64);
      border-bottom: 1px solid rgba(255, 255, 255, 0.055);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.3s var(--ease-out-cubic);
      backdrop-filter: blur(16px);
    }

    :global(body.is-nav-small) &::after {
      transform: scaleY(1);
    }
  }

  .inner {
    padding: 1.15rem 0;
    transition: padding 0.3s var(--ease-out-cubic);

    :global(body.is-nav-small) & {
      padding: 0.7rem 0;
    }
  }

  .wrapper {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  /* ── Wordmark ──────────────────────────────────────────────────────────── */
  .logo {
    position: relative;
    z-index: 3;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    line-height: 1;
    white-space: nowrap;

    .dot {
      color: var(--color-accent);
    }

    @media (--mq-phone-md) {
      font-size: 1rem;

      .mark {
        /* keep it compact on phones */
        clip-path: inset(0 0 0 0);
      }
    }
  }

  /* ── Center nav ────────────────────────────────────────────────────────── */
  /* In normal flow (not absolutely centred) so it can never overlap the
     wordmark or the right cluster, and never wraps a long label like
     "Services & Research" onto two lines. */
  .menu {
    display: flex;
    flex: 1 1 auto;
    justify-content: center;
    min-width: 0;

    @media (--mq-tablet) {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.4rem;
      width: 100vw;
      height: 100dvh;
      position: fixed;
      z-index: 2;
      padding: 0 1.4rem;
      background: var(--color-bg);
      top: 0;
      left: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.6s var(--ease-out-expo);

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }
    }

    ul {
      font-family: var(--font-inter);
      font-size: var(--font-size-sm);
      letter-spacing: 0.02em;
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      flex-wrap: nowrap;
      gap: clamp(0.85rem, 1.9vw, 2rem);

      @media (--mq-tablet) {
        flex-direction: column;
        font-family: var(--font-display);
        /* "Leistungen & Research" must fit a 360px phone — a fixed 2.25rem
           pushed it 19px past both edges. */
        font-size: clamp(1.55rem, 7.2vw, 2.25rem);
        gap: 1.25rem;
        text-align: center;
      }
    }

    a {
      text-decoration: none;
      position: relative;
      color: var(--color-text);
      white-space: nowrap;
      transition: color 0.3s var(--ease-out-expo);

      @media (--mq-tablet) {
        white-space: normal;
        line-height: 1.15;
      }

      &::before {
        content: "";
        position: absolute;
        height: 1px;
        background: var(--color-accent);
        top: 125%;
        width: 100%;
        left: 0;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.35s var(--ease-out-expo);
      }

      &:hover,
      &:focus {
        color: var(--color-accent);

        &::before {
          transform: scaleX(1);
          transform-origin: left;
        }
      }
    }
  }

  /* The overlay's own Archive entry — on phones the header CTA is hidden, and
     the archive must stay one tap away. */
  .menu-cta {
    display: none;

    @media (--mq-tablet) {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1.7rem;
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 100px;
      color: var(--color-text);
      font-family: var(--font-inter);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
  }

  /* ── Right cluster ─────────────────────────────────────────────────────── */
  .buttons {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    z-index: 2;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.2rem;
    border: 1px solid var(--color-line);
    border-radius: 100px;

    button,
    a {
      cursor: pointer;
      border: none;
      background: none;
      padding: 0.3rem 0.6rem;
      border-radius: 100px;
      font-family: var(--font-inter);
      font-size: var(--font-size-xs);
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--color-text-alt);
      transition:
        color 0.3s var(--ease-out-expo),
        background 0.3s var(--ease-out-expo);

      &.is-active {
        color: var(--color-black);
        background: var(--color-text);
      }

      &:not(.is-active):hover {
        color: var(--color-text);
      }
    }
  }

  .calm-toggle {
    cursor: pointer;
    padding: 0.42rem 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    background: none;
    color: var(--color-text-alt);
    font-family: var(--font-inter);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    transition: color 0.3s var(--ease-out-expo), background 0.3s var(--ease-out-expo), border-color 0.3s var(--ease-out-expo);
  }

  .calm-toggle:hover { color: var(--color-text); }

  /* ── Sound toggle: a 4-bar equaliser that only dances when audio is on ──── */
  .sound-toggle {
    cursor: pointer;
    display: grid;
    place-items: center;
    width: 2.05rem;
    height: 2.05rem;
    padding: 0;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    background: none;
    color: var(--color-text-alt);
    transition: color 0.3s var(--ease-out-expo), border-color 0.3s var(--ease-out-expo);
  }
  .sound-toggle:hover { color: var(--color-text); border-color: rgba(255, 255, 255, 0.28); }
  .sound-toggle[aria-pressed="true"] { color: var(--color-text); border-color: rgba(255, 255, 255, 0.4); }

  .eq {
    display: flex;
    align-items: center;
    gap: 1.5px;
    height: 0.62rem;
  }

  .eq i {
    width: 1.5px;
    height: 22%;
    background: currentColor;
    border-radius: 1px;
    transition: height 0.3s var(--ease-out-expo);
  }

  .sound-toggle[aria-pressed="true"] .eq i {
    animation: eq-bounce 1.1s ease-in-out infinite;
  }
  .sound-toggle[aria-pressed="true"] .eq i:nth-child(2) { animation-delay: 0.18s; }
  .sound-toggle[aria-pressed="true"] .eq i:nth-child(3) { animation-delay: 0.36s; }
  .sound-toggle[aria-pressed="true"] .eq i:nth-child(4) { animation-delay: 0.09s; }

  @keyframes eq-bounce {
    0%, 100% { height: 22%; }
    50% { height: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sound-toggle[aria-pressed="true"] .eq i { animation: none; height: 60%; }
  }

  .calm-toggle[aria-pressed="true"] {
    color: var(--color-black);
    background: var(--color-text);
    border-color: var(--color-text);
  }

  .nav-cta {
    font-family: var(--font-inter);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.7em 1.25em;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 6px;
    color: rgba(var(--rgb-text), 0.78);
    background: rgba(255, 255, 255, 0.025);
    backdrop-filter: blur(14px);
    white-space: nowrap;
    transition:
      color 0.35s var(--ease-out-expo),
      border-color 0.35s var(--ease-out-expo),
      background 0.35s var(--ease-out-expo),
      transform 0.35s var(--ease-out-expo);

    &:hover,
    &:focus {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.055);
      transform: translateY(-1px);
    }

    @media (--mq-phone-md) {
      display: none;
    }
  }

  /* ── Mobile toggle ─────────────────────────────────────────────────────── */
  .toggle {
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    display: none;
    z-index: 3;
    color: var(--color-text);

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 1.25rem;
      width: 2rem;

      span {
        display: flex;
        width: 100%;
        height: 2px;
        background: currentcolor;
        border-radius: 10px;
        transition: transform 0.25s var(--ease-out-cubic), opacity 0.2s;
      }
    }

    :global(body.is-nav-opened) & {
      > span span {
        &:first-child {
          transform: translateY(calc(0.625rem - 1px)) rotate(45deg);
        }
        &:nth-child(2) {
          opacity: 0;
        }
        &:last-child {
          transform: translateY(calc(-0.625rem + 1px)) rotate(-45deg);
        }
      }
    }
  }

  @media (max-width: 600px) {
    .inner { padding-block: .82rem; }
    .wrapper { gap: .65rem; }
    .logo { font-size: .9rem; }
    .buttons { gap: .5rem; }
    .calm-toggle { padding: .3rem .5rem; font-size: .62rem; }
    .lang button,
    .lang a { padding: .27rem .45rem; font-size: .68rem; }
    .toggle > span:last-child { width:1.65rem; height:1.05rem; }
  }

  /* Touch devices drop backdrop-filter for performance — but the plate was only
     64% opaque and relied on that blur, so page content bled straight through
     the header. Without the blur it has to be genuinely opaque. */
  @media (pointer: coarse) {
    sy-head::after,
    .nav-cta { backdrop-filter: none; }

    sy-head::after {
      background: linear-gradient(180deg, #050506 62%, rgba(5, 5, 6, 0.94));
    }

    .nav-cta { background: rgba(24, 25, 28, 0.96); }

    /* the mobile menu overlay must fully cover the scene behind it */
    .menu { background: #050506; }
  }
</style>

<script>
  import { addScrollObserver } from "../utils/observers";
  // Boot the language switcher (swaps copy in place + persists preference).
  import "../utils/i18n";

  const heroSelectors = ["[data-hero]"];

  class Header extends HTMLElement {
    smallThreshold = 100;
    hiddenThreshold = 200;
    toggleEl = this.querySelector(".toggle");
    hero = document.querySelector(heroSelectors.join(","));
    prevY = -1;

    constructor() {
      super();
      addScrollObserver(this);
      this.toggleEl?.addEventListener("click", this.toggleNav);

      // Close the mobile menu after navigating to an anchor.
      this.querySelectorAll(".menu a").forEach((a) =>
        a.addEventListener("click", () =>
          document.body.classList.remove("is-nav-opened"),
        ),
      );

      // (Wordmark + CTA carry [data-tunnel]; the Tunnel component handles them.)

      this.initCalmToggle();
      this.onResize();
      this.onScroll(window.scrollY);
    }

    // Full ⇄ Calm: html.rb-calm mutes grain/scan and heavy motion via CSS and
    // broadcasts rb:calmchange so the WebGL layers can drop their frame rate.
    initCalmToggle() {
      const toggle = this.querySelector<HTMLButtonElement>("[data-calm-toggle]");
      if (!toggle) return;
      const apply = (calm: boolean, persist: boolean) => {
        document.documentElement.classList.toggle("rb-calm", calm);
        toggle.setAttribute("aria-pressed", String(calm));
        if (persist) {
          try { localStorage.setItem("rb-motion", calm ? "calm" : "full"); } catch { /* private mode */ }
        }
        window.dispatchEvent(new CustomEvent("rb:calmchange", { detail: { calm } }));
      };
      apply(document.documentElement.classList.contains("rb-calm"), false);
      toggle.addEventListener("click", () => {
        apply(!document.documentElement.classList.contains("rb-calm"), true);
      });
    }

    onScroll(y: number) {
      const classList = document.body.classList;

      const shouldBeSmall = y > this.smallThreshold;
      if (shouldBeSmall !== classList.contains("is-nav-small")) {
        classList.toggle("is-nav-small", shouldBeSmall);
      }

      if (this.prevY < 0) {
        this.prevY = y;
        return;
      }

      const delta = y - this.prevY;
      if (Math.abs(delta) < 6) return;
      this.prevY = y;

      if (y <= this.hiddenThreshold) {
        classList.remove("is-nav-hidden");
      } else if (delta > 0) {
        classList.add("is-nav-hidden");
      } else {
        classList.remove("is-nav-hidden");
      }
    }

    toggleNav = () => {
      document.body.classList.toggle("is-nav-opened");
    };

    onResize() {
      const bcr = this.getBoundingClientRect();
      const heroBcr = this.hero && this.hero.getBoundingClientRect();
      this.smallThreshold = heroBcr ? heroBcr.height - bcr.height : bcr.height;
    }
  }

  customElements.define("sy-head", Header);
</script>
