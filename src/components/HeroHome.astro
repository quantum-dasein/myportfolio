---
import { useTranslations } from "../i18n/utils";

const t = useTranslations();
---

<section class="hero" data-hero id="intro">
  <div class="u-container hero-inner">
    <div class="hero-copy">
      <span class="status" data-intro>
        <span class="status-dot" aria-hidden="true"></span>
        <span data-i18n="hero.status">{t("hero.status")}</span>
      </span>

      <span class="eyebrow" data-intro data-i18n="hero.eyebrow">
        {t("hero.eyebrow")}
      </span>

      <h1 class="hero-title" aria-label={`${t("hero.title.1")} ${t("hero.title.2")}`}>
        <span class="line" data-intro data-i18n="hero.title.1">{t("hero.title.1")}</span>
        <span class="line muted" data-intro data-i18n="hero.title.2">{t("hero.title.2")}</span>
      </h1>

      <p class="hero-sub" data-intro data-i18n="hero.subtitle">{t("hero.subtitle")}</p>

      <div class="hero-actions" data-intro>
        <a class="primary" href="#work" data-i18n="hero.cta.primary" data-magnetic>{t("hero.cta.primary")}</a>
        <a class="secondary" href="#contact-cta" data-i18n="hero.cta.secondary" data-magnetic>{t("hero.cta.secondary")}</a>
      </div>

      <!-- Trust bar: the decision to trust happens in the first seconds, so the
           evidence belongs on the first screen, not buried five sections down. -->
      <div class="hero-trust" data-intro>
        <span class="trust-label" data-i18n="hero.trust.label">{t("hero.trust.label")}</span>
        <ul class="trust-names">
          <li>Siemens</li>
          <li>Bridge Consult</li>
          <li>FIDIC.uz</li>
        </ul>
        <span class="trust-metric">
          <b data-trust-count="780">+780%</b>
          <span data-i18n="hero.trust.metric">{t("hero.trust.metric")}</span>
        </span>
      </div>
    </div>

    <aside class="hero-readout" data-intro aria-label="Studio capabilities">
      <div><span>FOCUS</span><strong>DIGITAL MARKETING</strong></div>
      <div><span>SYSTEMS</span><strong>CONTENT / SEO / WEB</strong></div>
      <div><span>BASE</span><strong>VIENNA / REMOTE</strong></div>
    </aside>

    <nav class="hero-projects" data-intro aria-label="Selected projects">
      <span>SELECTED / 02</span>
      <a href="/work/bridge-consult" data-case-link>Bridge Consult <b class="css-arrow" aria-hidden="true"></b></a>
      <a href="/work/fidic" data-case-link>FIDIC.uz <b class="css-arrow" aria-hidden="true"></b></a>
    </nav>

    <div class="hero-cue" data-intro>
      <span class="cue-line"></span>
      <span data-i18n="hero.scroll">{t("hero.scroll")}</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 70%, rgba(255, 255, 255, 0.055), transparent 32%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.98) 0%, rgba(0, 0, 0, 0.88) 34%, rgba(0, 0, 0, 0.22) 63%, transparent 86%);
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    z-index: 1;
    height: 22%;
    pointer-events: none;
    background: linear-gradient(180deg, transparent, #020203);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 14rem;
    align-items: end;
    gap: 3rem;
    padding: 8rem 0 3rem;
  }

  .hero-copy { max-width: 58rem; }

  .status,
  .eyebrow,
  .hero-readout,
  .hero-projects,
  .hero-cue {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 2.4rem;
    color: rgba(var(--rgb-text), 0.48);
  }

  .status-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #f2f5f6;
    box-shadow: 0 0 0 0.35rem rgba(255, 255, 255, 0.055), 0 0 1.2rem rgba(255, 255, 255, 0.4);
  }

  .eyebrow {
    display: block;
    width: fit-content;
    color: rgba(244, 246, 249, 0.72);
    text-shadow: 0 0 1.4rem rgba(255, 255, 255, 0.12);
  }

  .hero-title {
    max-width: 14ch;
    margin: 1.35rem 0 0;
    font-family: var(--font-display);
    font-size: 5.8rem;
    font-weight: 430;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .line { display: block; }

  .muted {
    color: rgba(244, 246, 249, 0.64);
    background: none;
    text-shadow: 0 0 2.8rem rgba(255, 255, 255, 0.08);
  }

  .hero-sub {
    max-width: 38rem;
    margin: 1.7rem 0 0;
    color: rgba(var(--rgb-text), 0.76);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 2rem;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.8rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 550;
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
  }

  .primary {
    color: #050606;
    border-color: rgba(255, 255, 255, 0.72);
    background: linear-gradient(120deg, #fff, #cfd5d8);
    box-shadow: 0 0 2.2rem rgba(255, 255, 255, 0.12);
  }

  .secondary {
    color: rgba(var(--rgb-text), 0.78);
    border-color: rgba(255, 255, 255, 0.12);
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.012));
    backdrop-filter: blur(14px);
  }

  .primary:hover,
  .secondary:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.24);
  }

  /* ── Trust bar ─────────────────────────────────────────────────────────── */
  .hero-trust {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1.4rem;
    margin-top: 2.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.09);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .trust-label { color: rgba(var(--rgb-text), 0.34); }

  .trust-names {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .trust-names li {
    color: rgba(var(--rgb-text), 0.78);
    font-weight: 500;
  }

  .trust-names li + li::before {
    content: "·";
    margin-right: 0.9rem;
    color: rgba(var(--rgb-text), 0.28);
  }

  .trust-metric {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    margin-left: auto;
    color: rgba(var(--rgb-text), 0.4);
    white-space: nowrap;
  }

  .trust-metric b {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 700px) {
    .hero-trust { gap: 0.6rem 1rem; font-size: 0.56rem; }
    .trust-metric { margin-left: 0; }
  }

  .hero-readout {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 6px;
    color: rgba(var(--rgb-text), 0.32);
    background:
      radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.07), transparent 44%),
      rgba(7, 8, 9, 0.48);
    backdrop-filter: blur(20px) saturate(0.85);
    box-shadow: 0 1.4rem 4rem rgba(0, 0, 0, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .hero-readout div { display: grid; gap: 0.3rem; }
  .hero-readout strong { color: rgba(var(--rgb-text), 0.88); font-weight: 400; }

  .hero-projects {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr repeat(2, minmax(10rem, 15rem));
    align-items: center;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(var(--rgb-text), 0.35);
  }

  .hero-projects a {
    display: flex;
    justify-content: space-between;
    color: rgba(var(--rgb-text), 0.7);
    transition: color 0.3s ease;
  }

  .hero-projects a:hover { color: #fff; }
  .hero-projects a:hover b { color: #fff; transform: translate(0.18rem, -0.18rem); }
  .hero-projects b { font-weight: 400; }

  .css-arrow {
    width: 0.52rem;
    height: 0.52rem;
    border-top: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .hero-cue {
    position: absolute;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: rgba(var(--rgb-text), 0.3);
  }

  .cue-line {
    width: 2.5rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.3);
    transform-origin: left;
    animation: cue 2.4s ease-in-out infinite;
  }

  [data-intro] { opacity: 0; transform: translateY(24px); }

  @keyframes cue {
    0%, 100% { transform: scaleX(0.25); opacity: 0.35; }
    50% { transform: scaleX(1); opacity: 1; }
  }

  @media (max-width: 1050px) {
    .hero-title { font-size: 4.3rem; }
    .hero-inner { grid-template-columns: 1fr 12rem; }
  }

  @media (max-width: 900px) {
    .hero { min-height: 92svh; align-items: end; }
    .hero::before { background: linear-gradient(180deg, rgba(0,0,0,0.12), rgba(0,0,0,0.9) 46%, #000 82%); }
    .hero-inner { grid-template-columns: 1fr; gap: 1.35rem; padding: 13rem 0 2rem; }
    .hero-title { font-size: 3.6rem; max-width: 12ch; }
    .hero-sub { font-size: 1rem; }
    .hero-readout {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: .65rem;
      padding: .85rem;
      background: rgba(5, 6, 7, .58);
    }
    .hero-readout div { min-width: 0; }
    .hero-readout span { font-size: .5rem; }
    .hero-readout strong { font-size: .63rem; line-height: 1.35; overflow-wrap: anywhere; }
    .hero-projects { grid-template-columns: 1fr repeat(2, minmax(9rem, 1fr)); gap: 0.8rem; }
    .hero-projects > span { margin-bottom: 0.2rem; }
    .hero-cue { display: none; }
  }

  @media (max-width: 600px) {
    .hero { min-height: 100svh; }
    .hero-inner { gap: 1rem; padding-top: 12.5rem; padding-bottom: 1.35rem; }
    .hero-copy { max-width: 100%; }
    .hero-title { max-width: 10ch; font-size: clamp(2.65rem, 12.5vw, 3.25rem); line-height: .94; }
    .hero-sub { max-width: 34ch; margin-top: 1.1rem; font-size: .92rem; line-height: 1.48; }
    .hero-actions { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; margin-top: 1.2rem; }
    .hero-actions a { min-width: 0; padding-inline: .75rem; font-size: .68rem; text-align: center; }
    .hero-readout {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      padding: .7rem .55rem;
      border-radius: 4px;
    }
    .hero-readout div { display: block; padding: 0 .45rem; border-left: 1px solid rgba(255,255,255,.08); }
    .hero-readout div:first-child { border-left: 0; }
    .hero-readout span { display: block; margin-bottom: .28rem; font-size: .43rem; }
    .hero-readout strong { display: block; font-size: .52rem; line-height: 1.28; }
    .hero-projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: .65rem 1rem;
      padding-top: .85rem;
      font-size: .58rem;
    }
    .hero-projects > span { grid-column: 1 / -1; }
    .hero-projects a { min-width: 0; gap: .45rem; }
  }

  @media (pointer: coarse) {
    .secondary,
    .hero-readout { backdrop-filter: none; }
    .primary:hover,
    .secondary:hover { transform: none; }
    .cue-line { animation-duration: 4.8s; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-intro] { opacity: 1; transform: none; }
    .cue-line { animation: none; }
  }
</style>

<script>
  import gsap from "gsap";

  const hero = document.querySelector<HTMLElement>("[data-hero]");
  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // The proof number lands rather than just sitting there.
  const countTrustMetric = () => {
    const el = hero?.querySelector<HTMLElement>("[data-trust-count]");
    if (!el) return;
    const end = Number(el.dataset.trustCount || 0);
    if (reduced) { el.textContent = `+${end}%`; return; }
    const value = { v: 0 };
    gsap.to(value, {
      v: end,
      duration: 1.6,
      delay: 0.9,
      ease: "power2.out",
      onUpdate: () => (el.textContent = `+${Math.round(value.v)}%`),
    });
  };

  const revealHero = () => {
    if (!hero || hero.dataset.introPlayed === "true") return;
    hero.dataset.introPlayed = "true";
    const items = hero.querySelectorAll<HTMLElement>("[data-intro]");
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: reduced ? 0 : 1.05,
      stagger: reduced ? 0 : 0.075,
      delay: reduced ? 0 : 0.14,
      ease: "power3.out",
      overwrite: true,
    });
    countTrustMetric();
  };

  if (document.body.classList.contains("is-loaded") || !document.querySelector("rb-studio-loader")) {
    revealHero();
  } else {
    addEventListener("rb:loaded", revealHero, { once: true });
    requestAnimationFrame(() => {
      if (document.body.classList.contains("is-loaded") || !document.querySelector("rb-studio-loader")) revealHero();
    });
  }
</script>
