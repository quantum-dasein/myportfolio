---
import Layout from "../layouts/Layout.astro";
import { pick, serviceContent, type InsightContent, type SeoLang } from "../data/seo-content";
interface Props { lang: SeoLang; insight: InsightContent }
const { lang, insight } = Astro.props;
const de = lang === "de";
const service = serviceContent[insight.relatedService];
const alternates = { en: insight.paths.en, de: insight.paths.de, "x-default": insight.paths.en };
const articleSchema = { "@type": "Article", headline: pick(insight.title, lang), description: pick(insight.description, lang), author: { "@id": "https://rodionbelousov.studio/#rodion-belousov" }, datePublished: "2026-07-14", dateModified: "2026-07-14" };
// Unique OG image per insight — the artifact the article is actually about.
const og: Record<string, { image: string; alt: string }> = {
  "bridge-growth": { image: "/cases/bridge-consult-google-analytics-organic-search-growth-780-percent.jpg", alt: "Google Analytics chart: 780% organic search growth for Bridge Consult" },
  "fidic-platform": { image: "/cases/rodion-belousov-fidic-uz-contract-knowledge-platform-design.png", alt: "FIDIC.uz multilingual contract knowledge platform by Rodion Belousov" },
  "threejs-marketing": { image: "/cases/bridge-consult-threejs-project-experience-webgl.png", alt: "Bridge Consult interactive Three.js project universe" },
  "ai-development": { image: "/cases/bridge-consult-open-source-astro-threejs-github-repository.png", alt: "Open-source Astro and Three.js repository behind Bridge Consult" },
};
const ogEntry = og[insight.key];
---
<Layout lang={lang} alternateUrls={alternates} lockLang title={pick(insight.title, lang)} description={pick(insight.description, lang)} image={ogEntry?.image} imageAlt={ogEntry?.alt} pageType="article" structuredData={articleSchema}>
  <article class="insight">
    <header data-hero><div class="u-container"><span>RESEARCH / 2026</span><h1>{pick(insight.title, lang)}</h1><p>{pick(insight.dek, lang)}</p></div></header>
    <div class="u-container article-grid">
      <aside><span>{de ? "VON" : "BY"}</span><strong>Rodion Belousov</strong><span>{de ? "FOKUS" : "FOCUS"}</span><strong>Marketing / Search / Web</strong></aside>
      <div class="body">
        {insight.sections.map((section, index) => <section><span>0{index + 1}</span><h2>{pick(section.title, lang)}</h2><p>{pick(section.text, lang)}</p></section>)}
        <a class="service-link" href={service.paths[lang]}><span>{de ? "PASSENDE LEISTUNG" : "RELATED SERVICE"}</span><strong>{pick(service.title, lang)}</strong><b class="ui-arrow" aria-hidden="true"></b></a>
        <div class="case-links"><a href="/work/bridge-consult" data-case-link><span>Bridge Consult</span><i class="ui-arrow" aria-hidden="true"></i></a><a href="/work/fidic" data-case-link><span>FIDIC.uz</span><i class="ui-arrow" aria-hidden="true"></i></a></div>
      </div>
    </div>
  </article>
</Layout>
<style>
  .insight{position:relative;z-index:1;background:#030405}.insight header{min-height:82svh;display:grid;align-items:end;padding:10rem 0 6rem;background:radial-gradient(circle at 74% 30%,rgba(255,255,255,.09),transparent 26rem);border-bottom:1px solid rgba(255,255,255,.09)}.insight header span,.article-grid aside span,.body section>span,.service-link span{font:.62rem var(--font-inter);letter-spacing:.2em;color:rgba(var(--rgb-text),.47)}.insight h1{max-width:13ch;margin:1.6rem 0;font:500 clamp(3.8rem,7.3vw,7.5rem)/.92 var(--font-display);letter-spacing:0;overflow-wrap:anywhere}.insight header p{max-width:48rem;color:rgba(var(--rgb-text),.73);font-size:clamp(1.2rem,2vw,1.65rem);line-height:1.55}.article-grid{display:grid;grid-template-columns:15rem minmax(0,48rem);gap:clamp(3rem,9vw,10rem);padding-block:clamp(5rem,10vw,10rem)}.article-grid aside{display:flex;flex-direction:column;gap:.5rem;position:sticky;top:8rem;height:max-content}.article-grid aside span:not(:first-child){margin-top:1.4rem}.article-grid aside strong{font:.75rem var(--font-inter);letter-spacing:.09em}.body section{padding:0 0 5rem;margin-bottom:5rem;border-bottom:1px solid rgba(255,255,255,.13)}.body h2{margin:1rem 0 1.5rem;font:500 clamp(2.3rem,4.5vw,4.6rem)/.98 var(--font-display);overflow-wrap:anywhere}.body p{color:rgba(var(--rgb-text),.76);font-size:clamp(1.15rem,1.7vw,1.45rem);line-height:1.72}.service-link{display:grid;grid-template-columns:1fr auto;gap:1rem;padding:1.7rem;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.03)}.service-link span{grid-column:1/-1}.service-link strong{font:500 clamp(1.6rem,3vw,2.7rem)/1 var(--font-display);overflow-wrap:anywhere}.case-links{display:flex;gap:1rem;margin-top:1rem}.case-links a{flex:1;display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.2rem;border:1px solid rgba(255,255,255,.12)}@media(max-width:800px){.article-grid{grid-template-columns:1fr}.article-grid aside{position:static}.insight header{min-height:72svh;padding:8rem 0 4rem}.insight h1{max-width:100%;font-size:clamp(2.7rem,12vw,5.2rem);line-height:.94}.body section{padding-bottom:3rem;margin-bottom:3rem}.service-link{padding:1.25rem}.case-links{flex-direction:column}.case-links a{width:100%}}@media(pointer:coarse){.service-link{background:rgba(10,11,12,.9)}}
</style>
