---
import Layout from "../layouts/Layout.astro";
import { insightContent, pick, serviceContent, type SeoLang } from "../data/seo-content";

interface Props { lang: SeoLang }
const { lang } = Astro.props;
const de = lang === "de";
const services = Object.values(serviceContent);
const insights = Object.values(insightContent);
const alternates = { en: "/en/", de: "/de/", "x-default": "/" };
const title = de
  ? "Rodion Belousov | Digital Marketing, Technical SEO & Creative Development Wien"
  : "Rodion Belousov | Digital Marketing, Technical SEO & Creative Development Vienna";
const description = de
  ? "Digital Marketer und Creative Developer in Wien: Strategie, Content, Technical SEO, Astro, Three.js, Cinema 4D und messbare Launch-Systeme."
  : "Digital marketer and creative developer in Vienna combining strategy, content, technical SEO, Astro, Three.js, Cinema 4D and measurable launch systems.";
---

<Layout lang={lang} alternateUrls={alternates} title={title} description={description} pageType="profile">
  <section class="locale-hero" id="about" data-hero>
    <div class="u-container hero-grid">
      <div>
        <span class="eyebrow">{de ? "DIGITAL MARKETER / CREATIVE DEVELOPER / WIEN" : "DIGITAL MARKETER / CREATIVE DEVELOPER / VIENNA"}</span>
        <h1>{de ? "Marketing, das sich bewegt. Websites, die konvertieren." : "Marketing that moves. Websites that convert."}</h1>
        <p>{de
          ? "Ich verbinde Positionierung, Content, SEO, Motion und Webentwicklung zu einem Launch-System. Strategisch klar, visuell eigenständig und technisch messbar."
          : "I connect positioning, content, SEO, motion and web development into one launch system: strategically clear, visually distinct and technically measurable."}</p>
        <div class="hero-actions">
          <a class="primary" href="#work">{de ? "Cases ansehen" : "View cases"}</a>
          <a href="/gallery" data-tunnel>{de ? "Ins Archiv" : "Enter archive"}</a>
        </div>
      </div>
      <aside aria-label={de ? "Positionierung" : "Positioning"}>
        <span>FOCUS</span><strong>DIGITAL MARKETING</strong>
        <span>SYSTEMS</span><strong>CONTENT / SEO / WEB</strong>
        <span>CRAFT</span><strong>C4D / REDSHIFT / THREE.JS</strong>
      </aside>
    </div>
  </section>

  <section class="services band" aria-labelledby="services-title">
    <div class="u-container">
      <span class="eyebrow">01 / {de ? "LEISTUNGEN" : "SERVICES"}</span>
      <h2 id="services-title">{de ? "Drei Disziplinen. Ein verantwortliches System." : "Three disciplines. One accountable system."}</h2>
      <div class="service-grid">
        {services.map((service, index) => (
          <a class="service" href={service.paths[lang]}>
            <span>0{index + 1}</span>
            <h3>{pick(service.title, lang)}</h3>
            <p>{pick(service.lead, lang)}</p>
            <b>{de ? "Leistung öffnen" : "Open service"} <i class="ui-arrow" aria-hidden="true"></i></b>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cases band" id="work" aria-labelledby="cases-title">
    <div class="u-container">
      <span class="eyebrow">02 / {de ? "AUSGEWÄHLTE ARBEITEN" : "SELECTED WORK"}</span>
      <h2 id="cases-title">{de ? "Strategie, Code und Search unter realem Druck." : "Strategy, code and search under real pressure."}</h2>
      <div class="case-grid">
        <a class="case" href="/work/bridge-consult" data-case-link>
          <img src="/cases/rodion-belousov-bridge-consult-ai-assisted-web-development-case-study.webp" alt="Bridge Consult multilingual Astro and Three.js website case study" loading="lazy" />
          <div><span>01 / ASTRO · THREE.JS · SEO</span><h3>Bridge Consult</h3><p>{de ? "Solo gebautes Growth-System mit +780 % Organic-Search-Signal im frühen Launch-Fenster." : "A solo-built growth system with a +780% organic-search signal in the early launch window."}</p></div>
        </a>
        <a class="case" href="/work/fidic" data-case-link>
          <img src="/cases/rodion-belousov-fidic-uz-contract-knowledge-platform-design.webp" alt="FIDIC.uz multilingual contract knowledge platform case study" loading="lazy" />
          <div><span>02 / CONTENT · PLATFORM · SEO</span><h3>FIDIC.uz</h3><p>{de ? "109 Routen, 105 Fachartikel, neun Vertragsbücher und professionelle Tools in einer Plattform." : "109 routes, 105 expert articles, nine contract books and professional tools in one platform."}</p></div>
        </a>
      </div>
    </div>
  </section>

  <section class="insights band" aria-labelledby="insights-title">
    <div class="u-container insights-layout">
      <div>
        <span class="eyebrow">03 / {de ? "RESEARCH" : "RESEARCH"}</span>
        <h2 id="insights-title">{de ? "Arbeit, die ihre Logik offenlegt." : "Work that explains its logic."}</h2>
      </div>
      <div class="insight-list">
        {insights.map((insight, index) => (
          <a href={insight.paths[lang]}><span>0{index + 1}</span><strong>{pick(insight.title, lang)}</strong><b class="ui-arrow" aria-hidden="true"></b></a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .locale-hero,.band{position:relative;z-index:1}.locale-hero{min-height:100svh;display:grid;align-items:center;padding:9rem 0 5rem;background:radial-gradient(circle at 72% 40%,rgba(255,255,255,.08),transparent 25rem)}
  .hero-grid{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(18rem,.55fr);gap:clamp(3rem,8vw,9rem);align-items:end}.eyebrow{display:block;color:rgba(var(--rgb-text),.56);font:.64rem/1.4 var(--font-inter);letter-spacing:.22em;text-transform:uppercase}.locale-hero h1,.band h2{font-family:var(--font-display);font-weight:500;letter-spacing:0;color:#f7f9f9}.locale-hero h1{max-width:11ch;margin:1.7rem 0;font-size:clamp(4rem,8.5vw,9rem);line-height:.88}.locale-hero p{max-width:42rem;color:rgba(var(--rgb-text),.76);font-size:clamp(1.15rem,1.7vw,1.5rem);line-height:1.55}.hero-actions{display:flex;gap:.8rem;margin-top:2.3rem;flex-wrap:wrap}.hero-actions a{padding:.9rem 1.2rem;border:1px solid rgba(255,255,255,.18);border-radius:5px}.hero-actions .primary{background:#f2f4f4;color:#090a0b}.locale-hero aside{display:grid;gap:.55rem;padding:1.5rem;border:1px solid rgba(255,255,255,.13);background:rgba(8,9,10,.62);backdrop-filter:blur(18px)}.locale-hero aside span{margin-top:.8rem;color:rgba(var(--rgb-text),.4);font:.6rem var(--font-inter);letter-spacing:.18em}.locale-hero aside strong{font:.74rem var(--font-inter);letter-spacing:.12em}.band{padding:clamp(6rem,10vw,10rem) 0;background:rgba(3,4,5,.76);border-top:1px solid rgba(255,255,255,.07)}.band h2{max-width:12ch;margin:1.3rem 0 3.5rem;font-size:clamp(3rem,6.2vw,6.8rem);line-height:.94}.service-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.service{min-height:26rem;display:flex;flex-direction:column;padding:1.6rem;border:1px solid rgba(255,255,255,.12);background:linear-gradient(145deg,rgba(255,255,255,.05),rgba(255,255,255,.008));transition:transform .4s,border-color .4s}.service:hover{transform:translateY(-8px);border-color:rgba(255,255,255,.28)}.service>span,.case span{color:rgba(var(--rgb-text),.45);font:.62rem var(--font-inter);letter-spacing:.18em}.service h3{margin:auto 0 1rem;font:500 clamp(1.7rem,2.7vw,3rem)/1 var(--font-display)}.service p{color:rgba(var(--rgb-text),.66);line-height:1.55}.service b{margin-top:1.5rem;font:.66rem var(--font-inter);letter-spacing:.12em;text-transform:uppercase}.case-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}.case{position:relative;min-height:40rem;overflow:hidden;border:1px solid rgba(255,255,255,.13);background:#060708}.case img{width:100%;height:100%;object-fit:cover;filter:saturate(.55) brightness(.72);transition:transform .8s,filter .5s}.case:hover img{transform:scale(1.035);filter:saturate(.8) brightness(.82)}.case div{position:absolute;inset:auto 0 0;padding:2rem;background:linear-gradient(transparent,rgba(0,0,0,.92))}.case h3{margin:.7rem 0;font:500 clamp(2.3rem,4vw,4.4rem)/1 var(--font-display)}.case p{max-width:35rem;color:rgba(255,255,255,.72);line-height:1.5}.insights-layout{display:grid;grid-template-columns:.8fr 1.2fr;gap:5rem}.insight-list{border-top:1px solid rgba(255,255,255,.14)}.insight-list a{display:grid;grid-template-columns:3rem 1fr auto;gap:1.5rem;align-items:center;padding:1.6rem 0;border-bottom:1px solid rgba(255,255,255,.14)}.insight-list span,.insight-list b{font:.65rem var(--font-inter);letter-spacing:.14em;color:rgba(var(--rgb-text),.5)}.insight-list strong{font:500 clamp(1.15rem,2vw,1.8rem)/1.15 var(--font-display)}
  @media(max-width:900px){.hero-grid,.insights-layout{grid-template-columns:1fr}.hero-grid{gap:2.5rem}.service-grid{grid-template-columns:1fr}.case-grid{grid-template-columns:1fr}.case{min-height:30rem}.locale-hero{padding-top:7rem}.locale-hero h1{max-width:100%;font-size:clamp(3rem,13vw,5.5rem);overflow-wrap:anywhere}.band h2{max-width:100%;font-size:clamp(2.6rem,11vw,5rem);overflow-wrap:anywhere}.service{min-height:21rem}.insight-list a{grid-template-columns:2rem minmax(0,1fr) auto;gap:.8rem}.insight-list strong{overflow-wrap:anywhere}}@media(max-width:520px){.case{min-height:25rem}.case div{padding:1.3rem}.locale-hero aside{padding:1.1rem}.hero-actions a{flex:1;text-align:center}}@media(pointer:coarse){.locale-hero aside{backdrop-filter:none;background:rgba(8,9,10,.92)}.service:hover{transform:none}.case:hover img{transform:none;filter:saturate(.55) brightness(.72)}}
</style>
