---
// ─────────────────────────────────────────────────────────────────────────────
//  ScrollScrub.astro — Apple-style scroll-scrubbed product film.
//
//  A tall section with a sticky viewport; scroll progress is mapped straight
//  onto video.currentTime, so Rodion's 3D product animation turns under the
//  visitor's own scroll instead of autoplaying past them.
//
//  Sticky (CSS) rather than a GSAP pin: no pin-spacer to fight with Lenis.
//  On touch / reduced-motion it degrades to a normal looping autoplay clip.
// ─────────────────────────────────────────────────────────────────────────────
interface Props {
  video: string;
  poster: string;
  eyebrowKey?: string;
  titleKey?: string;
  textKey?: string;
  eyebrow?: string;
  title?: string;
  text?: string;
}

const { video, poster, eyebrowKey, titleKey, textKey, eyebrow, title, text } = Astro.props;
---

<section class="scrub" data-scrub>
  <div class="scrub-sticky">
    <video
      class="scrub-vid"
      src={video}
      poster={poster}
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
      data-scrub-video></video>

    <div class="scrub-veil" aria-hidden="true"></div>

    <div class="scrub-copy">
      <span class="scrub-eyebrow" data-i18n={eyebrowKey}>{eyebrow}</span>
      <h2 class="scrub-title" data-i18n={titleKey}>{title}</h2>
      <p class="scrub-text" data-i18n={textKey}>{text}</p>
    </div>

    <div class="scrub-hud" aria-hidden="true">
      <span class="scrub-rec"><i></i>REC</span>
      <span class="scrub-bar"><i data-scrub-bar></i></span>
      <span class="scrub-frame" data-scrub-frame>FRAME 0000</span>
    </div>
  </div>
</section>

<style>
  .scrub {
    position: relative;
    /* the scroll distance that drives the film */
    height: 300vh;
  }

  .scrub-sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    isolation: isolate;
    background: #050505;
  }

  .scrub-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Graded down to obsidian: only the highlights survive, so the film reads
       as sculpture in the dark rather than as a bright stock clip. */
    filter: contrast(1.32) brightness(0.52) saturate(0.28);
  }

  .scrub-veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(115% 85% at 70% 46%, transparent 0%, rgba(0, 0, 0, 0.5) 62%, rgba(0, 0, 0, 0.92) 100%),
      linear-gradient(90deg, rgba(3, 3, 4, 0.94), rgba(3, 3, 4, 0.55) 44%, rgba(3, 3, 4, 0.1) 74%),
      linear-gradient(0deg, rgba(3, 3, 4, 0.88), transparent 46%);
  }

  /* faint scan of the film gate */
  .scrub-sticky::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.5;
    background: repeating-linear-gradient(
      0deg,
      transparent 0 3px,
      rgba(255, 255, 255, 0.014) 3px 4px
    );
  }

  .scrub-copy {
    position: absolute;
    left: clamp(1.5rem, 5vw, 5rem);
    bottom: clamp(4.5rem, 10vw, 8rem);
    max-width: 34rem;
  }

  .scrub-eyebrow {
    display: inline-block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .scrub-title {
    margin: 1rem 0 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5.5vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: #fff;
  }

  .scrub-text {
    margin: 1.1rem 0 0;
    max-width: 42ch;
    color: rgba(var(--rgb-text), 0.66);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .scrub-hud {
    position: absolute;
    right: clamp(1.5rem, 5vw, 5rem);
    bottom: clamp(4.5rem, 10vw, 8rem);
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: rgba(var(--rgb-text), 0.6);
    font-variant-numeric: tabular-nums;
  }

  .scrub-rec {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(var(--rgb-text), 0.75);
  }
  .scrub-rec i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0.6rem rgba(255, 255, 255, 0.7);
    animation: rec-blink 1.6s steps(2) infinite;
  }
  @keyframes rec-blink {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 1; }
  }

  .scrub-bar {
    display: block;
    width: clamp(5rem, 12vw, 11rem);
    height: 1px;
    background: rgba(255, 255, 255, 0.16);
  }

  .scrub-bar i {
    display: block;
    width: 0%;
    height: 100%;
    background: #fff;
    box-shadow: 0 0 0.8rem rgba(255, 255, 255, 0.5);
  }

  /* Touch + reduced motion: scrubbing an mp4 by finger is unreliable, so the
     film simply plays itself and the section collapses to one screen. */
  @media (pointer: coarse), (prefers-reduced-motion: reduce) {
    .scrub { height: auto; }
    .scrub-sticky { position: relative; height: 78svh; }
    .scrub-hud { display: none; }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>("[data-scrub]");
  const video = document.querySelector<HTMLVideoElement>("[data-scrub-video]");
  const bar = document.querySelector<HTMLElement>("[data-scrub-bar]");
  const frame = document.querySelector<HTMLElement>("[data-scrub-frame]");

  if (section && video) {
    const coarse = matchMedia("(pointer: coarse)").matches;
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (coarse || reduced) {
      // fallback: just play it
      video.loop = true;
      const io = new IntersectionObserver(
        ([e]) => (e.isIntersecting ? video.play().catch(() => {}) : video.pause()),
        { threshold: 0.2 },
      );
      io.observe(section);
    } else {
      let duration = 0;
      const ready = () => {
        duration = video.duration || 0;
        ScrollTrigger.refresh();
      };
      if (video.readyState >= 1) ready();
      else video.addEventListener("loadedmetadata", ready, { once: true });

      // Seeking every frame thrashes the decoder; throttle to the target frame
      // and let the browser settle between seeks.
      let target = 0;
      let seeking = false;
      const apply = () => {
        if (!duration || seeking) return;
        if (Math.abs(video.currentTime - target) < 0.02) return;
        seeking = true;
        video.currentTime = target;
      };
      video.addEventListener("seeked", () => {
        seeking = false;
        apply();
      });

      ScrollTrigger.create({
        trigger: section,
        start: "top top",
        end: "bottom bottom",
        scrub: true,
        onUpdate: (self) => {
          const p = self.progress;
          target = p * duration;
          apply();
          if (bar) bar.style.width = `${(p * 100).toFixed(1)}%`;
          // Read as an edit suite, not a progress bar: real frame numbers off
          // the clip's own duration (25fps), so the count means something.
          if (frame) {
            const total = Math.max(1, Math.round(duration * 25));
            const current = Math.round(p * total);
            frame.textContent = `FRAME ${String(current).padStart(4, "0")} / ${String(total).padStart(4, "0")}`;
          }
        },
      });
    }
  }
</script>
