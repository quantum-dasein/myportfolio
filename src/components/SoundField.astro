---
// ─────────────────────────────────────────────────────────────────────────────
//  SoundField — the studio's ambience.
//
//  Plays Rodion's own generated audio (an ambient drone + two UI ticks) through
//  the Web Audio API rather than <audio> elements: a looping AudioBufferSource
//  loops seamlessly, where HTMLAudioElement.loop leaves an audible gap.
//
//  Rules it respects:
//   • OFF by default and never autoplays for a visitor who never asked for it.
//   • The ~1MB drone is NOT fetched until the visitor actually turns sound on.
//   • Once they HAVE asked, the ambience follows them across the site on its
//     own — it takes a breath and fades back in, it never waits for a click.
//   • Choice persists; muted under Calm mode and when the tab is hidden.
// ─────────────────────────────────────────────────────────────────────────────
---

<script>
  const STORE = "rb-sound";

  const SRC = {
    drone: "/audio/rb-ambient-drone.m4a",
    tick: "/audio/rb-ui-tick.m4a",   // light hover blip
    thunk: "/audio/rb-ui-thunk.m4a", // heavier click / toggle
  };

  const POS_KEY = "rb-sound-pos";

  const AMBIENT_LEVEL = 0.34; // the drone is already quiet; this is the ceiling
  const TICK_LEVEL = 0.1;     // hover fires constantly — it must be a whisper
  const THUNK_LEVEL = 0.26;

  // Crossing to another page reads as a beat of held breath, not a dropout: the
  // drone stops with the old document, rests, then eases back in exactly where
  // it left off. Both numbers are seconds and are scheduled on the audio clock,
  // so the gap is identical every time regardless of how busy the main thread is.
  const RESUME_PAUSE = 1.2;
  const RESUME_FADE = 1.6;
  // A deliberate toggle is a gesture, so it gets its own quicker, firmer rise.
  const TOGGLE_FADE = 0.6;

  let ctx: AudioContext | null = null;
  let master: GainNode | null = null;
  let droneGain: GainNode | null = null;
  let droneSource: AudioBufferSourceNode | null = null;
  const buffers = new Map<string, AudioBuffer>();
  let loading: Promise<void> | null = null;
  let enabled = false;

  // Every navigation is a brand-new document, so the AudioContext dies with it
  // and the drone would restart from zero. Remember where it was and resume
  // there, so the ambience reads as one continuous track across the site.
  let droneStartedAt = 0; // ctx.currentTime when the loop was started
  let droneOffset = 0;    // where in the buffer it started

  function dronePosition() {
    const buf = buffers.get("drone");
    if (!buf || !ctx || !droneSource) return droneOffset;
    // Guard the scheduled-but-not-yet-playing window, where currentTime is still
    // behind droneStartedAt and the elapsed term would run negative.
    const elapsed = Math.max(0, ctx.currentTime - droneStartedAt);
    return (droneOffset + elapsed) % buf.duration;
  }

  function rememberPosition() {
    if (!enabled || !droneSource) return;
    try { sessionStorage.setItem(POS_KEY, String(dronePosition())); } catch { /* private mode */ }
  }

  const isCalm = () => document.documentElement.classList.contains("rb-calm");
  const level = () => (enabled && !isCalm() && !document.hidden ? 1 : 0);

  function ensureContext() {
    if (ctx) return ctx;
    const Ctor = window.AudioContext || (window as any).webkitAudioContext;
    if (!Ctor) return null;
    ctx = new Ctor();
    master = ctx.createGain();
    master.gain.value = 0;
    master.connect(ctx.destination);
    droneGain = ctx.createGain();
    droneGain.gain.value = AMBIENT_LEVEL;
    droneGain.connect(master);
    return ctx;
  }

  async function load(key: keyof typeof SRC) {
    if (buffers.has(key) || !ctx) return;
    const res = await fetch(SRC[key]);
    const raw = await res.arrayBuffer();
    buffers.set(key, await ctx.decodeAudioData(raw));
  }

  /** Fetch + decode everything once, on the first activation only. */
  function loadAll() {
    if (!loading) {
      loading = (async () => {
        await Promise.all([load("drone"), load("tick"), load("thunk")]);
      })().catch(() => {
        loading = null; // let a later toggle retry
      });
    }
    return loading;
  }

  /** @param when audio-clock time to begin at; 0 means "now". */
  function startDrone(when = 0) {
    if (!ctx || !droneGain || droneSource) return;
    const buf = buffers.get("drone");
    if (!buf) return;

    let resumeAt = 0;
    try { resumeAt = Number(sessionStorage.getItem(POS_KEY) || 0); } catch { /* private mode */ }
    droneOffset = Number.isFinite(resumeAt) ? resumeAt % buf.duration : 0;

    droneSource = ctx.createBufferSource();
    droneSource.buffer = buf;
    droneSource.loop = true;
    droneSource.connect(droneGain);
    droneSource.start(when, droneOffset); // pick the track back up, don't restart it
    droneStartedAt = when || ctx.currentTime;
  }

  function stopDrone() {
    rememberPosition();
    droneSource?.stop();
    droneSource?.disconnect();
    droneSource = null;
  }

  // The generated one-shots are padded out to ~3s of trailing silence. Playing
  // them whole would stack dozens of near-silent sources on a fast hover, so
  // each is cut to just its transient and given a short fade-out.
  const CLIP = { tick: 0.4, thunk: 0.9 } as const;

  function play(key: "tick" | "thunk", gain: number) {
    if (!ctx || !master || !enabled || isCalm() || document.hidden) return;
    const buf = buffers.get(key);
    if (!buf) return;
    const dur = Math.min(CLIP[key], buf.duration);
    const src = ctx.createBufferSource();
    const g = ctx.createGain();
    src.buffer = buf;
    g.gain.setValueAtTime(gain, ctx.currentTime);
    g.gain.setValueAtTime(gain, ctx.currentTime + dur * 0.7);
    g.gain.linearRampToValueAtTime(0.0001, ctx.currentTime + dur);
    src.connect(g).connect(master);
    src.start(0, 0, dur);
    src.onended = () => src.disconnect();
  }

  /** Ramp the master gain, optionally starting at a future point on the audio clock. */
  function fade(to: number, time = 0.6, from = 0) {
    if (!ctx || !master) return;
    const at = Math.max(ctx.currentTime, from || ctx.currentTime);
    master.gain.cancelScheduledValues(ctx.currentTime);
    master.gain.setValueAtTime(master.gain.value, ctx.currentTime);
    if (at > ctx.currentTime) master.gain.setValueAtTime(master.gain.value, at);
    master.gain.linearRampToValueAtTime(to, at + time);
  }

  function markToggles(on: boolean) {
    document.querySelectorAll<HTMLElement>("[data-sound-toggle]").forEach((btn) =>
      btn.setAttribute("aria-pressed", String(on)),
    );
    document.documentElement.classList.toggle("rb-sound", on);
  }

  type ApplyOptions = {
    /** Write the choice to localStorage. Off when we are only restoring it. */
    persist?: boolean;
    /** Punctuate with the toggle thunk. Only a deliberate press earns one. */
    thunk?: boolean;
    fadeTime?: number;
  };

  async function apply(on: boolean, opts: ApplyOptions = {}) {
    const { persist = true, thunk = true, fadeTime = TOGGLE_FADE } = opts;
    enabled = on;
    markToggles(on);
    if (persist) {
      try { localStorage.setItem(STORE, on ? "on" : "off"); } catch { /* private mode */ }
    }

    if (!on) {
      fade(0, 0.45);
      setTimeout(() => { if (!enabled) stopDrone(); }, 500);
      return;
    }

    if (!ensureContext()) return;
    await ctx!.resume();
    await loadAll();       // ~1MB, fetched only now
    if (!enabled) return;  // toggled off while loading
    startDrone();
    if (thunk) play("thunk", THUNK_LEVEL);
    fade(level(), fadeTime);
  }

  // ── Continuity across navigation ──────────────────────────────────────────
  // Every page is a fresh document, so the ambience has to re-enter itself. It
  // used to sit silent until the visitor happened to click something, and then
  // land as one abrupt hit. Now it re-arms the moment the page boots: it takes
  // RESUME_PAUSE of deliberate silence, then eases in from the stored playhead.
  async function resumeFromNavigation() {
    enabled = true;
    markToggles(true);
    if (!ensureContext()) return;

    // Fetching and decoding need no gesture, and the drone is already in the
    // HTTP cache from the previous page — so this is ready well before we need it.
    const ready = loadAll();
    await ctx!.resume().catch(() => { /* blocked — handled below */ });

    // Chrome grants an origin the right to start audio once the visitor has
    // interacted with it, which they did by turning sound on. When that grant
    // is missing (a hard reload, a stricter browser) the context stays
    // suspended, and there is nothing to do but wait for a real gesture.
    if (ctx!.state !== "running") {
      armOnGesture();
      return;
    }

    await ready;
    if (!enabled || droneSource) return; // toggled off, or a gesture beat us to it
    const at = ctx!.currentTime + RESUME_PAUSE;
    startDrone(at);
    fade(level(), RESUME_FADE, at);
  }

  let armed = false;
  function armOnGesture() {
    if (armed) return;
    armed = true;
    let fired = false;
    const arm = () => {
      if (fired) return;
      fired = true;
      // Their gesture was meant for whatever they clicked, not for the audio —
      // so it still eases in rather than announcing itself.
      apply(true, { persist: false, thunk: false, fadeTime: RESUME_FADE });
    };
    // Any of these counts as activation; whichever lands first wins.
    ["pointerdown", "touchstart", "keydown"].forEach((type) =>
      addEventListener(type, arm, { once: true, passive: true }),
    );
  }

  // ── Wiring ────────────────────────────────────────────────────────────────
  document.addEventListener("click", (e) => {
    const toggle = (e.target as HTMLElement)?.closest("[data-sound-toggle]");
    if (toggle) {
      apply(!enabled);
      return;
    }
    if ((e.target as HTMLElement)?.closest("a, button")) play("thunk", THUNK_LEVEL * 0.55);
  });

  let lastHover: Element | null = null;
  let lastTick = 0;
  addEventListener("pointerover", (e) => {
    const el = (e.target as HTMLElement)?.closest("a, button, [data-cursor]");
    if (!el || el === lastHover) return;
    lastHover = el;
    // sweeping across a nav must not machine-gun the tick
    const now = performance.now();
    if (now - lastTick < 90) return;
    lastTick = now;
    play("tick", TICK_LEVEL);
  }, { passive: true });

  addEventListener("rb:calmchange", () => fade(level(), 0.35));

  // Dispatched the instant a transition commits to the new URL — the old
  // document then lives just long enough for this to land, so the ambience bows
  // out over the page swap instead of being guillotined by pagehide.
  addEventListener("rb:transition-depart", () => {
    rememberPosition();
    fade(0, 0.3);
  });

  document.addEventListener("visibilitychange", () => {
    rememberPosition();
    fade(level(), 0.25);
  });

  // Hand the playhead to the next page. pagehide is the one that survives
  // bfcache and mobile Safari, where unload never fires.
  addEventListener("pagehide", rememberPosition);
  // …and a slow heartbeat, so a crash or a hard close never loses the spot.
  setInterval(rememberPosition, 4000);

  // Restore the stored choice. Sound stays off unless this visitor asked for it
  // on an earlier page — at which point the ambience resumes itself, and only
  // falls back to waiting for a gesture if the browser refuses to let it start.
  let stored = "off";
  try { stored = localStorage.getItem(STORE) || "off"; } catch { /* private mode */ }
  if (stored === "on") resumeFromNavigation();
</script>
