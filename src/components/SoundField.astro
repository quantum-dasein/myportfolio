---
// ─────────────────────────────────────────────────────────────────────────────
//  SoundField — the studio's ambience.
//
//  Plays Rodion's own generated audio (an ambient drone + two UI ticks) through
//  the Web Audio API rather than <audio> elements: a looping AudioBufferSource
//  loops seamlessly, where HTMLAudioElement.loop leaves an audible gap.
//
//  Rules it respects:
//   • OFF by default and never autoplays — browsers block it and visitors hate it.
//   • The ~1MB drone is NOT fetched until the visitor actually turns sound on.
//   • The AudioContext is only created on the first real user gesture.
//   • Choice persists; muted under Calm mode and when the tab is hidden.
// ─────────────────────────────────────────────────────────────────────────────
---

<script>
  const STORE = "rb-sound";

  const SRC = {
    drone: "/audio/rb-ambient-drone.m4a",
    tick: "/audio/rb-ui-tick.m4a",   // light hover blip
    thunk: "/audio/rb-ui-thunk.m4a", // heavier click / toggle
  };

  const AMBIENT_LEVEL = 0.34; // the drone is already quiet; this is the ceiling
  const TICK_LEVEL = 0.3;
  const THUNK_LEVEL = 0.5;

  let ctx: AudioContext | null = null;
  let master: GainNode | null = null;
  let droneGain: GainNode | null = null;
  let droneSource: AudioBufferSourceNode | null = null;
  const buffers = new Map<string, AudioBuffer>();
  let loading: Promise<void> | null = null;
  let enabled = false;

  const isCalm = () => document.documentElement.classList.contains("rb-calm");
  const level = () => (enabled && !isCalm() && !document.hidden ? 1 : 0);

  function ensureContext() {
    if (ctx) return ctx;
    const Ctor = window.AudioContext || (window as any).webkitAudioContext;
    if (!Ctor) return null;
    ctx = new Ctor();
    master = ctx.createGain();
    master.gain.value = 0;
    master.connect(ctx.destination);
    droneGain = ctx.createGain();
    droneGain.gain.value = AMBIENT_LEVEL;
    droneGain.connect(master);
    return ctx;
  }

  async function load(key: keyof typeof SRC) {
    if (buffers.has(key) || !ctx) return;
    const res = await fetch(SRC[key]);
    const raw = await res.arrayBuffer();
    buffers.set(key, await ctx.decodeAudioData(raw));
  }

  /** Fetch + decode everything once, on the first activation only. */
  function loadAll() {
    if (!loading) {
      loading = (async () => {
        await Promise.all([load("drone"), load("tick"), load("thunk")]);
      })().catch(() => {
        loading = null; // let a later toggle retry
      });
    }
    return loading;
  }

  function startDrone() {
    if (!ctx || !droneGain || droneSource) return;
    const buf = buffers.get("drone");
    if (!buf) return;
    droneSource = ctx.createBufferSource();
    droneSource.buffer = buf;
    droneSource.loop = true;
    droneSource.connect(droneGain);
    droneSource.start();
  }

  function stopDrone() {
    droneSource?.stop();
    droneSource?.disconnect();
    droneSource = null;
  }

  // The generated one-shots are padded out to ~3s of trailing silence. Playing
  // them whole would stack dozens of near-silent sources on a fast hover, so
  // each is cut to just its transient and given a short fade-out.
  const CLIP = { tick: 0.4, thunk: 0.9 } as const;

  function play(key: "tick" | "thunk", gain: number) {
    if (!ctx || !master || !enabled || isCalm() || document.hidden) return;
    const buf = buffers.get(key);
    if (!buf) return;
    const dur = Math.min(CLIP[key], buf.duration);
    const src = ctx.createBufferSource();
    const g = ctx.createGain();
    src.buffer = buf;
    g.gain.setValueAtTime(gain, ctx.currentTime);
    g.gain.setValueAtTime(gain, ctx.currentTime + dur * 0.7);
    g.gain.linearRampToValueAtTime(0.0001, ctx.currentTime + dur);
    src.connect(g).connect(master);
    src.start(0, 0, dur);
    src.onended = () => src.disconnect();
  }

  function fade(to: number, time = 0.6) {
    if (!ctx || !master) return;
    master.gain.cancelScheduledValues(ctx.currentTime);
    master.gain.setValueAtTime(master.gain.value, ctx.currentTime);
    master.gain.linearRampToValueAtTime(to, ctx.currentTime + time);
  }

  async function apply(on: boolean, persist = true) {
    enabled = on;

    document.querySelectorAll<HTMLElement>("[data-sound-toggle]").forEach((btn) =>
      btn.setAttribute("aria-pressed", String(on)),
    );
    document.documentElement.classList.toggle("rb-sound", on);
    if (persist) {
      try { localStorage.setItem(STORE, on ? "on" : "off"); } catch { /* private mode */ }
    }

    if (!on) {
      fade(0, 0.45);
      setTimeout(() => { if (!enabled) stopDrone(); }, 500);
      return;
    }

    if (!ensureContext()) return;
    await ctx!.resume();
    await loadAll();       // ~1MB, fetched only now
    if (!enabled) return;  // toggled off while loading
    startDrone();
    play("thunk", THUNK_LEVEL);
    fade(level());
  }

  // ── Wiring ────────────────────────────────────────────────────────────────
  document.addEventListener("click", (e) => {
    const toggle = (e.target as HTMLElement)?.closest("[data-sound-toggle]");
    if (toggle) {
      apply(!enabled);
      return;
    }
    if ((e.target as HTMLElement)?.closest("a, button")) play("thunk", THUNK_LEVEL * 0.55);
  });

  let lastHover: Element | null = null;
  let lastTick = 0;
  addEventListener("pointerover", (e) => {
    const el = (e.target as HTMLElement)?.closest("a, button, [data-cursor]");
    if (!el || el === lastHover) return;
    lastHover = el;
    // sweeping across a nav must not machine-gun the tick
    const now = performance.now();
    if (now - lastTick < 90) return;
    lastTick = now;
    play("tick", TICK_LEVEL);
  }, { passive: true });

  addEventListener("rb:calmchange", () => fade(level(), 0.35));
  document.addEventListener("visibilitychange", () => fade(level(), 0.25));

  // Restore the stored choice, but only arm audio on the first gesture —
  // an AudioContext created before that is born suspended.
  let stored = "off";
  try { stored = localStorage.getItem(STORE) || "off"; } catch { /* private mode */ }
  if (stored === "on") {
    const arm = () => apply(true, false);
    addEventListener("pointerdown", arm, { once: true });
    addEventListener("keydown", arm, { once: true });
    document.querySelectorAll<HTMLElement>("[data-sound-toggle]").forEach((b) => b.setAttribute("aria-pressed", "true"));
    document.documentElement.classList.add("rb-sound");
  }
</script>
