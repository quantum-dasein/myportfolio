---
// ─────────────────────────────────────────────────────────────────────────────
//  Spatial.astro — the spatial 3D experience (the whole site).
//
//  Concept: an infinite black corridor (#050505 + fog + dust). Projects are
//  monumental onyx-glass PORTAL FRAMES at increasing Z depth; through each frame
//  the project is dimly visible via refraction/glass distortion. Scroll flies
//  the PerspectiveCamera forward along Z (fly-through). A strict chrome/platinum
//  cockpit HUD is anchored to the active portal and decodes its data in.
//
//  Click a portal → the camera flies THROUGH it (no modal, no blur) → a custom
//  GLSL transition dissolves the scene → the project "world" (focused, retinted).
//  Exit flies back. Everything runs through an RT composite for cinematic post
//  (vignette + fine grain + edge chromatic aberration) and the transition wipe.
//
//  Aesthetic: monochrome; the only "accent" is polished chrome (fresnel rims,
//  metal gradient) — cockpit / luxury-instrument, noir, cinematic.
//  60fps: capped DPR, gsap.ticker, pause when hidden, full .dispose().
// ─────────────────────────────────────────────────────────────────────────────
import { works } from "../data/works";
---

<div class="space" data-space-stage></div>

<div class="hud" data-hud>
  <!-- brand / sector -->
  <div class="hud-tl">
    <span class="mono">RB · STUDIO</span>
    <span class="mono dim" data-hud-sector>SECTOR 00 / {String(works.length).padStart(2, "0")}</span>
  </div>

  <!-- anchored marker that tracks the active portal in 3D -->
  <div class="marker" data-marker>
    <span class="marker-ring"></span>
    <span class="marker-idx" data-marker-idx>00</span>
  </div>

  <!-- active project panel (bottom-left), data decodes in -->
  <div class="panel" data-panel>
    <span class="mono dim" data-panel-cat>—</span>
    <h2 class="panel-title" data-panel-title>—</h2>
    <div class="panel-row">
      <span class="mono" data-panel-meta>—</span>
      <span class="enter mono" data-enter>ENTER ⟶</span>
    </div>
  </div>

  <!-- depth / progress (right) -->
  <div class="hud-depth">
    <span class="mono dim">DEPTH</span>
    <div class="depth-bar"><span data-depth-bar></span></div>
    <span class="mono" data-depth-val>Z 000.0</span>
  </div>

  <nav class="sector-nav" aria-label="Archive sectors">
    {works.map((work, index) => (
      <button type="button" data-sector-jump={index} aria-label={`Open sector ${index + 1}: ${work.title ?? work.hrefLabel}`}>
        <span></span><b>{String(index + 1).padStart(2, "0")}</b>
      </button>
    ))}
  </nav>

  <!-- scroll hint -->
  <div class="scrollhint mono" data-scrollhint>WHEEL: DEPTH · DRAG: STRAFE · WASD: MOVE</div>

  <!-- exit prompt (project world) -->
  <button class="exit mono" data-exit>⟵ EXIT</button>

  <aside class="film-note" data-film-note aria-live="polite">
    <span class="film-note__tools mono" data-film-tools></span>
    <div class="film-note__line" aria-hidden="true"><i></i><b><span class="film-note__arrow"></span></b></div>
    <p data-film-copy></p>
  </aside>

  <!-- corner brackets -->
  <span class="bracket tl"></span><span class="bracket tr"></span>
  <span class="bracket bl"></span><span class="bracket br"></span>
</div>

<div class="preloader" data-preloader>
  <div class="pre-inner">
    <span class="pre-tag">RODION BELOUSOV<span class="dot">.STUDIO</span></span>
    <div class="pre-row mono">
      <span data-i18n="preloader.label">Calibrating the void</span>
      <span><span data-pct>0</span>%</span>
    </div>
    <div class="pre-bar"><span data-bar></span></div>
  </div>
</div>

<style>
  .space {
    position: fixed;
    inset: 0;
    z-index: 0;
    touch-action: none;
    user-select: none;
  }
  :global(canvas.rb-space-canvas) {
    position: fixed;
    inset: 0;
    width: 100vw !important;
    height: 100svh !important;
    z-index: 0;
    display: block;
  }

  .mono {
    font-family: var(--font-inter);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .mono.dim {
    color: var(--color-text-alt);
  }

  /* ── HUD ────────────────────────────────────────────────────────────────── */
  .hud {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
  }
  .hud > * {
    position: absolute;
  }

  .hud-tl {
    top: 6.5rem;
    left: var(--container-offset);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* anchored 3D marker */
  .marker {
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-expo);
    will-change: transform;
  }
  .marker-ring {
    position: absolute;
    width: 2.4rem;
    height: 2.4rem;
    margin: -1.2rem;
    border: 1px solid var(--color-accent);
    border-radius: 50%;
    opacity: 0.6;
    animation: spin 6s linear infinite;
  }
  .marker-ring::before {
    content: "";
    position: absolute;
    inset: 0.5rem;
    border-top: 1px solid var(--color-accent);
    border-radius: 50%;
  }
  .marker-idx {
    position: absolute;
    left: 1.8rem;
    top: -0.6rem;
    font-family: var(--font-inter);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--color-accent);
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .panel {
    bottom: 3rem;
    left: var(--container-offset);
    max-width: 34rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .panel-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5.5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--color-text);
  }
  .panel-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .enter {
    pointer-events: auto;
    cursor: pointer;
    color: var(--color-accent);
    border: 1px solid var(--color-line);
    padding: 0.5rem 0.9rem;
    border-radius: 2px;
    transition: border-color 0.3s, background 0.3s;
  }
  .enter:hover {
    border-color: var(--color-accent);
    background: rgba(var(--rgb-accent), 0.08);
  }

  .hud-depth {
    top: 50%;
    right: var(--container-offset);
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.8rem;
  }
  .depth-bar {
    width: 1px;
    height: 34vh;
    background: var(--color-line);
    position: relative;
  }
  .depth-bar span {
    position: absolute;
    top: 0;
    left: -1px;
    width: 3px;
    height: 0%;
    background: var(--color-accent);
  }

  .scrollhint {
    bottom: 5.15rem;
    left: auto;
    right: var(--container-offset);
    transform: none;
    color: var(--color-text-alt);
    animation: fade 2.4s ease-in-out infinite;
    white-space: nowrap;
    text-align: right;
  }

  .sector-nav {
    right: var(--container-offset);
    bottom: 1.75rem;
    display: flex;
    gap: 0.5rem;
    pointer-events: auto;
  }

  .sector-nav button {
    display: grid;
    grid-template-columns: 1rem auto;
    gap: 0.35rem;
    align-items: center;
    padding: 0.35rem;
    border: 0;
    background: transparent;
    color: rgba(var(--rgb-text), 0.36);
    cursor: pointer;
    font: 500 0.56rem/1 var(--font-inter);
    letter-spacing: 0.1em;
  }
  .sector-nav button span {
    width: 1rem;
    height: 1px;
    background: currentColor;
    transition: width 0.3s ease, color 0.3s ease;
  }
  .sector-nav button b { font-weight: 500; }
  .sector-nav button:hover,
  .sector-nav button.is-active { color: #fff; }
  .sector-nav button.is-active span { width: 1.45rem; box-shadow: 0 0 0.8rem rgba(255,255,255,.45); }
  @keyframes fade {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .exit {
    top: 6.5rem;
    left: var(--container-offset);
    pointer-events: auto;
    cursor: pointer;
    background: none;
    border: 1px solid var(--color-line);
    padding: 0.5rem 0.9rem;
    border-radius: 2px;
    color: var(--color-text);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s, border-color 0.3s;
  }
  .exit:hover {
    border-color: var(--color-accent);
  }
  :global(body.is-inside) .exit {
    opacity: 1;
    visibility: visible;
  }
  :global(body.is-inside) .hud-tl,
  :global(body.is-inside) .scrollhint,
  :global(body.is-inside) .marker,
  :global(body.is-inside) .panel,
  :global(body.is-inside) .hud-depth {
    opacity: 0;
    pointer-events: none;
  }
  :global(body.is-inside) .sector-nav { opacity: 0; pointer-events: none; }

  .film-note {
    position: fixed;
    z-index: 12;
    right: clamp(1.25rem, 4vw, 4.5rem);
    top: 50%;
    width: min(21rem, 22vw);
    opacity: 0;
    visibility: hidden;
    transform: translate3d(1.25rem, -50%, 0);
    transition: opacity .32s ease, transform .55s var(--ease-out-expo), visibility 0s .55s;
    pointer-events: none;
  }
  :global(body.is-inside.has-film-note) .film-note {
    opacity: 1;
    visibility: visible;
    transform: translate3d(0, -50%, 0);
    transition-delay: .18s, .18s, 0s;
  }
  .film-note__tools { display:block; color:rgba(255,255,255,.62); font-size:.58rem; letter-spacing:.17em; line-height:1.5; }
  .film-note__line { display:grid; grid-template-columns:1fr auto; align-items:center; gap:1rem; margin:1rem 0; }
  .film-note__line i { height:1px; background:linear-gradient(90deg,rgba(255,255,255,.75),rgba(255,255,255,.08)); transform-origin:left; animation:film-signal 1.4s var(--ease-out-expo) both; }
  .film-note__line b { display:grid; width:2.7rem; aspect-ratio:1; place-items:center; border:1px solid rgba(255,255,255,.38); border-radius:50%; font-weight:400; }
  .film-note__arrow { position:relative; display:block; width:.72rem; height:.72rem; }
  .film-note__arrow::before,
  .film-note__arrow::after { content:""; position:absolute; }
  .film-note__arrow::before { left:.07rem; bottom:.05rem; width:.72rem; height:1px; background:currentColor; transform:rotate(-45deg); transform-origin:left center; }
  .film-note__arrow::after { right:0; top:0; width:.4rem; height:.4rem; border-top:1px solid currentColor; border-right:1px solid currentColor; }
  .film-note p { margin:0; color:rgba(255,255,255,.82); font:400 clamp(.92rem,1.15vw,1.08rem)/1.58 var(--font-inter); }
  @keyframes film-signal { from { transform:scaleX(0); opacity:0; } to { transform:scaleX(1); opacity:1; } }
  @media (max-width: 1100px) and (min-width: 701px) {
    .film-note { right:1.5rem; width:min(19rem,29vw); }
    .film-note p { font-size:.88rem; line-height:1.48; }
  }
  @media (max-width: 700px) {
    .film-note {
      left:1rem;
      right:1rem;
      top:auto;
      bottom:4.6rem;
      width:auto;
      padding:1rem;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(3,4,5,.9);
      transform:translate3d(0,1rem,0);
    }
    :global(body.is-inside.has-film-note) .film-note { transform:translate3d(0,0,0); }
    .film-note__tools { font-size:.52rem; letter-spacing:.12em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .film-note__line { margin:.55rem 0; }
    .film-note__line b { width:2rem; }
    .film-note p { display:-webkit-box; overflow:hidden; font-size:.82rem; line-height:1.42; -webkit-box-orient:vertical; -webkit-line-clamp:3; }
  }

  .bracket {
    width: 18px;
    height: 18px;
    opacity: 0.4;
  }
  .bracket.tl { top: 5.5rem; left: 1.1rem; border-top: 1px solid var(--color-text); border-left: 1px solid var(--color-text); }
  .bracket.tr { top: 5.5rem; right: 1.1rem; border-top: 1px solid var(--color-text); border-right: 1px solid var(--color-text); }
  .bracket.bl { bottom: 1.1rem; left: 1.1rem; border-bottom: 1px solid var(--color-text); border-left: 1px solid var(--color-text); }
  .bracket.br { bottom: 1.1rem; right: 1.1rem; border-bottom: 1px solid var(--color-text); border-right: 1px solid var(--color-text); }

  /* ── Preloader ─────────────────────────────────────────────────────────── */
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--color-bg);
    display: none;
    align-items: flex-end;
    padding: var(--container-offset);
  }
  .pre-inner { width: 100%; }
  .pre-tag {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 5vw, 2.6rem);
    letter-spacing: -0.01em;
  }
  .pre-tag .dot { color: var(--color-accent); }
  .pre-row {
    display: flex;
    justify-content: space-between;
    margin: 1.75rem 0 0.8rem;
    color: var(--color-text-alt);
  }
  .pre-bar { width: 100%; height: 1px; background: var(--color-line); overflow: hidden; }
  .pre-bar span { display: block; height: 100%; width: 0%; background: var(--color-accent); }

  @media (max-width: 640px) {
    .mono { font-size: 0.62rem; letter-spacing: 0.17em; }
    .hud-tl { top: 6.2rem; }
    .panel {
      right: var(--container-offset);
      bottom: 4.8rem;
      max-width: none;
      gap: 0.5rem;
    }
    .panel-title {
      max-width: 82vw;
      font-size: clamp(1.8rem, 9vw, 2.5rem);
      line-height: 0.96;
    }
    .panel-row { gap: 0.7rem; }
    .enter { padding: 0.45rem 0.65rem; }
    .sector-nav {
      left: var(--container-offset);
      right: var(--container-offset);
      bottom: 0.65rem;
      justify-content: space-between;
      gap: 0;
      padding-top: 0.55rem;
      border-top: 1px solid rgba(var(--rgb-text), 0.14);
      background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.72));
    }
    .sector-nav button {
      display: block;
      min-width: 1.7rem;
      padding: 0.3rem 0.18rem;
      font-size: 0.5rem;
      text-align: center;
    }
    .sector-nav button span { display: none; }
    .scrollhint { display: none; }
    .hud-depth { right: 1rem; gap: 0.55rem; }
    .depth-bar { height: 24vh; }
    .bracket.bl,
    .bracket.br { bottom: 3.55rem; }
  }
</style>

<script>
  import * as THREE from "three";
  import gsap from "gsap";
  import { works } from "../data/works";

  const FRAME_W = 4.6;
  const FRAME_H = 6.6;
  const HOLE_W = 3.7;
  const HOLE_H = 5.7;
  const GAP = 19; // Z distance between portals
  const START_Z = -18;

  const CHARS = "ABCDEFGHJKLMNPQRSTUVWXYZ0123456789/#*<>·";

  // fullscreen composite (post) shaders
  const compVert = /* glsl */ `
    varying vec2 vUv;
    void main(){ vUv = uv; gl_Position = vec4(position.xy, 0.0, 1.0); }
  `;
  const compFrag = /* glsl */ `
    precision highp float;
    uniform sampler2D uScene;
    uniform vec2 uRes;
    uniform float uTime;
    uniform float uWipe;   // 0..1 scene transition
    varying vec2 vUv;
    float hash(vec2 p){ p=fract(p*vec2(123.34,456.21)); p+=dot(p,p+45.32); return fract(p.x*p.y); }
    void main(){
      vec2 uv = vUv;
      vec2 d = uv - 0.5;
      float r2 = dot(d, d);
      uv = 0.5 + d * (1.0 - uWipe * 0.12);
      // very subtle edge chromatic aberration (no glitch fringing)
      float ca = (0.0009 + uWipe * 0.012) * r2;
      vec3 col;
      col.r = texture2D(uScene, uv + d * ca).r;
      col.g = texture2D(uScene, uv).g;
      col.b = texture2D(uScene, uv - d * ca).b;
      // fine grain
      col += (hash(uv * uRes + uTime) - 0.5) * 0.022;
      // gentle vignette
      col *= smoothstep(1.35, 0.35, r2 * 2.0);
      float wipe = smoothstep(0.0, 1.0, uWipe);
      float ring = exp(-abs(length(d) - mix(0.58, 0.08, wipe)) * 22.0);
      col += ring * vec3(0.18, 0.2, 0.23) * wipe;
      col = mix(col, vec3(0.003, 0.004, 0.006), wipe * 0.78);
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  // onyx-glass frame (chrome fresnel rim)
  const frameVert = /* glsl */ `
    varying vec3 vN; varying vec3 vV;
    void main(){
      vec4 wp = modelMatrix * vec4(position, 1.0);
      vN = normalize(mat3(modelMatrix) * normal);
      vV = normalize(cameraPosition - wp.xyz);
      gl_Position = projectionMatrix * viewMatrix * wp;
    }
  `;
  const frameFrag = /* glsl */ `
    precision highp float;
    uniform float uActive;
    varying vec3 vN; varying vec3 vV;
    void main(){
      vec3 n = normalize(vN); vec3 v = normalize(vV);
      float fres = pow(1.0 - max(dot(n, v), 0.0), 2.6);
      float metal = pow(0.5 + 0.5 * n.y, 2.0);              // vertical polish
      vec3 chrome = mix(vec3(0.02, 0.02, 0.028), vec3(0.62, 0.65, 0.72), metal);
      vec3 col = chrome + fres * vec3(0.9) * (0.35 + uActive * 0.4);
      col = clamp(col, 0.0, 1.0);                            // no blown-out strips
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  // project seen THROUGH the glass (refraction/distortion), clarifies when active
  const glassVert = /* glsl */ `
    varying vec2 vUv; varying vec3 vN; varying vec3 vV;
    void main(){
      vec4 wp = modelMatrix * vec4(position, 1.0);
      vUv = uv;
      vN = normalize(mat3(modelMatrix) * normal);
      vV = normalize(cameraPosition - wp.xyz);
      gl_Position = projectionMatrix * viewMatrix * wp;
    }
  `;
  const glassFrag = /* glsl */ `
    precision highp float;
    uniform sampler2D uTex;
    uniform float uTime; uniform float uActive; uniform float uReveal; uniform float uImgAspect;
    varying vec2 vUv; varying vec3 vN; varying vec3 vV;
    #define BOX 0.777
    vec2 cover(vec2 uv){
      float boxA = BOX;
      vec2 s = boxA > uImgAspect ? vec2(1.0, uImgAspect/boxA) : vec2(boxA/uImgAspect, 1.0);
      return (uv - 0.5) * s + 0.5;
    }
    void main(){
      float dist = 1.0 - uActive;          // idle = heavy glass distortion
      float t = uTime * 0.25;
      vec2 warp = vec2(sin(vUv.y*9.0+t), cos(vUv.x*9.0+t)) * 0.012 * dist;
      warp += vec2(sin(vUv.y*23.0-t*1.7), cos(vUv.x*23.0+t*1.3)) * 0.005 * dist;
      vec2 uv = cover(vUv + warp);
      float ca = 0.004 * dist;
      vec3 col;
      col.r = texture2D(uTex, uv + ca).r;
      col.g = texture2D(uTex, uv).g;
      col.b = texture2D(uTex, uv - ca).b;
      // dim + desaturate when idle, clarify when active
      float lum = dot(col, vec3(0.299,0.587,0.114));
      col = mix(vec3(lum), col, mix(0.35, 1.0, uActive));
      col *= mix(0.52, 1.0, uActive);
      float fres = pow(1.0 - max(dot(normalize(vN), normalize(vV)), 0.0), 3.0);
      col += fres * 0.35;
      gl_FragColor = vec4(col, uReveal);
    }
  `;

  type Portal = {
    group: THREE.Group;
    glass: THREE.ShaderMaterial;
    frame: THREE.ShaderMaterial;
    z: number;
    activeTarget: number;
    work: (typeof works)[number];
    video?: HTMLVideoElement;
    videoTexture?: THREE.VideoTexture;
    videoLoading?: boolean;
    poster?: THREE.Texture;
    home?: { pos: THREE.Vector3; rot: THREE.Euler };
  };

  class Space extends HTMLElement {
    private stage!: HTMLElement;
    private renderer!: THREE.WebGLRenderer;
    private scene!: THREE.Scene;
    private camera!: THREE.PerspectiveCamera;
    private rt!: THREE.WebGLRenderTarget;
    private compScene!: THREE.Scene;
    private compCam!: THREE.Camera;
    private comp!: THREE.ShaderMaterial;
    private dust!: THREE.Points;
    private portals: Portal[] = [];
    private raycaster = new THREE.Raycaster();
    private pointer = new THREE.Vector2(-2, -2);
    private tMouse = new THREE.Vector2();
    private cMouse = new THREE.Vector2();
    private laneTarget = new THREE.Vector2();
    private laneCurrent = new THREE.Vector2();
    private dragging = false;
    private dragX = 0;
    private dragY = 0;
    private dragDistance = 0;
    private dragPointerType = "";

    private progress = 0;
    private targetProgress = 0;
    private endZ = 0;
    private active = -1;
    private inside = false;
    private busy = false;
    private paused = false;
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private lastFrame = -Infinity;
    private _v = new THREE.Vector3();
    private caseDeparture?: {
      position: THREE.Vector3;
      progress: number;
      targetProgress: number;
      active: number;
    };

    private tickFn = (t: number) => this.render(t);

    connectedCallback() {
      this.stage = document.querySelector("[data-space-stage]")!;
      this.scene = new THREE.Scene();
      this.scene.fog = new THREE.FogExp2(0x050505, 0.028);

      this.camera = new THREE.PerspectiveCamera(62, innerWidth / innerHeight, 0.1, 400);
      this.camera.position.set(0, 0, 4);

      this.renderer = new THREE.WebGLRenderer({
        antialias: !this.lowPower,
        alpha: false,
        powerPreference: "high-performance",
      });
      this.renderer.setClearColor(0x050505, 1);
      this.renderer.domElement.className = "rb-space-canvas";
      this.stage.appendChild(this.renderer.domElement);

      this.rt = new THREE.WebGLRenderTarget(1, 1);
      this.compScene = new THREE.Scene();
      this.compCam = new THREE.Camera();
      this.comp = new THREE.ShaderMaterial({
        vertexShader: compVert,
        fragmentShader: compFrag,
        uniforms: {
          uScene: { value: this.rt.texture },
          uRes: { value: new THREE.Vector2(1, 1) },
          uTime: { value: 0 },
          uWipe: { value: 0 },
        },
      });
      this.compScene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), this.comp));

      this.buildDust();
      this.buildPortals();
      this.endZ = START_Z - (works.length - 1) * GAP - 10;

      const savedOrigin = sessionStorage.getItem("rb-case-origin");
      const savedSector = Number(sessionStorage.getItem("rb-case-sector"));
      if (savedOrigin && new URL(savedOrigin, location.href).pathname === location.pathname && this.portals[savedSector]) {
        const cameraStopZ = this.portals[savedSector].z + 10;
        this.progress = this.targetProgress = THREE.MathUtils.clamp((cameraStopZ - 4) / this.endZ, 0, 1);
        this.camera.position.z = cameraStopZ;
      }

      this.resize();
      this.bind();
      this.load();
    }

    disconnectedCallback() {
      gsap.ticker.remove(this.tickFn);
      gsap.killTweensOf(this.camera.position);
      removeEventListener("resize", this.onResize);
      removeEventListener("pointermove", this.onMove);
      removeEventListener("pointerdown", this.onDown);
      removeEventListener("wheel", this.onWheel as EventListener);
      removeEventListener("keydown", this.onKey);
      removeEventListener("pointerup", this.onUp);
      removeEventListener("pointercancel", this.onCancel);
      removeEventListener("pageshow", this.onPageShow);
      document.removeEventListener("visibilitychange", this.onVis);
      document.querySelector("[data-exit]")?.removeEventListener("click", this.exit);
      this.rt.dispose();
      this.dust.geometry.dispose();
      (this.dust.material as THREE.Material).dispose();
      this.portals.forEach((p) => {
        p.group.traverse((o) => {
          const m = o as THREE.Mesh;
          m.geometry?.dispose?.();
        });
        p.poster?.dispose();
        p.videoTexture?.dispose();
        p.glass.dispose();
        p.frame.dispose();
        if (p.video) { p.video.pause(); p.video.removeAttribute("src"); p.video.load(); }
      });
      this.renderer.dispose();
      this.renderer.domElement.remove();
    }

    private buildDust() {
      const N = this.lowPower ? 850 : 1400;
      const pos = new Float32Array(N * 3);
      for (let i = 0; i < N; i++) {
        pos[i * 3] = (Math.random() - 0.5) * 40;
        pos[i * 3 + 1] = (Math.random() - 0.5) * 40;
        pos[i * 3 + 2] = -Math.random() * 140 + 10;
      }
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.BufferAttribute(pos, 3));
      const m = new THREE.PointsMaterial({
        color: 0x9aa0aa,
        size: 0.03,
        sizeAttenuation: true,
        transparent: true,
        opacity: 0.5,
        depthWrite: false,
      });
      this.dust = new THREE.Points(g, m);
      this.scene.add(this.dust);
    }

    private buildPortals() {
      // rectangular frame = outer shape with a rectangular hole, extruded
      const shape = new THREE.Shape();
      shape.moveTo(-FRAME_W / 2, -FRAME_H / 2);
      shape.lineTo(FRAME_W / 2, -FRAME_H / 2);
      shape.lineTo(FRAME_W / 2, FRAME_H / 2);
      shape.lineTo(-FRAME_W / 2, FRAME_H / 2);
      shape.lineTo(-FRAME_W / 2, -FRAME_H / 2);
      const hole = new THREE.Path();
      hole.moveTo(-HOLE_W / 2, -HOLE_H / 2);
      hole.lineTo(HOLE_W / 2, -HOLE_H / 2);
      hole.lineTo(HOLE_W / 2, HOLE_H / 2);
      hole.lineTo(-HOLE_W / 2, HOLE_H / 2);
      hole.lineTo(-HOLE_W / 2, -HOLE_H / 2);
      shape.holes.push(hole);
      const frameGeo = new THREE.ExtrudeGeometry(shape, {
        depth: 0.5,
        bevelEnabled: true,
        bevelThickness: 0.06,
        bevelSize: 0.06,
        bevelSegments: this.lowPower ? 1 : 2,
      });
      frameGeo.center();
      const glassGeo = new THREE.PlaneGeometry(HOLE_W, HOLE_H, 1, 1);
      const edgeGeo = new THREE.EdgesGeometry(new THREE.BoxGeometry(FRAME_W + 0.14, FRAME_H + 0.14, 0.62));
      const glowGeo = new THREE.PlaneGeometry(HOLE_W + 0.34, HOLE_H + 0.34);

      works.forEach((work, i) => {
        const z = START_Z - i * GAP;
        const group = new THREE.Group();
        group.position.set(
          Math.sin(i * 1.4) * 3.2,
          Math.cos(i * 0.8) * 1.7,
          z,
        );
        group.rotation.y = Math.sin(i * 0.7) * 0.14;

        const frameMat = new THREE.ShaderMaterial({
          vertexShader: frameVert,
          fragmentShader: frameFrag,
          uniforms: { uActive: { value: 0 } },
        });
        const frameMesh = new THREE.Mesh(frameGeo, frameMat);
        const edgeMat = new THREE.LineBasicMaterial({
          color: 0xe8edf0,
          transparent: true,
          opacity: 0.28,
          blending: THREE.AdditiveBlending,
        });
        const outerEdge = new THREE.LineSegments(edgeGeo, edgeMat);
        const glow = new THREE.Mesh(
          glowGeo,
          new THREE.MeshBasicMaterial({ color: 0xbcc7cc, transparent: true, opacity: 0.055, depthWrite: false }),
        );
        glow.position.z = -0.08;

        const glassMat = new THREE.ShaderMaterial({
          vertexShader: glassVert,
          fragmentShader: glassFrag,
          transparent: true,
          uniforms: {
            uTex: { value: null },
            uTime: { value: 0 },
            uActive: { value: 0 },
            uReveal: { value: 0 },
            uImgAspect: { value: HOLE_W / HOLE_H },
          },
        });
        const glassMesh = new THREE.Mesh(glassGeo, glassMat);
        glassMesh.position.z = 0.05;
        glassMesh.userData.portal = i;

        group.add(glow, frameMesh, outerEdge, glassMesh);
        this.scene.add(group);
        this.portals.push({ group, glass: glassMat, frame: frameMat, z, activeTarget: 0, work });
      });
    }

    private load() {
      gsap.ticker.add(this.tickFn);
      const loader = new THREE.TextureLoader();
      const bar = document.querySelector<HTMLElement>("[data-bar]");
      const pct = document.querySelector<HTMLElement>("[data-pct]");
      const pre = document.querySelector<HTMLElement>("[data-preloader]");

      let done = false;
      const reveal = () => {
        if (done) return;
        done = true;
        this.portals.forEach((p, i) => {
          const img = (p.glass.uniforms.uTex.value as THREE.Texture)?.image as HTMLImageElement;
          if (img?.width) p.glass.uniforms.uImgAspect.value = img.width / img.height;
          gsap.to(p.glass.uniforms.uReveal, { value: 1, duration: 1, delay: 0.4 + i * 0.05 });
        });
        if (pre) {
          gsap.to(pre, { autoAlpha: 0, duration: 1, ease: "power2.inOut", delay: 0.3,
            onComplete: () => (pre.style.display = "none") });
          setTimeout(() => { pre.style.opacity = "0"; pre.style.display = "none"; }, 3400);
        }
      };
      setTimeout(reveal, 8000);

      const configure = (tex: THREE.Texture) => {
        tex.colorSpace = THREE.SRGBColorSpace;
        tex.minFilter = THREE.LinearMipmapLinearFilter;
        tex.magFilter = THREE.LinearFilter;
        tex.generateMipmaps = true;
        tex.anisotropy = Math.min(4, this.renderer.capabilities.getMaxAnisotropy());
        return tex;
      };

      const loaded = this.portals.map(async (p, index) => {
        try {
          const poster = configure(await loader.loadAsync(p.work.img));
          p.poster = poster;
          if (!p.videoTexture) p.glass.uniforms.uTex.value = poster;
          const image = poster.image as HTMLImageElement;
          if (!p.videoTexture && image?.width) p.glass.uniforms.uImgAspect.value = image.width / image.height;
          gsap.to(p.glass.uniforms.uReveal, { value: 1, duration: .7, delay: index * .04 });

          if (p.work.video && (index === this.active || !this.lowPower)) this.ensureVideo(index);
        } catch {
          p.glass.uniforms.uReveal.value = 1;
        } finally {
          const progress = Math.round(((index + 1) / this.portals.length) * 100);
          if (pct) pct.textContent = String(progress);
          if (bar) bar.style.width = `${progress}%`;
        }
      });

      Promise.allSettled(loaded).then(reveal);
    }

    private bind() {
      addEventListener("resize", this.onResize);
      addEventListener("pointermove", this.onMove, { passive: true });
      addEventListener("pointerdown", this.onDown);
      addEventListener("wheel", this.onWheel as EventListener, { passive: true });
      addEventListener("keydown", this.onKey);
      addEventListener("pointerup", this.onUp);
      addEventListener("pointercancel", this.onCancel);
      addEventListener("pageshow", this.onPageShow);
      document.addEventListener("visibilitychange", this.onVis);
      document.querySelector("[data-exit]")?.addEventListener("click", this.exit);
      document.querySelector("[data-enter]")?.addEventListener("click", () => {
        if (this.active >= 0) this.enter(this.active);
      });
      document.querySelectorAll<HTMLElement>("[data-sector-jump]").forEach((button) => {
        button.addEventListener("click", () => {
          const index = Number(button.dataset.sectorJump || 0);
          const portal = this.portals[index];
          if (!portal) return;
          const cameraStopZ = portal.z + 10;
          this.targetProgress = THREE.MathUtils.clamp((cameraStopZ - 4) / this.endZ, 0, 1);
        });
      });
    }

    private onVis = () => (this.paused = document.hidden);
    private onPageShow = (event: PageTransitionEvent) => {
      if (!event.persisted || !this.caseDeparture) return;
      gsap.killTweensOf(this.camera.position);
      gsap.killTweensOf(this.comp.uniforms.uWipe);
      this.portals.forEach((portal) => {
        gsap.killTweensOf(portal.glass.uniforms.uActive);
        portal.group.visible = true;
      });
      this.camera.position.copy(this.caseDeparture.position);
      this.progress = this.caseDeparture.progress;
      this.targetProgress = this.caseDeparture.targetProgress;
      this.active = this.caseDeparture.active;
      this.comp.uniforms.uWipe.value = 0;
      this.busy = false;
      this.inside = false;
      this.dragging = false;
      document.body.classList.remove("is-inside", "is-space-dragging");
    };
    private onResize = () => this.resize();
    private onMove = (e: PointerEvent) => {
      this.pointer.set((e.clientX / innerWidth) * 2 - 1, -((e.clientY / innerHeight) * 2 - 1));
      this.tMouse.set(this.pointer.x, this.pointer.y);
      if (this.dragging && !this.inside && !this.busy) {
        const dx = e.clientX - this.dragX;
        const dy = e.clientY - this.dragY;
        this.dragX = e.clientX;
        this.dragY = e.clientY;
        this.dragDistance += Math.abs(dx) + Math.abs(dy);
        const depthGesture = this.lowPower || this.dragPointerType === "touch" || this.dragPointerType === "pen";
        if (depthGesture) {
          this.targetProgress = THREE.MathUtils.clamp(this.targetProgress - dy * 0.00085, 0, 1);
          this.laneTarget.x = THREE.MathUtils.clamp(this.laneTarget.x - dx * 0.0065, -3.4, 3.4);
        } else {
          this.laneTarget.x = THREE.MathUtils.clamp(this.laneTarget.x - dx * 0.012, -4.8, 4.8);
          this.laneTarget.y = THREE.MathUtils.clamp(this.laneTarget.y + dy * 0.01, -3.2, 3.2);
        }
      }
    };
    private onDown = (e: PointerEvent) => {
      const target = e.target instanceof Element ? e.target : null;
      if (this.inside || this.busy || target?.closest("header, [data-hud], [data-tunnel-root]")) return;
      this.dragging = true;
      this.dragX = e.clientX;
      this.dragY = e.clientY;
      this.dragDistance = 0;
      this.dragPointerType = e.pointerType;
      document.body.classList.add("is-space-dragging");
    };
    private onWheel = (e: WheelEvent) => {
      if (this.inside || this.busy) return;
      this.targetProgress = Math.min(1, Math.max(0, this.targetProgress + e.deltaY * 0.00035));
    };
    private onKey = (e: KeyboardEvent) => {
      if (e.key === "Escape" && this.inside) this.exit();
      if (this.inside || this.busy) return;
      const key = e.key.toLowerCase();
      if (key === "arrowdown") this.targetProgress = Math.min(1, this.targetProgress + 0.12);
      if (key === "arrowup") this.targetProgress = Math.max(0, this.targetProgress - 0.12);
      if (["a", "arrowleft"].includes(key)) this.laneTarget.x = Math.max(-4.8, this.laneTarget.x - 0.8);
      if (["d", "arrowright"].includes(key)) this.laneTarget.x = Math.min(4.8, this.laneTarget.x + 0.8);
      if (key === "w") this.laneTarget.y = Math.min(3.2, this.laneTarget.y + 0.65);
      if (key === "s") this.laneTarget.y = Math.max(-3.2, this.laneTarget.y - 0.65);
    };
    private onUp = (e: PointerEvent) => {
      if (this.inside || this.busy) return;
      const wasDragging = this.dragging && this.dragDistance > 10;
      this.dragging = false;
      this.dragPointerType = "";
      document.body.classList.remove("is-space-dragging");
      if (wasDragging) return;
      // ignore clicks on the chrome (header, HUD, tunnel) — only the 3D counts
      if ((e.target as HTMLElement)?.closest("header, [data-hud], [data-tunnel-root]")) return;
      this.raycaster.setFromCamera(this.pointer, this.camera);
      const hit = this.raycaster.intersectObjects(this.portals.map((p) => p.group), true)[0];
      const idx = hit?.object.userData.portal;
      if (typeof idx === "number") this.enter(idx);
    };
    private onCancel = () => {
      this.dragging = false;
      this.dragPointerType = "";
      document.body.classList.remove("is-space-dragging");
    };

    // ── camera fly-THROUGH + GLSL transition + project world ────────────────
    private enter(i: number) {
      if (this.busy || this.inside) return;
      this.busy = true;
      const p = this.portals[i];
      p.home = { pos: p.group.position.clone(), rot: p.group.rotation.clone() };

      if (p.work.type === "case") {
        const title = p.work.id === "bridge" ? "Bridge Consult" : "FIDIC.uz";
        this.caseDeparture = {
          position: this.camera.position.clone(),
          progress: this.progress,
          targetProgress: this.targetProgress,
          active: i,
        };
        const transition = (window as any).__rbCaseTransition as undefined | ((options: any) => void);
        if (transition) {
          transition({
            href: p.work.href,
            kind: p.work.id === "fidic" ? "fidic" : "bridge",
            title,
            sector: i,
          });
        } else {
          sessionStorage.setItem("rb-case-origin", location.href);
          sessionStorage.setItem("rb-case-sector", String(i));
          sessionStorage.setItem("rb-case-arrive", p.work.id === "fidic" ? "fidic" : "bridge");
          location.assign(p.work.href);
        }
        return;
      }

      const tl = gsap.timeline({
        onComplete: () => {
          this.busy = false;
          this.inside = true;
          document.body.classList.add("is-inside");
          document.body.classList.toggle("has-film-note", Boolean(p.work.video && p.work.detail));
        },
      });
      // dip to black while the camera surges through the gate
      tl.to(this.comp.uniforms.uWipe, { value: 0.88, duration: 0.72, ease: "power2.inOut" }, 0);
      tl.to(this.camera.position, {
        x: p.group.position.x,
        y: p.group.position.y,
        z: p.z - 4.5,
        duration: 0.7,
        ease: "power3.in",
      }, 0);
      // at the black peak → teleport into the project "world"
      tl.add(() => {
        this.active = i;
        (this.scene.fog as THREE.FogExp2).density = 0.05;
        this.portals.forEach((q, j) => (q.group.visible = j === i));
        // bring the project centre-stage, clear + undistorted
        p.group.position.set(0, 0, 0);
        p.group.rotation.set(0, 0, 0);
        p.glass.uniforms.uActive.value = 1;
        this.camera.position.set(0, 0, 7);
        this.camera.lookAt(0, 0, 0);
      }, 0.74);
      tl.to(this.comp.uniforms.uWipe, { value: 0, duration: 1.05, ease: "power3.out" }, 0.76);
    }

    private exit = () => {
      if (this.busy || !this.inside) return;
      this.busy = true;
      document.body.classList.remove("has-film-note");
      const p = this.portals[this.active];
      const tl = gsap.timeline({
        onComplete: () => {
          this.busy = false;
          this.inside = false;
          document.body.classList.remove("is-inside");
        },
      });
      tl.to(this.comp.uniforms.uWipe, { value: 0.78, duration: 0.68, ease: "power2.inOut" }, 0);
      tl.add(() => {
        (this.scene.fog as THREE.FogExp2).density = 0.028;
        this.portals.forEach((q) => (q.group.visible = true));
        if (p.home) {
          p.group.position.copy(p.home.pos);
          p.group.rotation.copy(p.home.rot);
        }
        p.glass.uniforms.uActive.value = 0;
        // rejoin the corridor just in front of this portal
        this.camera.position.set(p.group.position.x, p.group.position.y, p.z + 9);
      }, 0.66);
      tl.to(this.comp.uniforms.uWipe, { value: 0, duration: 0.95, ease: "power3.out" }, 0.68);
    };

    // ── HUD ─────────────────────────────────────────────────────────────────
    private setActive(i: number) {
      if (i === this.active || i < 0) return;
      this.active = i;
      const w = this.portals[i].work;
      if (w.video) this.ensureVideo(i);
      this.portals.forEach((portal, index) => {
        if (!portal.video) return;
        if (index === i) portal.video.play().catch(() => {});
        else portal.video.pause();
      });
      const activeLang = (document.documentElement.lang || "en").split("-")[0];
      const dict = (window as any).__I18N__?.[activeLang] ?? {};
      const title = w.title ?? dict[w.kTitle ?? ""] ?? "";
      const cat = dict[w.kCat] ?? "";
      const yr = w.kText ? "CASE" : "REEL";
      this.decode(document.querySelector("[data-panel-title]"), title);
      this.decode(document.querySelector("[data-panel-cat]"), cat);
      this.decode(document.querySelector("[data-panel-meta]"), `${yr} · SECTOR ${String(i + 1).padStart(2, "0")}`);
      const tools = document.querySelector<HTMLElement>("[data-film-tools]");
      const copy = document.querySelector<HTMLElement>("[data-film-copy]");
      if (tools) tools.textContent = w.detail?.tools ?? "";
      if (copy) copy.textContent = w.detail?.[activeLang === "de" ? "de" : "en"] ?? "";
      const idxEl = document.querySelector("[data-marker-idx]");
      if (idxEl) idxEl.textContent = String(i + 1).padStart(2, "0");
      const sec = document.querySelector("[data-hud-sector]");
      if (sec) sec.textContent = `SECTOR ${String(i + 1).padStart(2, "0")} / ${String(works.length).padStart(2, "0")}`;
      document.querySelectorAll<HTMLElement>("[data-sector-jump]").forEach((button) => {
        button.classList.toggle("is-active", Number(button.dataset.sectorJump) === i);
      });
    }

    private ensureVideo(index: number) {
      const portal = this.portals[index];
      if (!portal?.work.video || portal.video || portal.videoLoading) return;
      portal.videoLoading = true;
      const video = document.createElement("video");
      video.src = portal.work.video;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.preload = this.lowPower ? "metadata" : "auto";
      portal.video = video;
      video.addEventListener("canplay", () => {
        portal.videoLoading = false;
        const texture = new THREE.VideoTexture(video);
        texture.colorSpace = THREE.SRGBColorSpace;
        texture.minFilter = THREE.LinearFilter;
        texture.magFilter = THREE.LinearFilter;
        portal.videoTexture = texture;
        portal.glass.uniforms.uTex.value = texture;
        if (video.videoWidth) portal.glass.uniforms.uImgAspect.value = video.videoWidth / video.videoHeight;
        if (this.active === index) video.play().catch(() => {});
      }, { once: true });
      video.addEventListener("error", () => {
        portal.videoLoading = false;
        portal.video = undefined;
      }, { once: true });
      video.load();
    }

    private decode(el: Element | null, final: string) {
      if (!el) return;
      const start = performance.now();
      const dur = 620;
      const step = (now: number) => {
        const t = Math.min((now - start) / dur, 1);
        const reveal = Math.floor(t * final.length);
        let out = "";
        for (let k = 0; k < final.length; k++) {
          out += k < reveal || final[k] === " " ? final[k] : CHARS[(Math.random() * CHARS.length) | 0];
        }
        el.textContent = out;
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = final;
      };
      requestAnimationFrame(step);
    }

    // ── loop ────────────────────────────────────────────────────────────────
    private render(t: number) {
      if (this.paused) return;
      if (this.lowPower && t - this.lastFrame < 1 / 30) return;
      this.lastFrame = t;
      this.comp.uniforms.uTime.value = t;

      // ease scroll → camera Z fly-through
      if (!this.inside && !this.busy) {
        this.progress += (this.targetProgress - this.progress) * 0.06;
        const targetZ = 4 + this.progress * this.endZ;
        this.camera.position.z += (targetZ - this.camera.position.z) * 0.1;
      }

      // inertial look
      this.cMouse.x += (this.tMouse.x - this.cMouse.x) * 0.04;
      this.cMouse.y += (this.tMouse.y - this.cMouse.y) * 0.04;
      this.laneCurrent.lerp(this.laneTarget, 0.065);
      if (!this.inside && !this.busy) {
        const targetX = this.laneCurrent.x + this.cMouse.x * 0.65;
        const targetY = this.laneCurrent.y + this.cMouse.y * 0.45;
        this.camera.position.x += (targetX - this.camera.position.x) * 0.065;
        this.camera.position.y += (targetY - this.camera.position.y) * 0.065;
        this.camera.lookAt(this.laneCurrent.x * 0.35 + this.cMouse.x * 0.25, this.laneCurrent.y * 0.3 + this.cMouse.y * 0.2, this.camera.position.z - 10);
      }

      // inside a project world → slow luxurious orbit of the piece
      if (this.inside && !this.busy && this.active >= 0) {
        const g = this.portals[this.active].group;
        g.rotation.y += (this.cMouse.x * 0.35 - g.rotation.y) * 0.05;
        g.rotation.x += (-this.cMouse.y * 0.2 - g.rotation.x) * 0.05;
        this.camera.position.x += (this.cMouse.x * 0.7 - this.camera.position.x) * 0.05;
        this.camera.position.y += (this.cMouse.y * 0.45 - this.camera.position.y) * 0.05;
        this.camera.lookAt(0, 0, 0);
      }

      // active portal = nearest ahead
      let best = -1, bestD = 1e9;
      this.portals.forEach((p, i) => {
        const d = this.camera.position.z - p.z;
        if (d >= -0.5 && d < bestD) { bestD = d; best = i; }
        // idle micro-motion + activation ease
        p.group.rotation.z = Math.sin(t * 0.0003 + i) * 0.03;
        p.glass.uniforms.uTime.value = t;
      });
      if (!this.inside && !this.busy) this.setActive(best);

      this.portals.forEach((p, i) => {
        const target = this.inside ? (i === this.active ? 1 : 0) : (i === best ? 1 : 0);
        // only auto-drive activation when not mid-enter (enter tween owns it)
        if (!this.busy) {
          p.glass.uniforms.uActive.value += (target - p.glass.uniforms.uActive.value) * 0.06;
        }
        p.frame.uniforms.uActive.value = p.glass.uniforms.uActive.value;
      });

      // depth HUD
      const depthBar = document.querySelector<HTMLElement>("[data-depth-bar]");
      const depthVal = document.querySelector<HTMLElement>("[data-depth-val]");
      if (depthBar) depthBar.style.height = `${Math.min(100, this.progress * 100)}%`;
      if (depthVal) depthVal.textContent = `Z ${Math.abs(this.camera.position.z).toFixed(1).padStart(5, "0")}`;

      // anchor the marker to the active portal (project 3D → screen)
      const marker = document.querySelector<HTMLElement>("[data-marker]");
      if (marker && best >= 0 && !this.inside) {
        this._v.copy(this.portals[best].group.position).project(this.camera);
        const on = this._v.z < 1;
        marker.style.opacity = on ? "1" : "0";
        if (on) {
          const x = (this._v.x * 0.5 + 0.5) * innerWidth;
          const y = (-this._v.y * 0.5 + 0.5) * innerHeight;
          marker.style.transform = `translate(${x}px, ${y}px)`;
        }
      }

      // scroll hint fades once you move
      const hint = document.querySelector<HTMLElement>("[data-scrollhint]");
      if (hint) hint.style.opacity = this.progress > 0.02 ? "0" : "";

      this.renderer.setRenderTarget(this.rt);
      this.renderer.render(this.scene, this.camera);
      this.renderer.setRenderTarget(null);
      this.renderer.render(this.compScene, this.compCam);
    }

    private resize() {
      const w = innerWidth, h = innerHeight;
      this.camera.aspect = w / h;
      this.camera.updateProjectionMatrix();
      const dpr = this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.35);
      const targetScale = this.lowPower ? .84 : 1;
      this.renderer.setPixelRatio(dpr);
      this.renderer.setSize(w, h, true);
      this.rt.setSize(Math.round(w * dpr * targetScale), Math.round(h * dpr * targetScale));
      this.comp.uniforms.uRes.value.set(w * dpr * targetScale, h * dpr * targetScale);
    }
  }

  if (!customElements.get("rb-space")) customElements.define("rb-space", Space);
  if (!document.querySelector("rb-space")) document.body.appendChild(document.createElement("rb-space"));
</script>
