<rb-studio-loader aria-hidden="true">
  <div class="loader-topline">
    <span>RB / DIGITAL STUDIO</span>
    <span>VIENNA / 2026</span>
  </div>

  <div class="loader-stage" data-loader-stage aria-hidden="true">
    <span class="loader-axis axis-x"></span>
    <span class="loader-axis axis-y"></span>
    <span class="loader-grid"></span>
    <span class="loader-node node-a"></span>
    <span class="loader-node node-b"></span>
    <span class="loader-node node-c"></span>
    <span class="loader-node node-d"></span>
    <span class="loader-orbit orbit-a"></span>
    <span class="loader-orbit orbit-b"></span>
    <div class="loader-cube" data-loader-cube>
      <span class="cube-face cube-front"></span>
      <span class="cube-face cube-back"></span>
      <span class="cube-face cube-left"></span>
      <span class="cube-face cube-right"></span>
      <span class="cube-face cube-top"></span>
      <span class="cube-face cube-bottom"></span>
      <i></i>
    </div>
  </div>

  <div class="loader-shell">
    <div class="loader-readout">
      <span data-loader-phase>INITIALISING RENDER</span>
      <span class="loader-count"><strong data-loader-count>000</strong><small>%</small></span>
    </div>
    <div class="loader-line" aria-hidden="true"><span data-loader-line></span></div>
    <div class="loader-meta">
      <span>PASS <b data-loader-pass>01/04</b></span>
      <span>WEBGL <b>READY</b></span>
      <span>COLOR <b>NOIR</b></span>
    </div>
  </div>
</rb-studio-loader>

<style>
  :global(html.rb-loader-seen) rb-studio-loader { display: none; }

  rb-studio-loader {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: clamp(1.2rem, 3vw, 2.5rem);
    background:
      radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.095), transparent 28%),
      radial-gradient(circle at 65% 54%, rgba(255, 255, 255, 0.035), transparent 34%),
      linear-gradient(145deg, #000, #08090a 54%, #010101);
    color: #e8e9e9;
  }

  rb-studio-loader::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent 49.95%, rgba(255, 255, 255, 0.035) 50%, transparent 50.05%),
      linear-gradient(180deg, transparent 49.95%, rgba(255, 255, 255, 0.025) 50%, transparent 50.05%);
  }

  rb-studio-loader::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      conic-gradient(from 0deg at 50% 42%, transparent, rgba(185, 213, 224, 0.045), transparent 18%, transparent 48%, rgba(185, 213, 224, 0.035), transparent 68%),
      radial-gradient(circle at 50% 42%, rgba(196, 222, 232, 0.16), transparent 34%, transparent 68%, rgba(0, 0, 0, 0.64));
  }

  rb-studio-loader.is-hidden { pointer-events: none; }

  .loader-topline,
  .loader-meta,
  [data-loader-phase] {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(0.58rem, 0.85vw, 0.72rem);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .loader-topline {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    color: rgba(232, 233, 233, 0.38);
  }

  .loader-stage {
    position: absolute;
    z-index: 1;
    top: 42%;
    left: 50%;
    width: min(58vw, 36rem);
    aspect-ratio: 1;
    perspective: 900px;
    /* the object grows into place as real assets resolve (--loader-progress) */
    transform: translate(-50%, -50%) scale(calc(0.86 + var(--loader-progress, 0) * 0.14));
  }

  .loader-stage::before {
    content: "RENDER OBJECT / 01";
    position: absolute;
    top: -1.5rem;
    left: 50%;
    color: rgba(232, 233, 233, 0.25);
    font: 400 0.55rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.12em;
    white-space: nowrap;
    transform: translateX(-50%);
  }

  .loader-cube {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8rem;
    height: 8rem;
    transform-style: preserve-3d;
    transform: translate(-50%, -50%) rotateX(-24deg) rotateY(38deg);
    animation: loader-cube 6s linear infinite;
  }

  .cube-face {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 42% 58% 54% 46% / 48% 43% 57% 52%;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.012));
    box-shadow: inset 0 0 2.4rem rgba(255, 255, 255, 0.06), 0 0 1.5rem rgba(255, 255, 255, 0.055);
    backdrop-filter: blur(3px);
  }

  .cube-front { transform: translateZ(4rem); }
  .cube-back { transform: rotateY(180deg) translateZ(4rem); border-color: rgba(255, 255, 255, 0.13); }
  .cube-left { transform: rotateY(-90deg) translateZ(4rem); border-color: rgba(255, 255, 255, 0.18); }
  .cube-right { transform: rotateY(90deg) translateZ(4rem); border-color: rgba(255, 255, 255, 0.1); }
  .cube-top { transform: rotateX(90deg) translateZ(4rem); }
  .cube-bottom { transform: rotateX(-90deg) translateZ(4rem); }

  .loader-cube i {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #ecfeff;
    box-shadow: 0 0 1.8rem rgba(255, 255, 255, 0.86), 0 0 4rem rgba(255, 255, 255, 0.22);
    transform: translate3d(-50%, -50%, 0);
  }

  .loader-orbit,
  .loader-axis {
    position: absolute;
    top: 50%;
    left: 50%;
    pointer-events: none;
  }

  .loader-grid {
    position: absolute;
    left: 50%;
    bottom: -4%;
    width: 92%;
    height: 52%;
    opacity: 0.42;
    background-image:
      linear-gradient(rgba(204, 226, 234, 0.13) 1px, transparent 1px),
      linear-gradient(90deg, rgba(204, 226, 234, 0.13) 1px, transparent 1px);
    background-size: 2.4rem 2.4rem;
    mask-image: linear-gradient(180deg, transparent, #000 24%, transparent 92%);
    transform: translateX(-50%) perspective(520px) rotateX(65deg);
    transform-origin: bottom;
    animation: loader-grid 2.2s linear infinite;
  }

  .loader-node {
    position: absolute;
    width: 0.48rem;
    height: 0.48rem;
    border: 1px solid rgba(229, 241, 245, 0.65);
    border-radius: 50%;
    background: #eef2f3;
    box-shadow: 0 0 1.8rem rgba(255, 255, 255, 0.72);
    /* nodes light up one by one as progress climbs */
    opacity: calc(0.25 + var(--loader-progress, 0) * 0.75);
  }

  .loader-node::after {
    content: "";
    position: absolute;
    inset: -0.7rem;
    border: 1px solid rgba(209, 231, 239, 0.12);
    border-radius: 50%;
    animation: node-pulse 1.8s ease-out infinite;
  }

  .node-a { top: 15%; left: 23%; }
  .node-b { top: 28%; right: 16%; animation-delay: -0.4s; }
  .node-b { background: #c9ced0; box-shadow: 0 0 1.8rem rgba(255, 255, 255, 0.58); }
  .node-c { bottom: 20%; left: 15%; animation-delay: -0.8s; background: #fff; box-shadow: 0 0 1.8rem rgba(255, 255, 255, 0.62); }
  .node-d { right: 24%; bottom: 12%; animation-delay: -1.2s; background: #b9bfc2; box-shadow: 0 0 1.8rem rgba(255, 255, 255, 0.48); }

  .loader-orbit {
    width: 72%;
    aspect-ratio: 1;
    border: 1px solid rgba(216, 232, 237, 0.1);
    border-top-color: rgba(230, 239, 242, 0.44);
    border-radius: 50%;
    filter: drop-shadow(0 0 0.65rem rgba(205, 225, 232, 0.2));
  }

  .orbit-a {
    transform: translate(-50%, -50%) rotateX(67deg) rotateZ(12deg);
    animation: loader-orbit-a 7s linear infinite;
    border-top-color: #f6f8f8;
    border-right-color: rgba(255, 255, 255, 0.18);
  }

  .orbit-b {
    width: 54%;
    transform: translate(-50%, -50%) rotateY(68deg) rotateZ(-18deg);
    animation: loader-orbit-b 5.5s linear infinite reverse;
    border-top-color: #d9dddf;
    border-left-color: rgba(255, 255, 255, 0.16);
  }

  .loader-axis { background: rgba(255, 255, 255, 0.045); }
  .axis-x { width: 100%; height: 1px; transform: translate(-50%, -50%); }
  .axis-y { width: 1px; height: 100%; transform: translate(-50%, -50%); }

  @keyframes loader-cube {
    to { transform: translate(-50%, -50%) rotateX(336deg) rotateY(398deg); }
  }

  @keyframes loader-orbit-a {
    to { transform: translate(-50%, -50%) rotateX(67deg) rotateZ(372deg); }
  }

  @keyframes loader-orbit-b {
    to { transform: translate(-50%, -50%) rotateY(68deg) rotateZ(342deg); }
  }

  @keyframes loader-grid {
    to { background-position: 0 2.4rem, 0 0; }
  }

  @keyframes node-pulse {
    0% { transform: scale(0.5); opacity: 0.8; }
    100% { transform: scale(1.8); opacity: 0; }
  }

  .loader-shell {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .loader-readout {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.1rem;
  }

  [data-loader-phase] { color: rgba(232, 233, 233, 0.55); }

  .loader-count {
    display: inline-flex;
    align-items: start;
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    line-height: 0.75;
  }

  .loader-count strong {
    min-width: 3ch;
    font-size: clamp(4rem, 13vw, 10rem);
    font-weight: 400;
    letter-spacing: 0;
    text-align: right;
    color: transparent;
    background: linear-gradient(135deg, #fff, #d8dddf 52%, #8e9599);
    background-clip: text;
    -webkit-background-clip: text;
    filter: drop-shadow(0 0 1.8rem rgba(255, 255, 255, 0.16));
  }

  .loader-count small {
    margin: 0.1rem 0 0 0.45rem;
    color: rgba(232, 233, 233, 0.4);
    font: 400 0.65rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .loader-line {
    height: 1px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.1);
  }

  .loader-line span {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, #fff, #b8bec1 58%, #f4f6f6);
    box-shadow: 0 0 1.2rem rgba(255, 255, 255, 0.42);
    transform-origin: left;
  }

  .loader-meta {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.9rem;
    color: rgba(232, 233, 233, 0.28);
  }

  .loader-meta b {
    color: rgba(232, 233, 233, 0.62);
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .loader-topline span:last-child,
    .loader-meta span:nth-child(2) { display: none; }
    .loader-meta { grid-template-columns: repeat(2, max-content); }
    .loader-stage { width: 96vw; top: 40%; }
    .loader-stage::after {
      content: "";
      position: absolute;
      inset: 12%;
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 50%;
      box-shadow: 0 0 4rem rgba(255,255,255,.07), inset 0 0 3rem rgba(255,255,255,.035);
      animation: loader-mobile-scan 4.8s ease-in-out infinite;
    }
    .loader-cube { width: 6.6rem; height: 6.6rem; }
    .cube-front { transform: translateZ(3.3rem); }
    .cube-back { transform: rotateY(180deg) translateZ(3.3rem); }
    .cube-left { transform: rotateY(-90deg) translateZ(3.3rem); }
    .cube-right { transform: rotateY(90deg) translateZ(3.3rem); }
    .cube-top { transform: rotateX(90deg) translateZ(3.3rem); }
    .cube-bottom { transform: rotateX(-90deg) translateZ(3.3rem); }
    .loader-count strong { font-size: clamp(5rem, 27vw, 7.2rem); }
    [data-loader-phase] { max-width: 13ch; line-height: 1.45; }
  }

  @keyframes loader-mobile-scan {
    0%, 100% { transform: scale(.82) rotate(0deg); opacity: .22; }
    50% { transform: scale(1.06) rotate(90deg); opacity: .7; }
  }

  /* Touch devices drop backdrop-filter for performance. The glass faces were
     built on that blur, so without compensation the object vanished and the
     loader read as "just a counter". Paint the glass explicitly instead. */
  @media (pointer: coarse) {
    .cube-face {
      backdrop-filter: none;
      border-color: rgba(255, 255, 255, 0.42);
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.17), rgba(255, 255, 255, 0.035));
      box-shadow: inset 0 0 2.2rem rgba(255, 255, 255, 0.12), 0 0 1.4rem rgba(255, 255, 255, 0.1);
    }
    .loader-orbit {
      filter: none;
      border-color: rgba(216, 232, 237, 0.26);
      border-top-color: #ffffff;
    }
    .loader-count strong { filter: none; }
    .loader-grid { opacity: 0.34; animation-duration: 4.4s; }
    .loader-node::after { animation-duration: 3.6s; }
    .loader-node { box-shadow: 0 0 1.2rem rgba(255, 255, 255, 0.8); }
  }

  /* Reduce Motion previously froze the object dead ("the cube just stands
     there"). Reduce it instead of killing it: a slow, steady turn with no
     pulsing or scanning — calm, but alive. */
  @media (prefers-reduced-motion: reduce) {
    .loader-cube { animation-duration: 26s; }
    .orbit-a { animation-duration: 34s; }
    .orbit-b { animation-duration: 30s; }
    .loader-grid,
    .loader-node::after,
    .loader-stage::after { animation: none; }
  }
</style>

<script>
  import gsap from "gsap";

  const phases = [
    "INITIALISING RENDER",
    "TRACING GEOMETRY",
    "RESOLVING TYPOGRAPHY",
    "OPENING CASE ARCHIVE",
  ];

  const GLYPHS = "ABCDEFGHJKLMNPQRSTUVWXYZ0123456789/#*<>·";
  const calm = matchMedia("(prefers-reduced-motion: reduce)").matches;

  /** Scramble → resolve, so each phase decodes into place. */
  function decode(el: HTMLElement, final: string) {
    if (calm) {
      el.textContent = final;
      return;
    }
    const started = performance.now();
    const duration = 520;
    const step = (now: number) => {
      const t = Math.min((now - started) / duration, 1);
      const solid = Math.floor(t * final.length);
      let out = "";
      for (let i = 0; i < final.length; i++) {
        out += i < solid || final[i] === " "
          ? final[i]
          : GLYPHS[(Math.random() * GLYPHS.length) | 0];
      }
      el.textContent = out;
      if (t < 1) requestAnimationFrame(step);
      else el.textContent = final;
    };
    requestAnimationFrame(step);
  }

  class StudioLoader extends HTMLElement {
    connectedCallback() {
      if (sessionStorage.getItem("rb-loader-seen") === "1") {
        document.documentElement.classList.remove("is-preloading");
        document.body.classList.remove("is-preloading");
        document.body.classList.add("is-loaded");
        this.remove();
        queueMicrotask(() => window.dispatchEvent(new CustomEvent("rb:loaded")));
        return;
      }

      sessionStorage.setItem("rb-loader-seen", "1");
      document.documentElement.classList.add("is-preloading");
      document.body.classList.add("is-preloading");
      this.play();
    }

    private play() {
      const line = this.querySelector<HTMLElement>("[data-loader-line]")!;
      const count = this.querySelector<HTMLElement>("[data-loader-count]")!;
      const phase = this.querySelector<HTMLElement>("[data-loader-phase]")!;
      const pass = this.querySelector<HTMLElement>("[data-loader-pass]")!;
      const cube = this.querySelector<HTMLElement>("[data-loader-cube]");

      // ── Asset-driven calibration ──────────────────────────────────────────
      // The theatre stays, but progress now tracks what is actually loading:
      // fonts (20%), full document (20%), first WebGL frame (25%), eager
      // images (35%). A slow time floor keeps it moving; 7s is the failsafe.
      let fontsDone = 0;
      let domDone = document.readyState === "complete" ? 1 : 0;
      let webglDone = document.querySelector("rb-hero-gl") ? 0 : 1;
      let imagesDone = 0;

      document.fonts?.ready.then(() => (fontsDone = 1));
      if (!domDone) addEventListener("load", () => (domDone = 1), { once: true });
      addEventListener("rb:webgl-ready", () => (webglDone = 1), { once: true });
      setTimeout(() => (webglDone = 1), 4200); // WebGL fallback (blocked/very slow GPU)

      const eager = [...document.images].filter((img) => img.loading !== "lazy");
      const pending = eager.filter((img) => !img.complete);
      const imgTotal = Math.max(1, eager.length);
      let imgLoaded = eager.length - pending.length;
      imagesDone = pending.length ? imgLoaded / imgTotal : 1;
      pending.forEach((img) => {
        const bump = () => (imagesDone = ++imgLoaded / imgTotal);
        img.addEventListener("load", bump, { once: true });
        img.addEventListener("error", bump, { once: true });
      });

      const real = () => fontsDone * 0.2 + domDone * 0.2 + webglDone * 0.25 + imagesDone * 0.35;

      const start = performance.now();
      let displayed = 0;
      let finished = false;
      let lastPhase = -1;

      const tick = () => {
        if (finished) return;
        const elapsed = (performance.now() - start) / 1000;
        const floor = Math.min(0.92, elapsed / 6.5); // never looks frozen
        const target = Math.max(real(), floor) * 100;
        displayed += (target - displayed) * 0.085;
        if (elapsed > 7) displayed = 100; // failsafe
        const value = Math.min(100, Math.round(displayed));
        const phaseIndex = Math.min(3, Math.floor(value / 25.1));
        line.style.width = `${value}%`;
        count.textContent = String(value).padStart(3, "0");
        // decode each new phase into place instead of hard-swapping the string
        if (phaseIndex !== lastPhase) {
          lastPhase = phaseIndex;
          decode(phase, phases[phaseIndex]);
        }
        pass.textContent = `${String(phaseIndex + 1).padStart(2, "0")}/04`;
        // Publish progress on the host so the whole stage can react to it —
        // the object materialises as the assets land instead of just spinning.
        this.style.setProperty("--loader-progress", String(value / 100));
        if (cube) cube.style.setProperty("--loader-progress", String(value / 100));

        if (value >= 100 && elapsed > 1.2) {
          finished = true;
          this.dismiss();
          return;
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    private dismiss() {
      this.classList.add("is-hidden");
      document.body.classList.add("is-loaded");
      window.dispatchEvent(new CustomEvent("rb:loaded"));

      const timeline = gsap.timeline({
        onComplete: () => {
          document.documentElement.classList.remove("is-preloading");
          document.body.classList.remove("is-preloading");
          this.remove();
        },
      });
      timeline
        .to(this.querySelector("[data-loader-stage]"), {
          scale: 0.28,
          rotate: 28,
          opacity: 0,
          duration: 0.72,
          ease: "power3.in",
        })
        .to(this.querySelectorAll(".loader-topline, .loader-shell"), {
          opacity: 0,
          y: -12,
          duration: 0.38,
          ease: "power2.in",
        }, "-=0.45")
        .to(this, {
          clipPath: "inset(0 0 100% 0)",
          duration: 1.05,
          ease: "power4.inOut",
        }, "-=0.08");
    }
  }

  if (!customElements.get("rb-studio-loader")) {
    customElements.define("rb-studio-loader", StudioLoader);
  }
</script>
