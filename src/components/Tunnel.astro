<div class="tunnel" data-tunnel-root aria-hidden="true">
  <div class="tunnel-black" data-tunnel-black></div>
  <canvas class="tunnel-canvas" data-tunnel-canvas></canvas>
  <div class="tunnel-hud"><span>RB / SPATIAL TRANSIT</span><b>ARCHIVE VECTOR</b></div>
</div>

<style>
  .tunnel {
    position: fixed;
    inset: 0;
    z-index: 480;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    background: #000;
  }
  .tunnel.is-active,
  :global(html.rb-warp-arriving) .tunnel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .tunnel-black { position: absolute; inset: 0; background: #000; opacity: 0; }
  :global(html.rb-warp-arriving) .tunnel-black { opacity: 1; }
  .tunnel-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .tunnel-hud {
    position: absolute;
    z-index: 2;
    left: clamp(1.2rem,4vw,4rem);
    right: clamp(1.2rem,4vw,4rem);
    bottom: clamp(1rem,3vw,2.5rem);
    display: flex;
    justify-content: space-between;
    color: rgba(255,255,255,.5);
    font: 500 .58rem/1 var(--font-inter);
    letter-spacing: .17em;
    opacity: 0;
  }
  .tunnel-hud b { color: #fff; font-weight: 500; }
  :global(html.rb-transitioning),
  :global(html.rb-transitioning body) { overflow: hidden !important; }
</style>

<script>
  import gsap from "gsap";
  // MPA, not ClientRouter — plain full-page navigation.
  const navigate = (href: string) => location.assign(href);

  let root: HTMLElement;
  let black: HTMLElement;
  let hud: HTMLElement;
  let canvas: HTMLCanvasElement;
  let ctx: CanvasRenderingContext2D;
  let reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  let lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
  let isGallery = location.pathname === "/gallery" || location.pathname === "/gallery/";

  const tunnelRoot = document.querySelector<HTMLElement>("[data-tunnel-root]");
  if (tunnelRoot) {
    root = tunnelRoot;
    black = root.querySelector<HTMLElement>("[data-tunnel-black]")!;
    hud = root.querySelector<HTMLElement>(".tunnel-hud")!;
    canvas = root.querySelector<HTMLCanvasElement>("[data-tunnel-canvas]")!;
    ctx = canvas.getContext("2d", { alpha: false })!;
    isGallery = location.pathname === "/gallery" || location.pathname === "/gallery/";
    resize();
  }

  let stars: { x: number; y: number; z: number; tone: number }[] = [];
  let W = 0, H = 0, cx = 0, cy = 0, focal = 0;
  let running = false;
  let completingBack = false;
  let rafId = 0;
  let safetyTimer = 0;
  let dir = 1; // 1 = forward warp (enter archive), -1 = reverse warp (leave it)
  const state = { speed: 0, alpha: 1 };

  const originMatches = () => {
    const raw = sessionStorage.getItem("rb-warp-origin");
    if (!raw) return false;
    const origin = new URL(raw, location.href);
    return origin.origin === location.origin && origin.pathname === location.pathname && origin.search === location.search;
  };

  function resize() {
    const dpr = lowPower ? 1 : Math.min(devicePixelRatio || 1, 1.45);
    W = canvas.width = Math.floor(innerWidth * dpr);
    H = canvas.height = Math.floor(innerHeight * dpr);
    cx = W / 2; cy = H / 2; focal = W * .52;
  }

  function initStars() {
    stars = Array.from({ length: lowPower ? 220 : 620 }, () => ({
      x: (Math.random() * 2 - 1) * W,
      y: (Math.random() * 2 - 1) * H,
      z: Math.random() * W + 1,
      tone: .48 + Math.random() * .52,
    }));
  }

  function draw() {
    if (!running) return;
    ctx.fillStyle = `rgba(0,0,0,${Math.max(.12, .46 - state.speed / 300)})`;
    ctx.fillRect(0, 0, W, H);
    const speed = state.speed;
    for (const star of stars) {
      const previous = star.z;
      // dir = 1 dives forward (streaks blow outward — entering the archive).
      // dir = -1 pulls backward (streaks rush inward — leaving it).
      star.z -= speed * dir;
      if (star.z < 1) {
        star.z = W;
        star.x = (Math.random() * 2 - 1) * W;
        star.y = (Math.random() * 2 - 1) * H;
        continue;
      }
      if (star.z > W) {
        star.z = 1;
        star.x = (Math.random() * 2 - 1) * W;
        star.y = (Math.random() * 2 - 1) * H;
        continue;
      }
      const k = focal / star.z;
      const oldK = focal / previous;
      const depth = 1 - star.z / W;
      ctx.strokeStyle = `rgba(238,244,247,${star.tone * state.alpha})`;
      ctx.lineWidth = Math.max(.55, depth * 3.2);
      ctx.beginPath();
      ctx.moveTo(cx + star.x * oldK, cy + star.y * oldK);
      ctx.lineTo(cx + star.x * k, cy + star.y * k);
      ctx.stroke();
    }
    rafId = requestAnimationFrame(draw);
  }

  function reset() {
    clearTimeout(safetyTimer);
    running = false;
    cancelAnimationFrame(rafId);
    gsap.killTweensOf([state, black, hud]);
    state.speed = 0;
    black.style.opacity = "0";
    root.classList.remove("is-active");
    document.documentElement.classList.remove("rb-transitioning", "rb-warp-arriving");
    ctx.clearRect(0, 0, W, H);
  }

  function depart(complete: () => void, reverse = false) {
    if (running) reset();
    if (reduced) { complete(); return; }
    running = true;
    dir = reverse ? -1 : 1;
    document.documentElement.classList.add("rb-transitioning");
    root.classList.add("is-active");
    initStars();
    state.speed = 5;
    state.alpha = 1;
    black.style.opacity = "0";
    draw();
    let finished = false;
    const finish = () => {
      if (finished) return;
      finished = true;
      clearTimeout(safetyTimer);
      complete();
    };
    safetyTimer = window.setTimeout(finish, 1650);
    gsap.timeline({ onComplete: finish })
      .to(hud, { opacity: 1, duration: .25 }, 0)
      .to(state, { speed: 112, duration: 1.05, ease: "power3.in" }, 0)
      .to(black, { opacity: 1, duration: .48, ease: "power2.in" }, .72);
  }

  function arrive(clearOrigin = false, reverse = false) {
    if (reduced) { reset(); return; }
    if (running) reset();
    running = true;
    dir = reverse ? -1 : 1;
    document.documentElement.classList.add("rb-transitioning");
    root.classList.add("is-active");
    initStars();
    state.speed = 105;
    state.alpha = 1;
    black.style.opacity = "1";
    draw();
    let finished = false;
    const finish = () => {
      if (finished) return;
      finished = true;
      clearTimeout(safetyTimer);
        reset();
        if (clearOrigin) {
          sessionStorage.removeItem("rb-warp-origin");
          sessionStorage.removeItem("rb-warp-scroll");
          sessionStorage.removeItem("rb-warp-return");
        }
    };
    safetyTimer = window.setTimeout(finish, 1750);
    gsap.timeline({ onComplete: finish })
      .to(black, { opacity: 0, duration: .7, ease: "power2.out" }, .12)
      .to(state, { speed: 2.8, duration: 1.25, ease: "power3.out" }, 0)
      .fromTo(hud, { opacity: 1 }, { opacity: 0, duration: .35 }, .62);
  }

  function enterArchive(href: string) {
    if (running) reset();
    sessionStorage.removeItem("rb-case-arrive");
    sessionStorage.removeItem("rb-case-return");
    sessionStorage.setItem("rb-warp-origin", location.href);
    sessionStorage.setItem("rb-warp-scroll", String(scrollY));
    depart(() => {
      sessionStorage.setItem("rb-warp-arrive", "1");
      navigate(href);
    });
  }

  // Leave the archive back to wherever we warped in from. The old path leaned on
  // history.back() (once here, once more inside popstate) — a double hop that
  // silently no-ops on iOS Safari, which left the reverse warp painted on screen
  // and frozen forever. This is deterministic: play the reverse warp, then load
  // the origin outright. The navigation failsafe is armed BEFORE any canvas/gsap
  // work runs, so a thrown frame can never strand us on a dead warp.
  function leaveArchive() {
    if (completingBack) return;
    completingBack = true;
    const origin = sessionStorage.getItem("rb-warp-origin") || "/";
    let navigated = false;
    const go = () => {
      if (navigated) return;
      navigated = true;
      sessionStorage.setItem("rb-warp-arrive", "1");
      sessionStorage.setItem("rb-warp-return", "1");
      location.assign(origin);
    };
    window.setTimeout(go, 1900); // hard failsafe — never let the warp sit frozen
    try {
      depart(go, true); // reverse warp → navigate on complete
    } catch {
      go();
    }
  }

  if (root) {
    const arriving = sessionStorage.getItem("rb-warp-arrive");
    if (arriving) {
      sessionStorage.removeItem("rb-warp-arrive");
      const isReturn = sessionStorage.getItem("rb-warp-return") === "1";
      arrive(isReturn, isReturn); // returning home decelerates OUT of the reverse warp
    }
  }

  // The browser back button is left native. We used to push a guard entry here
  // and intercept the resulting popstate with history.back() — the exact machine
  // that froze the warp on iOS (frozen BFCache timers, no-op hops). Native back
  // is instant and dependable; the archive's own back link still warps out via
  // the click handler below.
  //
  // Dead-man's switch: if the warp overlay is still up a beat after any load or
  // BFCache restore, force it down — it can never legitimately linger this long.
  const WARP_WATCHDOG_MS = 2400;
  function clearIfStuck() {
    if (root.classList.contains("is-active") || document.documentElement.classList.contains("rb-warp-arriving")) {
      reset();
    }
  }
  window.setTimeout(clearIfStuck, WARP_WATCHDOG_MS);

  addEventListener("pageshow", (event) => {
    window.setTimeout(clearIfStuck, WARP_WATCHDOG_MS);
    if (!event.persisted || sessionStorage.getItem("rb-warp-return") !== "1" || !originMatches()) return;
    reset();
    sessionStorage.removeItem("rb-warp-arrive");
    scrollTo(0, Number(sessionStorage.getItem("rb-warp-scroll") || 0));
    arrive(true, true);
  });

  document.addEventListener("click", (event) => {
    const anchor = (event.target as HTMLElement)?.closest<HTMLAnchorElement>("a[data-tunnel]");
    if (!anchor) return;
    const url = new URL(anchor.href, location.href);
    event.preventDefault();
    if (isGallery && sessionStorage.getItem("rb-warp-origin")) {
      leaveArchive();
      return;
    }
    if (url.pathname === location.pathname) return;
    document.body.classList.remove("is-nav-opened");
    enterArchive(url.href);
  });

  addEventListener("resize", resize);
</script>
