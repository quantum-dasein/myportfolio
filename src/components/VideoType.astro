---
// ─────────────────────────────────────────────────────────────────────────────
//  VideoType.astro — a giant word with Rodion's own 3D render playing inside it.
//
//  CSS `background-clip: text` cannot take a <video> as a background, so this
//  uses the reliable knockout: an inline SVG <mask> where the <text> is black
//  (masked out) over a rect filled with the page background. The letters become
//  holes and the video underneath shows through them. Inline SVG text renders
//  with the page's loaded webfont, so the display face stays consistent.
// ─────────────────────────────────────────────────────────────────────────────
interface Props {
  text?: string;
  video: string;
  poster: string;
  /** caption shown under the band */
  label?: string;
  labelKey?: string;
}

const { text = "MOTION", video, poster, label, labelKey } = Astro.props;
---

<section class="vtype" data-vtype>
  <video
    class="vtype-vid"
    src={video}
    poster={poster}
    muted
    loop
    playsinline
    preload="none"
    aria-hidden="true"
    data-vtype-video></video>

  <!-- black plate with the word punched out of it -->
  <svg class="vtype-knock" viewBox="0 0 1000 240" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <mask id="vtype-mask">
        <rect width="1000" height="240" fill="#fff" />
        <text x="500" y="124" text-anchor="middle" dominant-baseline="middle">{text}</text>
      </mask>
    </defs>
    <rect width="1000" height="240" fill="#050505" mask="url(#vtype-mask)" />
  </svg>

  <h2 class="u-sr-only">{text}</h2>

  {
    (label || labelKey) && (
      <p class="vtype-label">
        <span data-i18n={labelKey}>{label}</span>
      </p>
    )
  }
</section>

<style>
  .vtype {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: #050505;
  }

  .vtype-vid {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* the render reads as light inside the letters, not as a busy photo */
    filter: grayscale(0.25) contrast(1.12) brightness(1.05);
  }

  .vtype-knock {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: clamp(9rem, 22vw, 20rem);
  }

  /* styled via CSS so the inline SVG picks up the real display webfont */
  .vtype-knock text {
    font-family: var(--font-display);
    font-size: 190px;
    font-weight: 500;
    letter-spacing: -6px;
    fill: #000;
  }

  .vtype-label {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 0 clamp(1.5rem, 5vw, 5rem) 1.6rem;
    color: rgba(var(--rgb-text), 0.42);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  /* Phones get the film itself, not a keyhole: the band grows to a real strip
     and the plate goes translucent, so the render plays across the full width
     while the word stays punched through it as the brightest layer. */
  @media (max-width: 600px) {
    .vtype-knock { height: 62vw; }
    .vtype-knock > rect { fill-opacity: 0.52; }
    .vtype-knock text { font-size: 210px; letter-spacing: -4px; }
    .vtype-vid { filter: grayscale(0.15) contrast(1.1) brightness(1.02); }
  }
</style>

<script>
  // Only decode/play the clip while the band is on screen — a looping 3D render
  // has no business burning battery off-screen.
  const section = document.querySelector<HTMLElement>("[data-vtype]");
  const video = document.querySelector<HTMLVideoElement>("[data-vtype-video]");

  if (section && video) {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting && !reduced) {
          if (video.preload === "none") video.preload = "auto";
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      },
      { threshold: 0.15 },
    );
    io.observe(section);
  }
</script>
