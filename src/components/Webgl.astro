---
interface Props {
  sculpture?: boolean;
}

const { sculpture = true } = Astro.props;
---

<rb-hero-gl aria-hidden="true" data-sculpture={sculpture ? "true" : "false"}></rb-hero-gl>

<script>
  import * as THREE from "three";
  import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";

  class HeroGL extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private scene = new THREE.Scene();
    private camera = new THREE.PerspectiveCamera(58, 1, 0.1, 110);
    private sculpture?: THREE.Mesh<THREE.IcosahedronGeometry, THREE.MeshPhysicalMaterial>;
    private sculptureShader?: { uniforms: Record<string, { value: unknown }> };
    private starLayers: THREE.Points[] = [];
    private keyLight?: THREE.DirectionalLight;
    private rimLight?: THREE.PointLight;
    private clock = new THREE.Clock();
    private raf = 0;
    private mouse = new THREE.Vector2();
    private mouseTarget = new THREE.Vector2();
    private scrollProgress = 0;
    private scrollTarget = 0;
    private warp = 0;
    private warpTarget = 0;
    private lastScrollY = 0;
    private reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private visible = true;
    private lastFrame = 0;
    // Adaptive FPS: start at 60 (45 on low power), step 60→45→30 when the real
    // render cost climbs, step back up when there is headroom again.
    private fpsTiers = [60, 45, 30];
    private tier = this.lowPower ? 1 : 0;
    private baseTier = this.tier;
    private renderCost = 6; // EMA of renderer.render() in ms
    private tierFrames = 0;
    private announcedReady = false;
    private calm = document.documentElement.classList.contains("rb-calm");

    connectedCallback() {
      this.renderer = new THREE.WebGLRenderer({
        alpha: true,
        antialias: !this.lowPower,
        powerPreference: "high-performance",
      });
      this.renderer.setPixelRatio(this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.3));
      this.renderer.setClearColor(0x000000, 0);
      this.renderer.outputColorSpace = THREE.SRGBColorSpace;
      this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
      this.renderer.toneMappingExposure = 1.12;
      this.append(this.renderer.domElement);

      const pmrem = new THREE.PMREMGenerator(this.renderer);
      this.scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
      pmrem.dispose();

      this.camera.position.z = 7.2;
      this.buildStars(this.lowPower ? 2200 : 4800, 1.25, 1.0, 0);
      this.buildStars(this.lowPower ? 780 : 1800, 2.35, 1.0, 1);
      this.buildStars(this.lowPower ? 72 : 180, 10.8, 0.46, 2);
      if (this.dataset.sculpture !== "false") this.buildSculpture();
      this.buildLights();
      this.resize();
      this.updateScroll();

      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointerMove, { passive: true });
      addEventListener("scroll", this.updateScroll, { passive: true });
      document.addEventListener("visibilitychange", this.onVisibility);
      addEventListener("rb:calmchange", this.onCalmChange as EventListener);
      this.raf = requestAnimationFrame(this.render);
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.raf);
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointerMove);
      removeEventListener("scroll", this.updateScroll);
      document.removeEventListener("visibilitychange", this.onVisibility);
      removeEventListener("rb:calmchange", this.onCalmChange as EventListener);
      this.starLayers.forEach((layer) => {
        layer.geometry.dispose();
        (layer.material as THREE.Material).dispose();
      });
      this.sculpture?.geometry.dispose();
      this.sculpture?.material.dispose();
      this.renderer?.dispose();
    }

    private buildStars(count: number, sizeMultiplier: number, opacity: number, layerIndex: number) {
      const positions = new Float32Array(count * 3);
      const sizes = new Float32Array(count);
      const alpha = new Float32Array(count);
      const phase = new Float32Array(count);

      for (let i = 0; i < count; i += 1) {
        const i3 = i * 3;
        const radius = 2.8 + Math.pow(Math.random(), 0.6) * 34;
        const angle = Math.random() * Math.PI * 2;
        positions[i3] = Math.cos(angle) * radius;
        positions[i3 + 1] = Math.sin(angle) * radius * 0.62;
        positions[i3 + 2] = -Math.random() * 76 + 4;
        sizes[i] = (0.6 + Math.random() * 2.2) * sizeMultiplier;
        alpha[i] = (0.28 + Math.random() * 0.72) * opacity;
        phase[i] = Math.random() * Math.PI * 2;
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute("aSize", new THREE.BufferAttribute(sizes, 1));
      geometry.setAttribute("aAlpha", new THREE.BufferAttribute(alpha, 1));
      geometry.setAttribute("aPhase", new THREE.BufferAttribute(phase, 1));

      const material = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: {
          uPixelRatio: { value: this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.3) },
          uTime: { value: 0 },
          uTravel: { value: 0 },
          uWarp: { value: 0 },
          uLayer: { value: layerIndex },
        },
        vertexShader: `
          attribute float aSize;
          attribute float aAlpha;
          attribute float aPhase;
          uniform float uPixelRatio;
          uniform float uTime;
          uniform float uTravel;
          uniform float uWarp;
          uniform float uLayer;
          varying float vAlpha;
          varying float vWarp;
          varying float vAngle;
          varying float vLayer;

          void main() {
            vec3 p = position;
            float speed = mix(0.12, 0.3, uLayer / 2.0);
            p.z = mod(p.z + uTravel * 58.0 + uTime * speed + 80.0, 80.0) - 76.0;
            p.x += sin(uTime * 0.05 + aPhase) * 0.04;
            p.y += cos(uTime * 0.045 + aPhase) * 0.03;
            vec4 mv = modelViewMatrix * vec4(p, 1.0);
            vec4 projected = projectionMatrix * mv;
            gl_Position = projected;
            vec2 ndc = projected.xy / max(projected.w, 0.001);
            vAngle = atan(ndc.y, ndc.x);
            vWarp = uWarp;
            vLayer = uLayer;
            vAlpha = aAlpha * smoothstep(-76.0, -52.0, p.z) * smoothstep(4.0, -1.0, p.z);
            float perspective = clamp(16.0 / -mv.z, 0.48, 3.6);
            gl_PointSize = aSize * uPixelRatio * perspective * (1.0 + uWarp * 3.8);
          }
        `,
        fragmentShader: `
          precision highp float;
          varying float vAlpha;
          varying float vWarp;
          varying float vAngle;
          varying float vLayer;

          void main() {
            vec2 p = gl_PointCoord - 0.5;
            float c = cos(vAngle), s = sin(vAngle);
            p = mat2(c, -s, s, c) * p;
            p.x /= 1.0 + vWarp * 4.5;
            float d = length(p);
            float core = smoothstep(0.48, 0.018, d);
            float halo = smoothstep(0.5, 0.08, d) * mix(0.12, 0.55, vLayer / 2.0);
            float trail = smoothstep(0.17, 0.0, abs(p.y)) * smoothstep(0.5, 0.01, abs(p.x));
            float shape = max(core + halo, trail * vWarp);
            if (shape < 0.008) discard;
            vec3 silver = mix(vec3(0.78, 0.82, 0.85), vec3(1.0), core);
            gl_FragColor = vec4(silver * shape, vAlpha * shape);
          }
        `,
      });

      const layer = new THREE.Points(geometry, material);
      this.starLayers.push(layer);
      this.scene.add(layer);
    }

    private buildSculpture() {
      const geometry = new THREE.IcosahedronGeometry(2.05, this.lowPower ? 3 : 5);
      const material = new THREE.MeshPhysicalMaterial({
        color: new THREE.Color(0x050608),
        roughness: 0.055,
        metalness: 0.24,
        transmission: this.lowPower ? 0.68 : 0.84,
        thickness: 2.8,
        ior: 1.5,
        clearcoat: 1,
        clearcoatRoughness: 0.04,
        attenuationColor: new THREE.Color(0x0b0d10),
        attenuationDistance: 1.7,
        envMapIntensity: 2.15,
      });

      material.onBeforeCompile = (shader) => {
        shader.uniforms.uTime = { value: 0 };
        shader.vertexShader = shader.vertexShader.replace(
          "#include <common>",
          `#include <common>
          uniform float uTime;
          float rbNoise(vec3 p) {
            return sin(p.x * 1.9 + uTime * 0.31) *
                   sin(p.y * 2.3 - uTime * 0.24) *
                   sin(p.z * 1.7 + uTime * 0.19);
          }`,
        );
        shader.vertexShader = shader.vertexShader.replace(
          "#include <begin_vertex>",
          `vec3 transformed = vec3(position);
          float breath = sin(uTime * 0.48) * 0.055;
          float displacement = rbNoise(position) * 0.17 + breath;
          transformed += normal * displacement;
          transformed.x += sin(position.y * 1.55 + uTime * 0.22) * 0.08;
          transformed.y += cos(position.z * 1.35 - uTime * 0.18) * 0.06;`,
        );
        this.sculptureShader = shader;
      };

      this.sculpture = new THREE.Mesh(geometry, material);
      this.sculpture.position.set(innerWidth < 760 ? 1.45 : 3.15, innerWidth < 760 ? 1.15 : 0.25, 0);
      this.sculpture.rotation.set(-0.28, 0.48, 0.12);
      this.scene.add(this.sculpture);
    }

    private buildLights() {
      this.keyLight = new THREE.DirectionalLight(0xffffff, 7.4);
      this.keyLight.position.set(-4.5, 6, 7);
      this.scene.add(this.keyLight);
      const edge = new THREE.DirectionalLight(0xd9e0e3, 5.2);
      edge.position.set(7, -2.5, 3);
      this.scene.add(edge);
      this.rimLight = new THREE.PointLight(0xffffff, 28, 18, 1.8);
      this.rimLight.position.set(2.5, 2.2, 4.5);
      this.scene.add(this.rimLight);
    }

    private updateScroll = () => {
      const max = Math.max(1, document.documentElement.scrollHeight - innerHeight);
      this.scrollTarget = Math.min(1, scrollY / max);
      const delta = Math.abs(scrollY - this.lastScrollY);
      this.warpTarget = Math.min(1, delta / 90);
      this.lastScrollY = scrollY;
    };

    private onPointerMove = (event: PointerEvent) => {
      this.mouseTarget.set(event.clientX / innerWidth - 0.5, 0.5 - event.clientY / innerHeight);
    };

    private onVisibility = () => {
      this.visible = !document.hidden;
      if (this.visible && !this.raf) this.raf = requestAnimationFrame(this.render);
    };

    private onCalmChange = (event: CustomEvent<{ calm: boolean }>) => {
      this.calm = Boolean(event.detail?.calm);
    };

    private resize = () => {
      if (!this.renderer) return;
      this.renderer.setSize(innerWidth, innerHeight, false);
      this.camera.aspect = innerWidth / innerHeight;
      this.camera.updateProjectionMatrix();
      this.starLayers.forEach((layer) => {
        (layer.material as THREE.ShaderMaterial).uniforms.uPixelRatio.value = this.lowPower
          ? Math.min(devicePixelRatio || 1, 1)
          : Math.min(devicePixelRatio || 1, 1.3);
      });
    };

    private render = (now = performance.now()) => {
      this.raf = 0;
      if (!this.renderer || !this.visible) return;
      const targetFps = this.calm ? 30 : this.fpsTiers[this.tier];
      if (now - this.lastFrame < 1000 / targetFps) {
        this.raf = requestAnimationFrame(this.render);
        return;
      }
      this.lastFrame = now;
      const elapsed = this.clock.getElapsedTime();
      this.mouse.lerp(this.mouseTarget, this.reduced ? 1 : 0.045);
      this.scrollProgress += (this.scrollTarget - this.scrollProgress) * (this.reduced ? 1 : 0.055);
      this.warp += (this.warpTarget - this.warp) * 0.12;
      this.warpTarget *= 0.9;

      this.camera.position.x += (this.mouse.x * 0.48 - this.camera.position.x) * 0.03;
      this.camera.position.y += (this.mouse.y * 0.34 - this.camera.position.y) * 0.03;

      this.starLayers.forEach((layer, index) => {
        const material = layer.material as THREE.ShaderMaterial;
        material.uniforms.uTime.value = elapsed;
        material.uniforms.uTravel.value = this.scrollProgress;
        material.uniforms.uWarp.value = this.reduced ? 0 : this.warp;
        layer.rotation.y = this.mouse.x * (0.018 + index * 0.012);
        layer.rotation.x = -this.mouse.y * (0.012 + index * 0.008);
      });

      if (this.sculpture) {
        const p = this.scrollProgress;
        const mobile = innerWidth < 760;
        const baseX = mobile ? 1.45 : 3.15;
        this.sculpture.position.x = baseX + Math.sin(p * Math.PI * 4.2) * (mobile ? 0.45 : 1.3) + this.mouse.x * 0.55;
        this.sculpture.position.y = (mobile ? 1.15 : 0.25) + Math.sin(p * Math.PI * 3.1) * 0.75 + this.mouse.y * 0.34;
        this.sculpture.position.z = -p * 4.4;
        const scale = 1 - p * 0.24;
        this.sculpture.scale.setScalar(scale);
        this.sculpture.rotation.x = -0.28 + elapsed * 0.055 + this.mouse.y * 0.2;
        this.sculpture.rotation.y = 0.48 + elapsed * 0.08 + this.mouse.x * 0.28;
        this.sculpture.rotation.z = 0.12 + Math.sin(elapsed * 0.18) * 0.08;
      }

      if (this.sculptureShader) this.sculptureShader.uniforms.uTime.value = elapsed;
      if (this.keyLight) this.keyLight.position.x = -4.5 + this.mouse.x * 3;
      if (this.rimLight) this.rimLight.position.y = 2.2 + this.mouse.y * 2;

      const renderStart = performance.now();
      this.renderer.render(this.scene, this.camera);
      this.renderCost += (performance.now() - renderStart - this.renderCost) * 0.05;

      // Retier every ~90 frames based on the measured render cost.
      if (++this.tierFrames >= 90) {
        this.tierFrames = 0;
        if (this.renderCost > 12 && this.tier < this.fpsTiers.length - 1) this.tier += 1;
        else if (this.renderCost < 5 && this.tier > this.baseTier) this.tier -= 1;
      }

      if (!this.announcedReady) {
        this.announcedReady = true;
        window.dispatchEvent(new CustomEvent("rb:webgl-ready"));
      }

      this.raf = requestAnimationFrame(this.render);
    };
  }

  if (!customElements.get("rb-hero-gl")) customElements.define("rb-hero-gl", HeroGL);
</script>

<style>
  rb-hero-gl {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    background: #000;
  }

  rb-hero-gl::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(80% 70% at 72% 42%, transparent 0%, rgba(0, 0, 0, 0.14) 56%, rgba(0, 0, 0, 0.58) 100%);
  }

  rb-hero-gl canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    animation: webgl-enter 1.7s 0.2s var(--ease-out-expo) forwards;
  }

  @keyframes webgl-enter { to { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    rb-hero-gl canvas { animation: none; opacity: 1; }
  }
</style>
