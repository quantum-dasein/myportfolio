---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import Tunnel from "../components/Tunnel.astro";
import Webgl from "../components/Webgl.astro";
import StudioLoader from "../components/StudioLoader.astro";
import CursorField from "../components/CursorField.astro";
import SoundField from "../components/SoundField.astro";
import CaseTransition from "../components/CaseTransition.astro";
import { ui, defaultLang } from "../i18n/ui";
import { useTranslations, type Lang } from "../i18n/utils";
import type { Link } from "../types";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  pageType?: "website" | "profile" | "article";
  keywords?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  /** "deck" = fixed, non-scrolling presentation (no footer, no smooth scroll). */
  mode?: "scroll" | "deck";
  theme?: "bridge" | "fidic";
  lang?: Lang;
  /**
   * hreflang alternates for search engines. Passing these does NOT change how
   * the language switcher behaves — set `lockLang` for that.
   */
  alternateUrls?: Partial<Record<Lang | "x-default", string>>;
  /**
   * true = this page is a hard-localized route (/en/…, /de/…): the switcher
   * navigates between locale URLs. false (default) = the switcher swaps copy
   * in place on the current page and never changes the route.
   */
  lockLang?: boolean;
}

const {
  title = t("meta.title"),
  description = t("meta.description"),
  image = "/og/rodion-belousov-digital-marketer-creative-developer-vienna.jpg",
  imageAlt = "Rodion Belousov — Marketing that moves. Websites that convert. Digital Marketer and Creative Developer in Vienna",
  pageType = "website",
  keywords = [],
  structuredData = [],
  noindex = false,
  mode = "scroll",
  theme,
  lang = defaultLang,
  alternateUrls,
  lockLang = false,
} = Astro.props;
const t = useTranslations(lang);
const isDeck = mode === "deck";
// There is exactly ONE home: "/". The old /en/ and /de/ landings were clones of
// it, and treating them as the "locale root" is what sent visitors from a
// service page to a duplicate homepage they could not get out of. Locale lives
// only on genuinely localized CONTENT (/en/<service>, /de/<insight>), never on
// the home, and the wordmark always returns to "/".
const homePrefix = Astro.url.pathname === "/" ? "" : "/";
const site = Astro.site ?? new URL("https://rodionbelousov.studio");
const canonical = new URL(Astro.url.pathname, site).toString();
const socialImage = new URL(image, site).toString();
const resolveAlternate = (value?: string) => value ? new URL(value, site).toString() : undefined;
const localizedAlternates = alternateUrls ? {
  en: resolveAlternate(alternateUrls.en),
  de: resolveAlternate(alternateUrls.de),
  xDefault: resolveAlternate(alternateUrls["x-default"] ?? "/"),
} : undefined;
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const pageSchemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${site}#rodion-belousov`,
      name: "Rodion Belousov",
      url: site.toString(),
      email: "mailto:rodionbelousov@protonmail.com",
      jobTitle: "Digital Marketer and Creative Developer",
      description,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Vienna",
        addressCountry: "AT",
      },
      sameAs: [
        "https://www.linkedin.com/in/rodion-belousov-413040228/",
        "https://www.behance.net/gallery/146849483/Meine-3D-Projekte",
        "https://github.com/quantum-dasein",
      ],
      knowsLanguage: ["German", "English", "Russian", "Czech"],
      knowsAbout: [
        "Digital marketing",
        "Marketing strategy",
        "Search engine optimization",
        "Technical SEO",
        "Content strategy",
        "Web development",
        "Astro",
        "Three.js",
        "WebGL",
        "Cinema 4D",
        "Redshift Renderer",
        "Adobe After Effects",
        "Adobe Premiere Pro",
        "Adobe Photoshop",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${site}#website`,
      url: site.toString(),
      name: "Rodion Belousov Studio",
      description: t("meta.description"),
      inLanguage: lang === "de" ? "de-AT" : "en",
      publisher: { "@id": `${site}#rodion-belousov` },
    },
    {
      "@type": pageType === "profile" ? "ProfilePage" : pageType === "article" ? "Article" : "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      inLanguage: lang === "de" ? "de-AT" : "en",
      isPartOf: { "@id": `${site}#website` },
      about: { "@id": `${site}#rodion-belousov` },
      ...(pageType === "profile" ? { mainEntity: { "@id": `${site}#rodion-belousov` } } : {}),
      ...(pageType === "article" ? {
        author: { "@id": `${site}#rodion-belousov` },
        datePublished: "2026-07-14",
        dateModified: "2026-07-14",
      } : {}),
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: socialImage,
        caption: imageAlt,
      },
    },
    ...pageSchemas,
  ],
};
const serializedSchema = JSON.stringify(schema).replace(/</g, "\\u003c");

const nav: Link[] = isDeck
  ? []
  : [
      { title: t("nav.about"), url: `${homePrefix}#about`, i18n: "nav.about" },
      { title: t("nav.work"), url: `${homePrefix}#work`, i18n: "nav.work" },
      // Services & Research is its own destination (/services) — a real page,
      // completely independent of the language system. It must never resolve to
      // a locale root (/en/, /de/), which is what trapped visitors before.
      { title: t("nav.services"), url: "/services", i18n: "nav.services" },
      { title: t("nav.contact"), url: `${homePrefix}#contact-cta`, i18n: "nav.contact" },
    ];
const cta = isDeck
  ? { title: t("portal.back"), url: "/", i18n: "portal.back", tunnel: true }
  : { title: t("nav.gallery"), url: "/gallery", i18n: "nav.gallery", tunnel: true };

// Serialize the full dictionary for the in-page language controller, and set the
// preferred <html lang> before paint to avoid a flash of the wrong locale attr.
const bootScript = `window.__I18N__=${JSON.stringify(ui)};window.__DEFAULT_LANG__=${JSON.stringify(
  defaultLang,
)};window.__LOCKED_LANG__=${JSON.stringify(lockLang ? lang : null)};try{var locked=window.__LOCKED_LANG__;var l=locked||localStorage.getItem('rb-lang')||(navigator.language||'').slice(0,2);if(window.__I18N__[l]){document.documentElement.lang=l==='de'?'de-AT':'en';if(locked)localStorage.setItem('rb-lang',locked);}}catch(e){}try{if(localStorage.getItem('rb-motion')==='calm')document.documentElement.classList.add('rb-calm');if(sessionStorage.getItem('rb-loader-seen')==='1')document.documentElement.classList.add('rb-loader-seen');if(sessionStorage.getItem('rb-case-arrive')||sessionStorage.getItem('rb-case-return')||sessionStorage.getItem('rb-case-direct-arrive'))document.documentElement.classList.add('rb-case-arriving');if(sessionStorage.getItem('rb-warp-arrive'))document.documentElement.classList.add('rb-warp-arriving')}catch(e){}`;
---

<html lang={lang === "de" ? "de-AT" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Rodion Belousov" />
    <meta name="creator" content="Rodion Belousov" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <meta name="geo.region" content="AT-9" />
    <meta name="geo.placename" content="Vienna" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#08080a" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    <link rel="canonical" href={canonical} />
    {localizedAlternates?.en && <link rel="alternate" hreflang="en" href={localizedAlternates.en} />}
    {localizedAlternates?.de && <link rel="alternate" hreflang="de-AT" href={localizedAlternates.de} />}
    {localizedAlternates?.xDefault && <link rel="alternate" hreflang="x-default" href={localizedAlternates.xDefault} />}
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={pageType === "article" ? "article" : pageType === "profile" ? "profile" : "website"} />
    <meta property="og:site_name" content="Rodion Belousov Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={lang === "de" ? "de_AT" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "de" ? "en_US" : "de_AT"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" is:inline set:html={serializedSchema} />

    <script is:inline set:html={bootScript} />

    <title>{title}</title>
  </head>
  <body class:list={[{ "is-deck": isDeck }, theme && `case-theme-${theme}`]}>
    <StudioLoader />
    <CursorField />
    <SoundField />

    {!isDeck && (
      <div class="cosmic-backdrop" aria-hidden="true">
        <Webgl sculpture={!theme} />
      </div>
    )}

    <div class="site-fx" aria-hidden="true">
      <span class="site-fx__stars"></span>
      <span class="site-fx__grain"></span>
      <span class="site-fx__scan"></span>
      <span class="site-fx__vignette"></span>
    </div>

    <a href="#main" class="skip-link" data-i18n="accessibility.skip-to-content">
      {t("accessibility.skip-to-content")}
    </a>

    <Header
      logoUrl="/"
      logoAlt="Rodion Belousov"
      links={nav}
      cta={cta}
      lang={lang}
      localeLinks={lockLang && alternateUrls?.en && alternateUrls?.de
        ? { en: alternateUrls.en, de: alternateUrls.de }
        : undefined}
      logoTunnel={isDeck}
    />

    <main id="main">
      <slot />
    </main>

    {!isDeck && <Footer logoUrl="/" logoAlt="Rodion Belousov" links={nav} lang={lang} />}
    {!isDeck && <SmoothScroll />}
    <CaseTransition />
    <Tunnel />
  </body>
</html>

<style>
  .skip-link {
    background: var(--color-accent);
    color: var(--color-black);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem 1rem;
    border-radius: 0 0 0.5rem 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }

  .cosmic-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #000;
  }

  :global(body.case-theme-bridge),
  :global(body.case-theme-fidic) {
    background: #030405;
  }

  :global(body.case-theme-bridge main),
  :global(body.case-theme-fidic main) {
    background: #030405;
    isolation: isolate;
  }

  :global(main) {
    position: relative;
    z-index: 1;
  }

  /* Deck mode: lock the viewport — navigation is by chapter, not scroll. */
  :global(body.is-deck) {
    height: 100svh;
    overflow: hidden;
    overscroll-behavior: none;
    touch-action: none;
  }

  :global(body.is-deck main) {
    height: 100svh;
  }

  .site-fx,
  .site-fx span {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .site-fx {
    z-index: 45;
    overflow: hidden;
  }

  .site-fx__stars {
    opacity: 0.24;
    background-image:
      radial-gradient(circle at 9% 18%, rgba(255, 255, 255, 0.56) 0 1px, transparent 1.5px),
      radial-gradient(circle at 22% 72%, rgba(255, 255, 255, 0.38) 0 1px, transparent 1.4px),
      radial-gradient(circle at 44% 28%, rgba(var(--rgb-accent), 0.48) 0 1px, transparent 1.6px),
      radial-gradient(circle at 67% 61%, rgba(255, 255, 255, 0.34) 0 1px, transparent 1.5px),
      radial-gradient(circle at 86% 24%, rgba(var(--rgb-accent), 0.42) 0 1px, transparent 1.4px);
    background-size: 19rem 19rem, 23rem 23rem, 29rem 29rem, 31rem 31rem, 37rem 37rem;
    animation: fx-stars 26s linear infinite;
  }

  .site-fx__grain {
    opacity: 0.07;
    background-image:
      repeating-radial-gradient(circle at 17% 32%, rgba(255, 255, 255, 0.16) 0 1px, transparent 1px 4px),
      repeating-radial-gradient(circle at 82% 21%, rgba(255, 255, 255, 0.1) 0 1px, transparent 1px 5px);
    background-size: 180px 180px, 220px 220px;
    mix-blend-mode: overlay;
    animation: fx-grain 0.8s steps(2) infinite;
  }

  .site-fx__scan {
    display: none;
  }

  .site-fx__vignette {
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.15), transparent 18%, transparent 82%, rgba(0, 0, 0, 0.2)),
      radial-gradient(120% 90% at 50% 42%, transparent 0%, transparent 68%, rgba(0, 0, 0, 0.46) 100%);
  }

  @keyframes fx-grain {
    0% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-1.5%, 1%, 0); }
    100% { transform: translate3d(1%, -1.5%, 0); }
  }

  @keyframes fx-stars {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-2rem, 1.4rem, 0); }
  }

  /* ── Calm mode: keep the composition, mute the noise ───────────────────── */
  :global(html.rb-calm) .site-fx__grain,
  :global(html.rb-calm) .site-fx__scan {
    display: none;
  }

  :global(html.rb-calm) .site-fx__stars {
    animation: none;
    opacity: 0.18;
  }

  @media (max-width: 760px), (pointer: coarse) {
    .site-fx__stars {
      opacity: .27;
      animation-duration: 42s;
    }

    .site-fx__grain {
      opacity: .035;
      animation: none;
    }

    .site-fx__vignette {
      background: radial-gradient(130% 100% at 50% 42%, transparent 0%, transparent 72%, rgba(0, 0, 0, .38) 100%);
    }
  }
</style>

<script>
  import "../utils/reveals";
  import "../utils/vitals";

  // Warm up the archive before the likely click: prefetch the /gallery route
  // (and its hashed three.js chunk via the browser's speculative parse) once
  // the main thread is idle. Skipped on the gallery itself and on save-data.
  const idle = (window as any).requestIdleCallback ?? ((fn: () => void) => setTimeout(fn, 2500));
  const saveData = (navigator as any).connection?.saveData;
  if (location.pathname !== "/gallery" && !saveData) {
    idle(() => {
      const link = document.createElement("link");
      link.rel = "prefetch";
      link.href = "/gallery";
      link.as = "document";
      document.head.appendChild(link);
    });
  }
</script>
