---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
---

<Layout
  title="404 — Signal Lost"
  description="You've drifted off course. These coordinates do not exist in the current space."
  noindex={true}
  noWebgl={true}
>
  <section class="void" aria-labelledby="void-title">
    <!-- z1: the whole anomaly (stars → ghost 404 → obsidian sphere → RGB split) -->
    <rb-anomaly class="void-gl" aria-hidden="true"></rb-anomaly>

    <!-- z2: the readout, over the scene -->
    <div class="void-ui">
      <p class="void-eyebrow" data-i18n="404.eyebrow" data-decode-in>{t("404.eyebrow")}</p>
      <h1 id="void-title" class="void-title" data-i18n="404.title" data-split>{t("404.title")}</h1>
      <p class="void-sub" data-i18n="404.subtitle" data-decode-in>{t("404.subtitle")}</p>

      <a href="/" class="evac" data-magnetic data-cursor="HOME">
        <span class="evac-inner" data-i18n="404.cta">{t("404.cta")}</span>
        <span class="evac-arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <!-- corner telemetry, for the "adrift" mood -->
    <div class="void-corner tl" aria-hidden="true"><span data-decode-in>LOST SIGNAL</span></div>
    <div class="void-corner br" aria-hidden="true">
      <span>LAT <b data-coord="lat">--.----</b></span>
      <span>LON <b data-coord="lon">--.----</b></span>
    </div>

    <span class="void-bracket tl" aria-hidden="true"></span>
    <span class="void-bracket tr" aria-hidden="true"></span>
    <span class="void-bracket bl" aria-hidden="true"></span>
    <span class="void-bracket br" aria-hidden="true"></span>

    <span class="void-scroll" aria-hidden="true"><b></b><span data-i18n="404.scroll">drift on</span></span>
  </section>

  <!-- ── Signal recovery: real destinations, dressed as navigation beacons ──── -->
  <section class="recover" aria-labelledby="recover-title">
    <div class="recover-head">
      <span class="recover-eyebrow" data-i18n="404.recover.eyebrow" data-decode-in>{t("404.recover.eyebrow")}</span>
      <h2 id="recover-title" data-i18n="404.recover.title">{t("404.recover.title")}</h2>
      <p data-i18n="404.recover.sub">{t("404.recover.sub")}</p>
    </div>

    <div class="beacons">
      <a class="beacon" href="/" data-beacon data-magnetic data-cursor="HOME">
        <span class="beacon-top"><span class="beacon-id">00 / BASE</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.studio.name">{t("404.beacon.studio.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.studio.desc">{t("404.beacon.studio.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
      <a class="beacon" href="/services" data-beacon data-magnetic data-cursor="OPEN">
        <span class="beacon-top"><span class="beacon-id">01 / WORKSHOP</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.services.name">{t("404.beacon.services.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.services.desc">{t("404.beacon.services.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
      <a class="beacon" href="/gallery" data-beacon data-magnetic data-cursor="ENTER">
        <span class="beacon-top"><span class="beacon-id">02 / ARCHIVE</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.archive.name">{t("404.beacon.archive.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.archive.desc">{t("404.beacon.archive.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
      <a class="beacon" href="/work/bridge-consult" data-beacon data-magnetic data-cursor="OPEN">
        <span class="beacon-top"><span class="beacon-id">03 / CASE</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.bridge.name">{t("404.beacon.bridge.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.bridge.desc">{t("404.beacon.bridge.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
      <a class="beacon" href="/work/fidic" data-beacon data-magnetic data-cursor="OPEN">
        <span class="beacon-top"><span class="beacon-id">04 / CASE</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.fidic.name">{t("404.beacon.fidic.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.fidic.desc">{t("404.beacon.fidic.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
      <a class="beacon" href="/work/studio" data-beacon data-magnetic data-cursor="OPEN">
        <span class="beacon-top"><span class="beacon-id">05 / META</span><span class="beacon-dot"></span></span>
        <span class="beacon-name" data-i18n="404.beacon.meta.name">{t("404.beacon.meta.name")}</span>
        <span class="beacon-desc" data-i18n="404.beacon.meta.desc">{t("404.beacon.meta.desc")}</span>
        <span class="beacon-go" aria-hidden="true">→</span>
      </a>
    </div>

    <div class="diag" aria-hidden="true">
      <div class="diag-cell"><span class="diag-key">System</span><span class="diag-val"><i class="diag-pulse"></i><span data-i18n="404.diag.system">{t("404.diag.system")}</span></span></div>
      <div class="diag-cell"><span class="diag-key">Sector</span><span class="diag-val">rodionbelousov.studio</span></div>
      <div class="diag-cell"><span class="diag-key">Error</span><span class="diag-val">HTTP 404 · NO_ROUTE</span></div>
      <div class="diag-cell"><span class="diag-key">Recovery</span><span class="diag-val" data-i18n="404.diag.recovery">{t("404.diag.recovery")}</span></div>
    </div>
  </section>
</Layout>

<script>
  // ───────────────────────────────────────────────────────────────────────────
  //  404 — "The Event Horizon".
  //
  //  The studio's liquid-obsidian sphere, but unstable: an FBM noise field
  //  breathes and tears through its surface, it periodically glitches — flashing
  //  its wireframe skeleton and shattering a few facets outward — and the whole
  //  frame splits into RGB when the pointer moves fast or a glitch fires.
  //
  //  One opaque scene, composited in order: a slow starfield, a giant ghost 404
  //  behind the sphere, the sphere in front, then a single RGB-split post pass.
  //  Everything is self-contained here; the homepage hero (Webgl.astro) is left
  //  untouched.
  // ───────────────────────────────────────────────────────────────────────────
  import * as THREE from "three";
  import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
  import gsap from "gsap";
  import { decodeText, prefersCalm } from "../utils/decode";

  // Injected into both the sphere and its wireframe so their vertices move as
  // one. Displacement rides `normalize(position)` (the sphere's own normal) so
  // it never depends on a `normal` attribute being present in the material.
  const NOISE = /* glsl */ `
    uniform float uTime;
    uniform float uGlitch;
    uniform float uBurst;
    vec3 rbHash(vec3 p){
      p = vec3(dot(p, vec3(127.1, 311.7, 74.7)),
               dot(p, vec3(269.5, 183.3, 246.1)),
               dot(p, vec3(113.5, 271.9, 124.6)));
      return fract(sin(p) * 43758.5453123) * 2.0 - 1.0;
    }
    float rbNoise(vec3 p){
      vec3 i = floor(p); vec3 f = fract(p);
      vec3 u = f * f * (3.0 - 2.0 * f);
      return mix(mix(mix(dot(rbHash(i + vec3(0,0,0)), f - vec3(0,0,0)),
                         dot(rbHash(i + vec3(1,0,0)), f - vec3(1,0,0)), u.x),
                     mix(dot(rbHash(i + vec3(0,1,0)), f - vec3(0,1,0)),
                         dot(rbHash(i + vec3(1,1,0)), f - vec3(1,1,0)), u.x), u.y),
                 mix(mix(dot(rbHash(i + vec3(0,0,1)), f - vec3(0,0,1)),
                         dot(rbHash(i + vec3(1,0,1)), f - vec3(1,0,1)), u.x),
                     mix(dot(rbHash(i + vec3(0,1,1)), f - vec3(0,1,1)),
                         dot(rbHash(i + vec3(1,1,1)), f - vec3(1,1,1)), u.x), u.y), u.z);
    }
    float rbFbm(vec3 p){
      float v = 0.0, a = 0.5;
      for (int i = 0; i < 4; i++) { v += a * rbNoise(p); p = p * 2.03 + 1.3; a *= 0.5; }
      return v;
    }
  `;

  const DISPLACE = /* glsl */ `
    vec3 rbDir = normalize(position + 1e-5);
    float rbN = rbFbm(position * 1.5 + uTime * 0.28);
    float rbBreath = sin(uTime * 0.6) * 0.045;
    float rbDisp = rbN * 0.15 + rbBreath;
    float rbRnd = fract(sin(dot(position, vec3(12.9898, 78.233, 45.164))) * 43758.5453);
    // A glitch burst throws a subset of facets outward — the sphere shatters.
    rbDisp += uBurst * smoothstep(0.55, 1.0, rbRnd) * (0.4 + 0.9 * rbRnd);
    // Fine radial jitter whenever glitch is hot.
    rbDisp += uGlitch * (rbRnd - 0.5) * 0.35;
    transformed += rbDir * rbDisp;
    // Lateral tearing on glitch.
    transformed += normalize(position.zxy + 1e-5) * uGlitch * (rbRnd - 0.5) * 0.25;
  `;

  const POST_VERT = /* glsl */ `
    varying vec2 vUv;
    void main(){ vUv = uv; gl_Position = vec4(position.xy, 0.0, 1.0); }
  `;
  const POST_FRAG = /* glsl */ `
    precision highp float;
    uniform sampler2D uTex;
    uniform vec2 uSplit;
    uniform vec2 uRes;
    uniform float uTime;
    varying vec2 vUv;
    float rand(vec2 p){ return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }
    void main(){
      vec2 o = uSplit;
      vec3 col;
      col.r = texture2D(uTex, vUv + o).r;
      col.g = texture2D(uTex, vUv).g;
      col.b = texture2D(uTex, vUv - o).b;
      // Faint scanline shear, only while actively glitching (wide split).
      float amt = length(uSplit);
      float band = step(0.6, rand(vec2(floor(vUv.y * uRes.y / 3.0), floor(uTime * 22.0))));
      col += band * amt * 6.0 * vec3(0.10, 0.12, 0.16);
      // Fine grain keeps the black from banding.
      col += (rand(vUv + fract(uTime)) - 0.5) * 0.015;
      gl_FragColor = vec4(col, 1.0);
    }
  `;

  class Anomaly extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private scene = new THREE.Scene();
    private camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
    private target?: THREE.WebGLRenderTarget;
    private postScene = new THREE.Scene();
    private postCam = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
    private post?: THREE.ShaderMaterial;
    private sphere?: THREE.Mesh;
    private wire?: THREE.Mesh;
    private stars?: THREE.Points;
    private ghost?: THREE.Mesh;
    private uniforms = {
      uTime: { value: 0 },
      uGlitch: { value: 0 },
      uBurst: { value: 0 },
    };
    private clock = new THREE.Clock();
    private raf = 0;
    private mouse = new THREE.Vector2();
    private mouseTarget = new THREE.Vector2();
    private lastPointer = new THREE.Vector2();
    private vel = 0;
    private split = new THREE.Vector2();
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private visible = true;
    private calm = document.documentElement.classList.contains("rb-calm");
    private reduced = prefersCalm();
    private lastFrame = 0;
    private glitchTimer?: gsap.core.Tween;

    connectedCallback() {
      const gl = new THREE.WebGLRenderer({ antialias: !this.lowPower, alpha: false, powerPreference: "high-performance" });
      this.renderer = gl;
      gl.setPixelRatio(Math.min(devicePixelRatio || 1, this.lowPower ? 1.3 : 1.5));
      gl.setClearColor(0x030405, 1);
      gl.outputColorSpace = THREE.SRGBColorSpace;
      gl.toneMapping = THREE.ACESFilmicToneMapping;
      gl.toneMappingExposure = 1.1;
      this.append(gl.domElement);

      const pmrem = new THREE.PMREMGenerator(gl);
      this.scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
      pmrem.dispose();

      this.camera.position.set(0, 0, 7.2);
      this.camera.lookAt(0, 0, 0);

      this.buildStars();
      this.buildGhost();
      this.buildSphere();
      this.buildLights();

      // Post pass (RGB split + scanline shear). Skipped on low-power: it renders
      // straight to the canvas there.
      if (!this.lowPower) {
        this.target = new THREE.WebGLRenderTarget(1, 1, { minFilter: THREE.LinearFilter, magFilter: THREE.LinearFilter, depthBuffer: true });
        this.post = new THREE.ShaderMaterial({
          vertexShader: POST_VERT,
          fragmentShader: POST_FRAG,
          depthTest: false,
          depthWrite: false,
          uniforms: {
            uTex: { value: this.target.texture },
            uSplit: { value: this.split },
            uRes: { value: new THREE.Vector2(1, 1) },
            uTime: { value: 0 },
          },
        });
        this.postScene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), this.post));
      }

      this.resize();
      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointerMove, { passive: true });
      document.addEventListener("visibilitychange", this.onVisibility);
      addEventListener("rb:calmchange", this.onCalm as EventListener);

      if (!this.reduced && !this.calm) this.scheduleGlitch();
      this.lastFrame = performance.now();
      this.raf = requestAnimationFrame(this.render);
      if (this.calm || this.reduced) this.draw(0); // one static frame
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.raf);
      this.glitchTimer?.kill();
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointerMove);
      document.removeEventListener("visibilitychange", this.onVisibility);
      removeEventListener("rb:calmchange", this.onCalm as EventListener);
      this.scene.traverse((o) => {
        const m = o as THREE.Mesh;
        m.geometry?.dispose?.();
        const mat = m.material as THREE.Material | THREE.Material[] | undefined;
        if (Array.isArray(mat)) mat.forEach((x) => x.dispose());
        else mat?.dispose();
      });
      this.scene.environment?.dispose();
      this.target?.dispose();
      this.post?.dispose();
      this.renderer?.dispose();
      this.renderer = undefined;
    }

    private inject = (shader: THREE.WebGLProgramParametersWithUniforms) => {
      shader.uniforms.uTime = this.uniforms.uTime;
      shader.uniforms.uGlitch = this.uniforms.uGlitch;
      shader.uniforms.uBurst = this.uniforms.uBurst;
      shader.vertexShader = shader.vertexShader
        .replace("#include <common>", "#include <common>\n" + NOISE)
        .replace("#include <begin_vertex>", "#include <begin_vertex>\n" + DISPLACE);
    };

    private buildSphere() {
      const detail = this.lowPower ? 4 : 6;
      const geo = new THREE.IcosahedronGeometry(1.75, detail);

      // Dark, glossy obsidian — reads as a solid polished orb, not a bubble.
      const mat = new THREE.MeshPhysicalMaterial({
        color: new THREE.Color(0x070a10),
        metalness: 0.42,
        roughness: 0.13,
        clearcoat: 1,
        clearcoatRoughness: 0.09,
        envMapIntensity: 1.05,
        emissive: new THREE.Color(0x0a1626),
        emissiveIntensity: 0.22,
      });
      mat.onBeforeCompile = this.inject;
      this.sphere = new THREE.Mesh(geo, mat);
      this.scene.add(this.sphere);

      // The skeleton underneath — nearly invisible at rest, it flares only when
      // the orb glitches (opacity is driven per-frame in draw()).
      const wireMat = new THREE.MeshBasicMaterial({
        color: 0x9fb6cc,
        wireframe: true,
        transparent: true,
        opacity: 0,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      wireMat.onBeforeCompile = this.inject;
      this.wire = new THREE.Mesh(geo, wireMat);
      this.wire.scale.setScalar(1.004);
      this.scene.add(this.wire);
    }

    private buildGhost() {
      const c = document.createElement("canvas");
      c.width = 2048; c.height = 1024;
      const ctx = c.getContext("2d")!;
      ctx.clearRect(0, 0, c.width, c.height);
      ctx.fillStyle = "rgba(255,255,255,0.06)";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.font = "900 620px Inter, 'Helvetica Neue', Arial, sans-serif";
      ctx.fillText("404", c.width / 2, c.height / 2 + 30);
      const tex = new THREE.CanvasTexture(c);
      tex.colorSpace = THREE.SRGBColorSpace;
      tex.anisotropy = Math.min(this.renderer!.capabilities.getMaxAnisotropy(), 8);
      const geo = new THREE.PlaneGeometry(20, 10);
      const mat = new THREE.MeshBasicMaterial({ map: tex, transparent: true, depthWrite: false, opacity: 1 });
      this.ghost = new THREE.Mesh(geo, mat);
      this.ghost.position.z = -5.5;
      this.scene.add(this.ghost);
    }

    private buildStars() {
      const count = this.lowPower ? 520 : 1100;
      const pos = new Float32Array(count * 3);
      const size = new Float32Array(count);
      for (let i = 0; i < count; i++) {
        const r = 22 + Math.random() * 55;
        const a = Math.random() * Math.PI * 2;
        const y = (Math.random() * 2 - 1) * 40;
        pos[i * 3] = Math.cos(a) * r;
        pos[i * 3 + 1] = y;
        pos[i * 3 + 2] = -12 - Math.random() * 60;
        size[i] = 0.5 + Math.random() * 1.6;
      }
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.BufferAttribute(pos, 3));
      g.setAttribute("aSize", new THREE.BufferAttribute(size, 1));
      const m = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: { uTime: this.uniforms.uTime, uPr: { value: Math.min(devicePixelRatio || 1, 2) } },
        vertexShader: `
          attribute float aSize; uniform float uTime; uniform float uPr; varying float vT;
          void main(){
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_Position = projectionMatrix * mv;
            vT = 0.6 + 0.4 * sin(uTime * 1.4 + position.x * 3.0 + position.y);
            gl_PointSize = aSize * uPr * (60.0 / -mv.z);
          }`,
        fragmentShader: `
          precision highp float; varying float vT;
          void main(){
            float d = length(gl_PointCoord - 0.5);
            float a = smoothstep(0.5, 0.0, d) * vT * 0.7;
            if (a < 0.01) discard;
            gl_FragColor = vec4(vec3(0.82, 0.88, 0.95), a);
          }`,
      });
      this.stars = new THREE.Points(g, m);
      this.scene.add(this.stars);
    }

    private buildLights() {
      const key = new THREE.DirectionalLight(0xdfe9ff, 3.4);
      key.position.set(-4, 5, 6);
      this.scene.add(key);
      const rim = new THREE.PointLight(0x88a6ff, 22, 30, 2);
      rim.position.set(4, -2, 3);
      this.scene.add(rim);
      this.scene.add(new THREE.AmbientLight(0x0a1018, 0.5));
    }

    /** Random glitch bursts: flash the wireframe, shatter, widen the RGB split. */
    private scheduleGlitch = () => {
      const gap = 2.6 + Math.random() * 5.2;
      this.glitchTimer = gsap.delayedCall(gap, () => {
        const tl = gsap.timeline({ onComplete: this.scheduleGlitch });
        tl.to(this.uniforms.uGlitch, { value: 0.4 + Math.random() * 0.35, duration: 0.06, ease: "power2.in" })
          .to(this.uniforms.uBurst, { value: 0.2 + Math.random() * 0.3, duration: 0.06 }, 0)
          .to(this.split, { x: (Math.random() - 0.5) * 0.007, y: (Math.random() - 0.5) * 0.003, duration: 0.06 }, 0)
          .to(this.uniforms.uGlitch, { value: 0, duration: 0.28 + Math.random() * 0.3, ease: "power2.out" }, ">-0.02")
          .to(this.uniforms.uBurst, { value: 0, duration: 0.42, ease: "power3.out" }, "<")
          .to(this.split, { x: 0, y: 0, duration: 0.3, ease: "power2.out" }, "<");
      });
    };

    private onPointerMove = (e: PointerEvent) => {
      const nx = e.clientX / innerWidth - 0.5;
      const ny = 0.5 - e.clientY / innerHeight;
      this.mouseTarget.set(nx, ny);
      const dx = nx - this.lastPointer.x;
      const dy = ny - this.lastPointer.y;
      this.lastPointer.set(nx, ny);
      this.vel = Math.min(1, this.vel + Math.sqrt(dx * dx + dy * dy) * 6);
    };

    private onVisibility = () => {
      this.visible = !document.hidden;
      if (this.visible && !this.raf && !this.calm) {
        this.lastFrame = performance.now();
        this.raf = requestAnimationFrame(this.render);
      }
    };

    private onCalm = (e: CustomEvent<{ calm: boolean }>) => {
      this.calm = Boolean(e.detail?.calm);
      if (this.calm) { this.glitchTimer?.kill(); requestAnimationFrame(() => this.draw(this.clock.getElapsedTime())); }
      else if (!this.raf && this.visible) { this.scheduleGlitch(); this.lastFrame = performance.now(); this.raf = requestAnimationFrame(this.render); }
    };

    private resize = () => {
      if (!this.renderer) return;
      const w = innerWidth, h = innerHeight;
      this.renderer.setSize(w, h, false);
      this.camera.aspect = w / h;
      this.camera.updateProjectionMatrix();
      const dpr = this.renderer.getPixelRatio();
      if (this.target && this.post) {
        this.target.setSize(Math.round(w * dpr), Math.round(h * dpr));
        (this.post.uniforms.uRes.value as THREE.Vector2).set(w * dpr, h * dpr);
      }
    };

    private draw(elapsed: number) {
      if (!this.renderer) return;
      this.uniforms.uTime.value = elapsed;

      // Pointer parallax + a slow adrift sway.
      this.mouse.lerp(this.mouseTarget, 0.05);
      this.camera.position.x += (this.mouse.x * 1.6 + Math.sin(elapsed * 0.13) * 0.25 - this.camera.position.x) * 0.04;
      this.camera.position.y += (this.mouse.y * 1.1 + Math.cos(elapsed * 0.17) * 0.18 - this.camera.position.y) * 0.04;
      this.camera.lookAt(0, 0, 0);

      if (this.sphere) {
        this.sphere.rotation.y = elapsed * 0.12 + this.mouse.x * 0.4;
        this.sphere.rotation.x = Math.sin(elapsed * 0.2) * 0.12 - this.mouse.y * 0.3;
        this.wire!.rotation.copy(this.sphere.rotation);
      }
      if (this.stars) this.stars.rotation.z = elapsed * 0.01;

      // Velocity decays; it and the live glitch drive the RGB split + wire flash.
      this.vel *= 0.88;
      const g = this.uniforms.uGlitch.value;
      if (this.wire) (this.wire.material as THREE.MeshBasicMaterial).opacity = 0.015 + g * 0.5 + this.vel * 0.05;
      if (this.ghost) {
        const gm = this.ghost.material as THREE.MeshBasicMaterial;
        // Ghost 404 flickers like a failing panel during a glitch.
        gm.opacity = 1 - g * (0.4 + 0.5 * Math.sin(elapsed * 80.0));
        this.ghost.position.x = g * (Math.random() - 0.5) * 0.3;
      }

      // Ease the split toward the velocity-driven baseline unless a glitch tween
      // is actively pushing it wider. Kept subtle — a chromatic accent, not a wash.
      if (g < 0.05) {
        this.split.x += (this.vel * 0.004 - this.split.x) * 0.2;
        this.split.y += (0 - this.split.y) * 0.2;
      }
      if (this.post) (this.post.uniforms.uTime.value as number) = elapsed;

      if (this.target && this.post && !this.lowPower) {
        this.renderer.setRenderTarget(this.target);
        this.renderer.render(this.scene, this.camera);
        this.renderer.setRenderTarget(null);
        this.renderer.render(this.postScene, this.postCam);
      } else {
        this.renderer.render(this.scene, this.camera);
      }
    }

    private render = (now = performance.now()) => {
      this.raf = 0;
      if (!this.renderer || !this.visible || this.calm) return;
      const fps = this.lowPower ? 40 : 60;
      if (now - this.lastFrame < 1000 / fps) { this.raf = requestAnimationFrame(this.render); return; }
      this.lastFrame = now;
      this.draw(this.clock.getElapsedTime());
      this.raf = requestAnimationFrame(this.render);
    };
  }

  if (!customElements.get("rb-anomaly")) customElements.define("rb-anomaly", Anomaly);

  // ── Copy choreography ──────────────────────────────────────────────────────
  const page = document.querySelector(".void");
  if (page) {
    const reduced = prefersCalm();

    // Title: split into characters that resolve in a scrambled order.
    document.querySelectorAll<HTMLElement>("[data-split]").forEach((el) => {
      const text = el.textContent ?? "";
      el.textContent = "";
      el.setAttribute("aria-label", text);
      const spans: HTMLElement[] = [];
      for (const ch of text) {
        const s = document.createElement("span");
        s.className = "void-char";
        s.textContent = ch === " " ? " " : ch;
        s.setAttribute("aria-hidden", "true");
        el.appendChild(s);
        spans.push(s);
      }
      if (reduced) { gsap.set(spans, { opacity: 1, y: 0 }); return; }
      gsap.set(spans, { opacity: 0, y: (i) => (i % 2 ? 30 : -30), rotateX: -60 });
      gsap.to(spans, {
        opacity: 1, y: 0, rotateX: 0, duration: 0.9, ease: "power3.out",
        delay: 0.25, stagger: { each: 0.05, from: "random" },
      });
    });

    document.querySelectorAll<HTMLElement>("[data-decode-in]").forEach((el, i) => {
      gsap.delayedCall(0.5 + i * 0.08, () => decodeText(el, { duration: 720 }));
    });

    if (!reduced) {
      gsap.fromTo(".void-sub", { opacity: 0 }, { opacity: 1, duration: 1.2, delay: 0.7 });
      gsap.fromTo(".evac", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 1.1, ease: "power3.out", delay: 0.9 });

      // Drifting coordinates readout.
      const lat = document.querySelector<HTMLElement>('[data-coord="lat"]');
      const lon = document.querySelector<HTMLElement>('[data-coord="lon"]');
      const drift = () => {
        if (lat) lat.textContent = (Math.random() * 180 - 90).toFixed(4);
        if (lon) lon.textContent = (Math.random() * 360 - 180).toFixed(4);
        gsap.delayedCall(0.6 + Math.random() * 1.4, drift);
      };
      drift();
    }
  }

  // Beacon grid drifts into range as it scrolls into view.
  const beacons = gsap.utils.toArray<HTMLElement>("[data-beacon]");
  if (beacons.length) {
    if (prefersCalm()) {
      gsap.set(beacons, { opacity: 1, y: 0 });
    } else {
      gsap.set(beacons, { opacity: 0, y: 26 });
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e, i) => {
            if (!e.isIntersecting) return;
            gsap.to(e.target, { opacity: 1, y: 0, duration: 0.8, ease: "power3.out", delay: (i % 3) * 0.08 });
            io.unobserve(e.target);
          });
        },
        { threshold: 0.18 },
      );
      beacons.forEach((b) => io.observe(b));
    }
  }
</script>

