---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Signal Lost" description="The page you are looking for has drifted into the void." noindex={true} noWebgl={true}>
  <section class="not-found" aria-labelledby="not-found-heading">
    
    <!-- Top Text Group -->
    <div class="top-text-group">
      <div class="error-label">ERROR</div>
      <h1 id="not-found-heading" class="huge-404">404</h1>
      <p class="subtitle main-subtitle" data-decode>THE ARCHIVE HAS DRIFTED<br/>INTO THE VOID</p>
    </div>
    
    <!-- Center Button -->
    <div class="center-button-group">
      <a href="/" class="return-btn">RETURN TO STUDIO <span class="arrow">→</span></a>
    </div>
    
    <!-- HUD -->
    <div class="hud-container">
      <div class="hud-item">
        <div class="hud-label">GRAVITY</div>
        <div class="hud-value">1.42 &times; 10&sup1;&sup1; m/s&sup2;</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">DISTANCE</div>
        <div class="hud-value">&infin; LY</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">EVENT HORIZON</div>
        <div class="hud-value">UNKNOWN</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">SIGNAL</div>
        <div class="hud-value">NONE</div>
      </div>
    </div>

    <!-- Scroll Stabilize -->
    <div class="scroll-stabilize">
      <div class="scroll-dot"></div>
      SCROLL TO STABILIZE
    </div>

    <div class="cosmic-backdrop" aria-hidden="true">
      <rb-404-gl></rb-404-gl>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from "three";
  import gsap from "gsap";
  import { decode } from "../utils/decode";

  const subs = document.querySelectorAll(".subtitle, .hud-label, .hud-value, .scroll-stabilize, .error-label");
  subs.forEach((sub) => {
    decode(sub as HTMLElement, sub.textContent!, { duration: 800 });
  });

  class GlitchGL extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private scene = new THREE.Scene();
    private camera = new THREE.PerspectiveCamera(45, 1, 0.1, 150);
    private blackHoleGroup = new THREE.Group();
    private diskMaterial?: THREE.ShaderMaterial;
    private starLayers: THREE.Points[] = [];
    private asteroidLayer?: THREE.Points;
    private clock = new THREE.Clock();
    private raf = 0;
    private mouse = new THREE.Vector2();
    private mouseTarget = new THREE.Vector2();
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private visible = true;

    connectedCallback() {
      this.renderer = new THREE.WebGLRenderer({ alpha: true, antialias: !this.lowPower, powerPreference: "high-performance" });
      this.renderer.setPixelRatio(this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.3));
      this.renderer.setClearColor(0x000000, 0);
      this.append(this.renderer.domElement);

      this.camera.position.z = 12;

      this.buildStars(this.lowPower ? 2000 : 5000, 1.0, 0.8, 0);
      this.buildStars(this.lowPower ? 800 : 2000, 1.8, 1.0, 1);
      this.buildAsteroids(this.lowPower ? 150 : 400);
      this.buildBlackHole();

      this.resize();
      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointerMove, { passive: true });
      document.addEventListener("visibilitychange", this.onVisibility);
      this.raf = requestAnimationFrame(this.render);

      gsap.fromTo(".top-text-group", 
        { opacity: 0, y: -20 }, 
        { opacity: 1, y: 0, duration: 1.5, ease: "power3.out", delay: 0.2 }
      );
      gsap.fromTo(".center-button-group", 
        { opacity: 0, y: 20 }, 
        { opacity: 1, y: 0, duration: 1.5, ease: "power3.out", delay: 0.6 }
      );
      gsap.fromTo(".hud-item", 
        { opacity: 0, y: 15 }, 
        { opacity: 1, y: 0, duration: 1.0, stagger: 0.1, ease: "power3.out", delay: 0.8 }
      );
      gsap.fromTo(".scroll-stabilize", 
        { opacity: 0 }, 
        { opacity: 0.5, duration: 1.5, ease: "none", delay: 1.5 }
      );
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.raf);
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointerMove);
      document.removeEventListener("visibilitychange", this.onVisibility);
      this.starLayers.forEach(l => { l.geometry.dispose(); (l.material as THREE.Material).dispose(); });
      if (this.asteroidLayer) {
        this.asteroidLayer.geometry.dispose();
        (this.asteroidLayer.material as THREE.Material).dispose();
      }
      this.renderer?.dispose();
    }

    private buildStars(count: number, sizeMultiplier: number, opacity: number, layerIndex: number) {
      const positions = new Float32Array(count * 3);
      const sizes = new Float32Array(count);
      const alpha = new Float32Array(count);
      
      for (let i = 0; i < count; i += 1) {
        const i3 = i * 3;
        positions[i3] = (Math.random() - 0.5) * 80;
        positions[i3 + 1] = (Math.random() - 0.5) * 50;
        positions[i3 + 2] = (Math.random() - 0.5) * 60 - 20;
        sizes[i] = (Math.random() * 2.0 + 0.5) * sizeMultiplier;
        alpha[i] = (Math.random() * 0.7 + 0.3) * opacity;
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute("aSize", new THREE.BufferAttribute(sizes, 1));
      geometry.setAttribute("aAlpha", new THREE.BufferAttribute(alpha, 1));

      const material = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: {
          uPixelRatio: { value: this.renderer!.getPixelRatio() },
          uTime: { value: 0 }
        },
        vertexShader: `
          attribute float aSize;
          attribute float aAlpha;
          uniform float uPixelRatio;
          uniform float uTime;
          varying float vAlpha;
          void main() {
            vec3 p = position;
            // Slow rotation around center
            float angle = uTime * 0.02;
            float s = sin(angle);
            float c = cos(angle);
            p.x = position.x * c - position.z * s;
            p.z = position.x * s + position.z * c;
            
            vec4 mvPosition = modelViewMatrix * vec4(p, 1.0);
            gl_Position = projectionMatrix * mvPosition;
            gl_PointSize = aSize * uPixelRatio * (15.0 / -mvPosition.z);
            vAlpha = aAlpha;
          }
        `,
        fragmentShader: `
          varying float vAlpha;
          void main() {
            float d = length(gl_PointCoord - 0.5);
            if (d > 0.5) discard;
            float alpha = smoothstep(0.5, 0.1, d) * vAlpha;
            gl_FragColor = vec4(vec3(0.8, 0.9, 1.0), alpha);
          }
        `
      });

      const points = new THREE.Points(geometry, material);
      this.starLayers.push(points);
      this.scene.add(points);
    }

    private buildAsteroids(count: number) {
      const positions = new Float32Array(count * 3);
      const randoms = new Float32Array(count);
      
      for (let i = 0; i < count; i += 1) {
        const i3 = i * 3;
        // Distribute asteroids around the black hole in a wide disk
        const radius = Math.random() * 25 + 4;
        const angle = Math.random() * Math.PI * 2;
        positions[i3] = Math.cos(angle) * radius;
        positions[i3 + 1] = (Math.random() - 0.5) * (radius * 0.15); // thicker further out
        positions[i3 + 2] = Math.sin(angle) * radius;
        randoms[i] = Math.random();
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute("aRandom", new THREE.BufferAttribute(randoms, 1));

      const material = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        uniforms: {
          uPixelRatio: { value: this.renderer!.getPixelRatio() },
          uTime: { value: 0 }
        },
        vertexShader: `
          attribute float aRandom;
          uniform float uPixelRatio;
          uniform float uTime;
          varying float vAlpha;
          void main() {
            vec3 p = position;
            float r = length(p.xz);
            float angle = atan(p.z, p.x);
            
            // Orbital mechanics: closer orbits faster
            angle += uTime * (0.5 / sqrt(r));
            
            p.x = cos(angle) * r;
            p.z = sin(angle) * r;
            
            vec4 mvPosition = modelViewMatrix * vec4(p, 1.0);
            gl_Position = projectionMatrix * mvPosition;
            
            float size = aRandom * 12.0 + 2.0;
            gl_PointSize = size * uPixelRatio * (15.0 / -mvPosition.z);
            
            // Fade out when very close or very far
            vAlpha = smoothstep(3.0, 5.0, r) * smoothstep(30.0, 20.0, r) * (0.4 + aRandom * 0.6);
          }
        `,
        fragmentShader: `
          varying float vAlpha;
          void main() {
            // Irregular rock shape approximation
            vec2 p = gl_PointCoord - 0.5;
            float r = length(p);
            if (r > 0.5) discard;
            
            // Soft shading
            float shade = smoothstep(0.5, 0.0, r);
            vec3 rockColor = vec3(0.08, 0.09, 0.1);
            gl_FragColor = vec4(rockColor * shade, vAlpha * shade);
          }
        `
      });

      this.asteroidLayer = new THREE.Points(geometry, material);
      // Tilt the asteroid belt
      this.asteroidLayer.rotation.x = -1.2;
      this.scene.add(this.asteroidLayer);
    }

    private buildBlackHole() {
      // Event Horizon
      const sphereGeo = new THREE.SphereGeometry(1.5, 64, 64);
      const sphereMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
      const eventHorizon = new THREE.Mesh(sphereGeo, sphereMat);
      
      // Accretion Disk
      const diskGeo = new THREE.PlaneGeometry(16, 16, 64, 64);
      this.diskMaterial = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        side: THREE.DoubleSide,
        uniforms: {
          uTime: { value: 0 }
        },
        vertexShader: `
          varying vec2 vUv;
          varying vec3 vPos;
          void main() {
            vUv = uv;
            vPos = position;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          varying vec2 vUv;
          varying vec3 vPos;
          uniform float uTime;
          
          // Noise function
          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }
          float snoise(vec2 v) {
            const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
            vec2 i  = floor(v + dot(v, C.yy) );
            vec2 x0 = v -   i + dot(i, C.xx);
            vec2 i1;
            i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz;
            x12.xy -= i1;
            i = mod289(i); // Avoid truncation effects in permutation
            vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 )) + i.x + vec3(0.0, i1.x, 1.0 ));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
            m = m*m ;
            m = m*m ;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
            vec3 g;
            g.x  = a0.x  * x0.x  + h.x  * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 130.0 * dot(m, g);
          }

          void main() {
            vec2 center = vec2(0.0);
            float r = length(vPos.xy);
            float angle = atan(vPos.y, vPos.x);
            
            // Normalize radius relative to event horizon
            float n = (r - 1.4) / 6.0;
            if(n < 0.0 || n > 1.0) discard;
            
            // Smooth gradient
            float glow = smoothstep(1.0, 0.0, n) * smoothstep(0.0, 0.08, n);
            
            // Swirling details
            float speed = uTime * 1.5;
            float swirl1 = snoise(vec2(angle * 4.0 - speed, r * 1.5));
            float swirl2 = snoise(vec2(angle * 8.0 + speed * 0.5, r * 3.0));
            
            glow *= mix(0.4, 1.0, swirl1 * 0.5 + 0.5);
            glow *= mix(0.7, 1.2, swirl2 * 0.5 + 0.5);
            
            // Doppler beaming (brighter on one side due to relativistic speeds)
            float doppler = sin(angle) * 0.5 + 0.5;
            glow *= mix(0.5, 2.0, doppler);
            
            // Colors: Deep orange, gold, and white hot core
            vec3 deepSpace = vec3(0.05, 0.1, 0.2);
            vec3 coreGlow = vec3(1.0, 0.9, 0.7);
            vec3 outerGlow = vec3(0.8, 0.4, 0.1);
            
            vec3 color = mix(outerGlow, coreGlow, pow(smoothstep(0.8, 0.0, n), 2.0));
            color = mix(deepSpace, color, glow);
            
            gl_FragColor = vec4(color, glow * 0.95);
          }
        `
      });

      const disk = new THREE.Mesh(diskGeo, this.diskMaterial);
      disk.rotation.x = -1.25; // Cinematic tilt
      disk.position.z = -0.1; // Slightly behind horizon to prevent z-fighting
      
      this.blackHoleGroup.add(eventHorizon);
      this.blackHoleGroup.add(disk);
      
      this.scene.add(this.blackHoleGroup);
    }

    private onPointerMove = (event: PointerEvent) => {
      this.mouseTarget.set(event.clientX / innerWidth - 0.5, 0.5 - event.clientY / innerHeight);
    };

    private onVisibility = () => {
      this.visible = !document.hidden;
      if (this.visible && !this.raf) this.raf = requestAnimationFrame(this.render);
    };

    private resize = () => {
      if (!this.renderer) return;
      this.renderer.setSize(innerWidth, innerHeight, false);
      this.camera.aspect = innerWidth / innerHeight;
      this.camera.updateProjectionMatrix();
    };

    private render = (now = performance.now()) => {
      this.raf = 0;
      if (!this.renderer || !this.visible) return;
      const elapsed = this.clock.getElapsedTime();
      this.mouse.lerp(this.mouseTarget, 0.05);

      // Camera parallax
      this.camera.position.x += (this.mouse.x * 1.5 - this.camera.position.x) * 0.03;
      this.camera.position.y += (this.mouse.y * 1.5 - this.camera.position.y) * 0.03;
      this.camera.lookAt(0, 0, 0);

      this.starLayers.forEach((layer) => {
        (layer.material as THREE.ShaderMaterial).uniforms.uTime.value = elapsed;
      });
      
      if (this.asteroidLayer) {
        (this.asteroidLayer.material as THREE.ShaderMaterial).uniforms.uTime.value = elapsed;
      }

      if (this.diskMaterial) {
        this.diskMaterial.uniforms.uTime.value = elapsed;
        // Subtle tilt interaction based on mouse
        this.blackHoleGroup.rotation.y = this.mouse.x * 0.15;
        this.blackHoleGroup.rotation.x = -this.mouse.y * 0.15;
      }

      this.renderer.render(this.scene, this.camera);
      this.raf = requestAnimationFrame(this.render);
    };
  }

  if (!customElements.get("rb-404-gl")) customElements.define("rb-404-gl", GlitchGL);
</script>

<style>
  .not-found {
    position: relative;
    z-index: 10;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding: 3rem 2rem;
    overflow: hidden;
  }

  /* Top Group: ERROR, 404, Subtitle */
  .top-text-group {
    text-align: center;
    position: relative;
    z-index: 2;
    pointer-events: none;
    margin-top: 4vh;
  }

  .error-label {
    font-family: var(--font-inter);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.5em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.5rem;
  }

  .huge-404 {
    font-family: var(--font-inter), sans-serif;
    font-size: clamp(8rem, 18vw, 15rem);
    font-weight: 300;
    line-height: 1;
    margin: 0;
    color: #ffffff;
    letter-spacing: -0.01em;
    text-shadow: 0 0 4rem rgba(255, 255, 255, 0.1);
  }

  .subtitle {
    font-family: var(--font-inter);
    font-size: clamp(0.6rem, 1.2vw, 0.75rem);
    font-weight: 400;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    line-height: 1.8;
  }

  .main-subtitle {
    margin-top: 1.5rem;
  }

  /* Center Button */
  .center-button-group {
    position: absolute;
    top: 68%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
  }

  .return-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 3.4rem;
    padding: 0 2rem 0 2.4rem;
    font-family: var(--font-inter);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(5, 5, 5, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2rem;
    text-decoration: none;
    pointer-events: auto;
    transition: transform 0.6s var(--ease-out-expo), background 0.6s, border-color 0.6s;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .return-btn .arrow {
    margin-left: 1.5rem;
    font-size: 1.2em;
    font-weight: 300;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .return-btn:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.35);
    color: #fff;
  }

  .return-btn:hover .arrow {
    transform: translateX(4px);
  }

  /* HUD Layout */
  .hud-container {
    width: 100%;
    display: flex;
    justify-content: space-between;
    z-index: 2;
    pointer-events: none;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    margin-bottom: 2rem;
  }

  .hud-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    flex: 1;
  }

  /* Vertical separators */
  .hud-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background: rgba(255, 255, 255, 0.15);
  }
  
  .hud-item:not(:first-child) {
    padding-left: 2rem;
  }

  .hud-label {
    font-family: var(--font-inter);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 0.75rem;
  }

  .hud-value {
    font-family: var(--font-inter);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Scroll to stabilize */
  .scroll-stabilize {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-inter);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.4em;
    color: rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 2;
  }

  .scroll-dot {
    width: 4px;
    height: 4px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 10px 2px rgba(255,255,255,0.8);
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.5); }
  }

  @media (max-width: 768px) {
    .huge-404 {
      font-size: 8rem;
    }
    .hud-container {
      flex-wrap: wrap;
      gap: 2rem;
      margin-bottom: 5rem;
    }
    .hud-item {
      min-width: 40%;
    }
    .hud-item:not(:last-child)::after {
      display: none;
    }
    .hud-item:not(:first-child) {
      padding-left: 0;
    }
    .center-button-group {
      top: 60%;
    }
  }

  rb-404-gl {
    position: absolute;
    inset: 0;
    display: block;
    z-index: 1;
    background: #040508;
    pointer-events: none;
  }
  
  rb-404-gl canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .cosmic-backdrop {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: auto;
  }
</style>
