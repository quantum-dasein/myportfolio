---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 — Signal Lost"
  description="The page you are looking for has drifted into the void."
  noindex={true}
  noWebgl={true}
>
  <section class="not-found" aria-labelledby="not-found-heading">
    <div class="top-text-group">
      <div class="error-label" data-decode-in>ERROR</div>
      <h1 id="not-found-heading" class="huge-404">404</h1>
      <p class="subtitle" data-decode-in>THE ARCHIVE HAS DRIFTED<br />INTO THE VOID</p>
    </div>

    <div class="center-button-group">
      <a href="/" class="return-btn" data-magnetic data-cursor="HOME">
        <span data-decode-in>RETURN TO STUDIO</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <div class="hud-container">
      <div class="hud-item">
        <div class="hud-label" data-decode-in>GRAVITY</div>
        <div class="hud-value"><span data-gravity>1.42</span> &times; 10&sup1;&sup1; m/s&sup2;</div>
      </div>
      <div class="hud-item">
        <div class="hud-label" data-decode-in>DISTANCE</div>
        <div class="hud-value">&infin; LY</div>
      </div>
      <div class="hud-item">
        <div class="hud-label" data-decode-in>EVENT HORIZON</div>
        <div class="hud-value" data-decode-in>UNKNOWN</div>
      </div>
      <div class="hud-item">
        <div class="hud-label" data-decode-in>SIGNAL</div>
        <div class="hud-value" data-decode-in>NONE</div>
      </div>
    </div>

    <div class="scroll-stabilize">
      <div class="scroll-dot"></div>
      <span data-decode-in>SCROLL TO STABILIZE</span>
    </div>

    <div class="cosmic-backdrop" aria-hidden="true">
      <rb-404-gl></rb-404-gl>
    </div>
  </section>
</Layout>

<script>
  // ───────────────────────────────────────────────────────────────────────────
  //  404 — a Schwarzschild black hole, lensed for real.
  //
  //  The disk is NOT a tilted plane with a sphere in front of it. Every pixel
  //  fires a photon at the hole and integrates its geodesic, so the far side of
  //  the disk bends up and over the shadow and the near side wraps underneath —
  //  the light is genuinely curved, which is the only way this reads as gravity
  //  rather than as a texture. The shadow is where photons were captured; the
  //  bright rim around it is the photon sphere, and it falls out of the physics
  //  for free rather than being drawn on.
  //
  //  Three passes: the lensed universe is marched into a half-resolution target
  //  (integrating ~120 geodesic steps for every screen pixel melts a laptop —
  //  and the result is all soft gas and starlight, which upscales invisibly),
  //  blitted up, then the asteroid belt is rasterised over it at full crispness
  //  with a camera matched to the shader's.
  // ───────────────────────────────────────────────────────────────────────────
  import * as THREE from "three";
  import gsap from "gsap";
  import { decodeText, prefersCalm } from "../utils/decode";

  // Framed so the disk spans ~60% of the width, as in the reference.
  const FOCAL = 2.0;
  // Rs = 1: horizon at r = 1, photon sphere at 1.5, ISCO (the disk's inner edge) at 3.
  const CAM = new THREE.Vector3(0, 3.4, 45);
  const TARGET = new THREE.Vector3(0, 0, 0);
  /** Pushes the hole below centre so the 404 never sits on top of it. */
  const SHIFT = 0.075;

  const VERT = /* glsl */ `
    void main() { gl_Position = vec4(position.xy, 0.0, 1.0); }
  `;

  const FRAG = /* glsl */ `
    precision highp float;

    uniform vec2  uRes;
    uniform float uTime;
    uniform vec3  uCamPos;
    uniform vec3  uCamTarget;
    uniform float uFocal;
    uniform float uShift;
    uniform float uIntensity;

    #define RS       1.0
    #define DISK_IN  3.0
    #define DISK_OUT 12.5
    /** Radius outside which light travels straight enough to fake it. */
    #define FIELD    16.0

    float hash31(vec3 p) {
      p = fract(p * 0.3183099 + vec3(0.71, 0.113, 0.419));
      p *= 17.0;
      return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
    }
    float hash21(vec2 p) {
      vec3 q = fract(vec3(p.xyx) * 0.1031);
      q += dot(q, q.yzx + 33.33);
      return fract((q.x + q.y) * q.z);
    }
    float noise3(vec3 x) {
      vec3 i = floor(x), f = fract(x);
      f = f * f * (3.0 - 2.0 * f);
      return mix(mix(mix(hash31(i + vec3(0,0,0)), hash31(i + vec3(1,0,0)), f.x),
                     mix(hash31(i + vec3(0,1,0)), hash31(i + vec3(1,1,0)), f.x), f.y),
                 mix(mix(hash31(i + vec3(0,0,1)), hash31(i + vec3(1,0,1)), f.x),
                     mix(hash31(i + vec3(0,1,1)), hash31(i + vec3(1,1,1)), f.x), f.y), f.z);
    }
    float noise2(vec2 x) {
      vec2 i = floor(x), f = fract(x);
      f = f * f * (3.0 - 2.0 * f);
      return mix(mix(hash21(i + vec2(0,0)), hash21(i + vec2(1,0)), f.x),
                 mix(hash21(i + vec2(0,1)), hash21(i + vec2(1,1)), f.x), f.y);
    }
    float fbm3(vec3 p) {
      float v = 0.0, a = 0.5;
      for (int i = 0; i < 3; i++) { v += a * noise3(p); p = p * 2.02 + 1.7; a *= 0.5; }
      return v;
    }
    // Four octaves for the disk — it is the subject and lives or dies on gas
    // detail; the nebula behind it stays at three.
    float fbm2(vec2 p) {
      float v = 0.0, a = 0.5;
      for (int i = 0; i < 4; i++) { v += a * noise2(p); p = p * 2.03 + 3.1; a *= 0.5; }
      return v;
    }

    float starLayer(vec3 d, float thresh, float scale) {
      vec3 p = d * scale;
      float h = hash31(floor(p));
      float on = step(thresh, h);
      float b = (h - thresh) / max(1e-4, 1.0 - thresh);
      return on * b * smoothstep(0.36, 0.0, length(fract(p) - 0.5));
    }

    /** Whatever the photon was looking at when it escaped. */
    vec3 background(vec3 d) {
      float n1 = fbm3(d * 1.9 + 4.0);
      float n2 = fbm3(d * 5.2 - 2.0);
      // These look absurdly dark written down, and have to be: everything here
      // is linear light and gets a 1/2.2 gamma on the way out, which lifts 0.002
      // to a visible 0.06. Authoring the sky at "looks right" values made deep
      // space read as milky grey.
      vec3 col = mix(vec3(0.0004, 0.0006, 0.0013), vec3(0.004, 0.005, 0.009), n1);
      col += vec3(0.018, 0.016, 0.027) * pow(smoothstep(0.42, 0.95, n1), 2.4);
      col += vec3(0.020, 0.010, 0.005) * pow(smoothstep(0.55, 1.0, n2), 3.0);
      // A faint galactic band arcing behind the hole, tilted off-axis so it
      // reads as scenery the hole sits in front of, not a frame around it.
      // The falloff must die within ~15° of the band's plane — a soft power
      // curve here floods the whole equator of the sky with haze.
      float band = abs(dot(d, normalize(vec3(0.34, 1.0, -0.25))));
      float streak = smoothstep(0.30, 0.02, band);
      col += vec3(0.016, 0.019, 0.027) * streak * streak * (0.35 + 0.65 * n1);
      col += vec3(0.85, 0.92, 1.00) * starLayer(d, 0.9900, 190.0) * 1.15;
      col += vec3(1.00, 0.94, 0.86) * starLayer(d, 0.9972, 74.0) * 1.7;
      return col;
    }

    /** Colour and opacity of the disk where a photon punched through it. */
    vec4 diskSample(vec3 p, vec3 dir) {
      float r = length(p.xz);
      float shape = smoothstep(DISK_IN, DISK_IN + 1.1, r) *
                    (1.0 - smoothstep(DISK_OUT - 5.0, DISK_OUT, r));
      if (shape <= 0.001) return vec4(0.0);

      // Keplerian shear — the inner disk laps the outer one, so the gas smears
      // into arcs instead of turning like a solid record. Sign matches the
      // orbital velocity below; flipping one without the other would light the
      // wrong limb.
      float shear = -uTime * 2.4 / pow(r, 1.5);
      float a = atan(p.z, p.x) + shear;
      // Back to Cartesian before sampling: noise on (angle, r) tears at ±π.
      vec2 q = vec2(cos(a), sin(a)) * r;

      float n = fbm2(q * 0.8);
      float n2 = fbm2(q * 2.5 + 9.0);
      float density = shape * mix(0.22, 1.0, n) * mix(0.5, 1.4, n2);

      // Temperature falls with radius: white-hot at the ISCO, a dusty warm
      // silver at the rim. The reference disk is starlight-coloured, not lava —
      // the warmth is a tint, never the body of the colour.
      float t = 1.0 - smoothstep(DISK_IN, DISK_OUT * 0.8, r);
      vec3 col = mix(vec3(0.62, 0.46, 0.34), vec3(0.95, 0.82, 0.66), pow(t, 1.4));
      col = mix(col, vec3(1.0, 0.98, 0.95), pow(t, 3.5));

      // Relativistic beaming: the limb rotating toward us is dramatically
      // brighter than the one rotating away. This asymmetry is the tell.
      vec3 vel = normalize(vec3(p.z, 0.0, -p.x)) * (0.52 / sqrt(max(r, 1.0) / RS));
      float beam = 1.0 / (1.0 - dot(vel, -dir));
      // Physically this wants a higher exponent, but past ~2.4 the receding limb
      // drops out of the frame entirely and the ring stops reading as a ring.
      beam = pow(clamp(beam, 0.0, 3.0), 2.4);
      col *= beam;
      density *= clamp(beam * 0.6, 0.25, 1.0);

      return vec4(col, clamp(density, 0.0, 1.0));
    }

    // Output is LINEAR on purpose: the blit pass sRGB-encodes exactly once on
    // the way to the canvas. Encoding here as well double-lifts every value —
    // 0.004 deep space becomes 0.32 fog — which is precisely the milky wash
    // this page shipped with twice.
    vec3 grade(vec3 col) {
      col *= uIntensity;
      return col / (1.0 + col);         // filmic-ish rolloff, no clipped highlights
    }

    void main() {
      vec2 p = (gl_FragCoord.xy - 0.5 * uRes) / uRes.y;
      p.y += uShift;

      vec3 fwd = normalize(uCamTarget - uCamPos);
      vec3 rgt = normalize(cross(fwd, vec3(0.0, 1.0, 0.0)));
      vec3 up  = cross(rgt, fwd);

      vec3 pos = uCamPos;
      vec3 dir = normalize(p.x * rgt + p.y * up + uFocal * fwd);

      // Conserved angular momentum of this photon; it sets how hard it bends.
      float h2 = dot(cross(pos, dir), cross(pos, dir));

      // Out here spacetime is flat to the eye and the disk is nowhere near, so
      // stepping the 30 units in from the camera would burn most of the march on
      // a straight line. Jump to the sphere where gravity starts to matter; rays
      // that miss it entirely never bend at all and are just sky.
      float b = dot(pos, dir);
      float c = dot(pos, pos) - FIELD * FIELD;
      float disc = b * b - c;
      if (disc < 0.0) {
        gl_FragColor = vec4(grade(background(dir)), 1.0);
        return;
      }
      pos += dir * max(0.0, -b - sqrt(disc));

      vec3 col = vec3(0.0);
      float trans = 1.0;
      bool captured = false;

      for (int i = 0; i < STEPS; i++) {
        float r2 = dot(pos, pos);
        float r = sqrt(r2);
        if (r < RS * 1.02) { captured = true; break; }
        if (r > FIELD + 2.0 && dot(pos, dir) > 0.0) break; // escaped for good

        float dt = clamp(r * 0.075, 0.05, 0.9);
        vec3 prev = pos;

        // Null geodesic, Cartesian form: a = -1.5 h² r⃗ / r⁵.
        dir = normalize(dir - (1.5 * h2 / (r2 * r2 * r)) * pos * dt);
        pos += dir * dt;

        // Crossed the disk plane between the last step and this one?
        if (prev.y * pos.y < 0.0) {
          vec3 hit = mix(prev, pos, prev.y / (prev.y - pos.y));
          vec4 d = diskSample(hit, dir);
          col += d.rgb * d.a * trans;
          trans *= 1.0 - d.a;
          if (trans < 0.01) break;
        }
      }

      if (!captured) col += background(dir) * trans;
      gl_FragColor = vec4(grade(col), 1.0);
    }
  `;

  /** Fraction of the screen the geodesic march actually runs at. */
  const MARCH_SCALE = 0.7;

  class BlackHoleGL extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private bgScene = new THREE.Scene();
    private bgCamera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
    private target?: THREE.WebGLRenderTarget;
    private blitScene = new THREE.Scene();
    private scene = new THREE.Scene();
    private camera = new THREE.PerspectiveCamera(45, 1, 0.1, 400);
    private material?: THREE.ShaderMaterial;
    private rocks?: THREE.InstancedMesh;
    private orbits: { r: number; y: number; phase: number; speed: number; scale: THREE.Vector3; spin: THREE.Vector3 }[] = [];
    private clock = new THREE.Clock();
    private raf = 0;
    private mouse = new THREE.Vector2();
    private mouseTarget = new THREE.Vector2();
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private visible = true;
    private calm = document.documentElement.classList.contains("rb-calm");
    private lastFrame = 0;
    private dummy = new THREE.Object3D();

    connectedCallback() {
      // AA costs nothing here (the march happens in the offscreen target); it
      // only smooths the rasterised debris, which otherwise shimmers with jaggies.
      this.renderer = new THREE.WebGLRenderer({ antialias: !this.lowPower, alpha: false, powerPreference: "high-performance" });
      // The march is the whole cost of this page — resolution is the cheapest
      // dial there is, so it stays modest and the geodesics stay accurate.
      this.renderer.setPixelRatio(Math.min(devicePixelRatio || 1, this.lowPower ? 1 : 1.25));
      this.renderer.setClearColor(0x000000, 1);
      this.renderer.autoClear = false;
      this.append(this.renderer.domElement);

      // Linear working space end to end: the march writes linear light into a
      // half-float target (8-bit storage bands badly across these huge soft
      // gradients), the blit samples it untouched, and the renderer applies the
      // one and only sRGB encode when writing the canvas. Any gamma before that
      // point stacks a second lift on top and washes the scene out to grey fog.
      this.target = new THREE.WebGLRenderTarget(1, 1, {
        minFilter: THREE.LinearFilter,
        magFilter: THREE.LinearFilter,
        depthBuffer: false,
        type: THREE.HalfFloatType,
      });
      this.blitScene.add(
        new THREE.Mesh(
          new THREE.PlaneGeometry(2, 2),
          new THREE.MeshBasicMaterial({ map: this.target.texture, depthTest: false, depthWrite: false }),
        ),
      );

      this.material = new THREE.ShaderMaterial({
        vertexShader: VERT,
        fragmentShader: FRAG,
        depthTest: false,
        depthWrite: false,
        defines: { STEPS: this.lowPower ? 64 : 110 },
        uniforms: {
          uRes: { value: new THREE.Vector2(1, 1) },
          uTime: { value: 0 },
          uCamPos: { value: CAM.clone() },
          uCamTarget: { value: TARGET.clone() },
          uFocal: { value: FOCAL },
          uShift: { value: SHIFT },
          uIntensity: { value: prefersCalm() ? 1 : 0 },
        },
      });
      this.bgScene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), this.material));

      this.camera.fov = 2 * Math.atan(0.5 / FOCAL) * (180 / Math.PI);
      this.camera.position.copy(CAM);
      this.camera.lookAt(TARGET);
      this.buildAsteroids(this.lowPower ? 50 : 110);

      this.resize();
      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointerMove, { passive: true });
      document.addEventListener("visibilitychange", this.onVisibility);
      addEventListener("rb:calmchange", this.onCalmChange as EventListener);

      this.lastFrame = performance.now();
      this.raf = requestAnimationFrame(this.render);

      if (!prefersCalm()) {
        // The universe fades up rather than snapping on — the hole is the reveal.
        gsap.to(this.material.uniforms.uIntensity, { value: 1, duration: 2.4, ease: "power2.out" });
      }
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.raf);
      this.raf = 0;
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointerMove);
      document.removeEventListener("visibilitychange", this.onVisibility);
      removeEventListener("rb:calmchange", this.onCalmChange as EventListener);
      this.material?.dispose();
      this.target?.dispose();
      this.rocks?.geometry.dispose();
      (this.rocks?.material as THREE.Material | undefined)?.dispose();
      this.bgScene.clear();
      this.scene.clear();
      this.renderer?.dispose();
      this.renderer = undefined;
    }

    /** Debris that never made it in, lit only by the disk it is falling toward. */
    private buildAsteroids(count: number) {
      const geometry = new THREE.IcosahedronGeometry(1, 1);
      const material = new THREE.MeshStandardMaterial({
        color: 0x14161a,
        roughness: 0.95,
        metalness: 0.05,
        flatShading: true,
      });
      this.rocks = new THREE.InstancedMesh(geometry, material, count);
      this.rocks.frustumCulled = false;

      for (let i = 0; i < count; i += 1) {
        const r = 14 + Math.random() * 30;
        this.orbits.push({
          r,
          // Hug the disk plane near the hole, drift wider further out.
          y: (Math.random() - 0.5) * (2 + r * 0.14),
          phase: Math.random() * Math.PI * 2,
          speed: 0.55 / Math.pow(r, 1.5),
          // In scene units the disk is ~12 across; debris must read as motes
          // against it, not boulders. At 0.5 units each rock was the size of a
          // building and the belt looked like Minecraft gravel.
          scale: new THREE.Vector3(
            0.5 + Math.random() * 0.8,
            0.4 + Math.random() * 0.7,
            0.5 + Math.random() * 0.9,
          ).multiplyScalar(0.035 + Math.pow(Math.random(), 2.5) * 0.1),
          spin: new THREE.Vector3(Math.random() - 0.5, Math.random() - 0.5, Math.random() - 0.5).multiplyScalar(0.4),
        });
      }
      this.scene.add(this.rocks);

      // The disk is the only light source out here: a faint warm kiss on the
      // sunward face of each mote, and near-nothing ambient. Debris should be
      // silhouettes drifting across the glow, not lit props.
      const glow = new THREE.PointLight(0xffb066, 140, 70, 2);
      this.scene.add(glow);
      this.scene.add(new THREE.AmbientLight(0x1a2230, 0.12));
    }

    private onPointerMove = (event: PointerEvent) => {
      this.mouseTarget.set(event.clientX / innerWidth - 0.5, 0.5 - event.clientY / innerHeight);
    };

    private onVisibility = () => {
      this.visible = !document.hidden;
      if (this.visible && !this.raf && !this.calm) {
        this.lastFrame = performance.now();
        this.raf = requestAnimationFrame(this.render);
      }
    };

    private onCalmChange = (event: CustomEvent<{ calm: boolean }>) => {
      this.calm = Boolean(event.detail?.calm);
      if (!this.calm && !this.raf && this.visible) {
        this.lastFrame = performance.now();
        this.raf = requestAnimationFrame(this.render);
      }
      // Calm still renders — it just stops moving. Draw one last frame.
      if (this.calm) requestAnimationFrame(() => this.draw(this.clock.getElapsedTime()));
    };

    private resize = () => {
      if (!this.renderer || !this.material || !this.target) return;
      const w = innerWidth;
      const h = innerHeight;
      this.renderer.setSize(w, h, false);
      const dpr = this.renderer.getPixelRatio();
      const scale = this.lowPower ? MARCH_SCALE * 0.85 : MARCH_SCALE;
      const mw = Math.max(2, Math.round(w * dpr * scale));
      const mh = Math.max(2, Math.round(h * dpr * scale));
      this.target.setSize(mw, mh);
      this.material.uniforms.uRes.value.set(mw, mh);
      this.camera.aspect = w / h;
      // Match the shader's lens shift so the rasterised rocks sit in the same
      // frame as the raymarched universe behind them.
      this.camera.setViewOffset(w, h, 0, -SHIFT * h, w, h);
      this.camera.updateProjectionMatrix();
    };

    private draw(elapsed: number) {
      if (!this.renderer || !this.material) return;
      this.material.uniforms.uTime.value = elapsed;

      // The camera drifts with the pointer — a slow, heavy parallax.
      this.mouse.lerp(this.mouseTarget, 0.045);
      const pos = this.material.uniforms.uCamPos.value as THREE.Vector3;
      pos.x += (this.mouse.x * 4.5 - pos.x) * 0.04;
      pos.y += (CAM.y + this.mouse.y * 2.6 - pos.y) * 0.04;
      this.camera.position.copy(pos);
      this.camera.lookAt(TARGET);

      if (this.rocks) {
        this.orbits.forEach((orbit, i) => {
          const a = orbit.phase + elapsed * orbit.speed * 6;
          this.dummy.position.set(Math.cos(a) * orbit.r, orbit.y, Math.sin(a) * orbit.r);
          this.dummy.rotation.set(elapsed * orbit.spin.x, elapsed * orbit.spin.y, elapsed * orbit.spin.z);
          this.dummy.scale.copy(orbit.scale);
          this.dummy.updateMatrix();
          this.rocks!.setMatrixAt(i, this.dummy.matrix);
        });
        this.rocks.instanceMatrix.needsUpdate = true;
      }

      // 1. March the geodesics at half res. 2. Blit up. 3. Rocks on top, sharp.
      this.renderer.setRenderTarget(this.target!);
      this.renderer.clear();
      this.renderer.render(this.bgScene, this.bgCamera);
      this.renderer.setRenderTarget(null);
      this.renderer.clear();
      this.renderer.render(this.blitScene, this.bgCamera);
      this.renderer.clearDepth();
      this.renderer.render(this.scene, this.camera);
    }

    private render = (now = performance.now()) => {
      this.raf = 0;
      if (!this.renderer || !this.visible || this.calm) return;

      const targetFps = this.lowPower ? 40 : 60;
      if (now - this.lastFrame < 1000 / targetFps) {
        this.raf = requestAnimationFrame(this.render);
        return;
      }
      this.lastFrame = now;
      this.draw(this.clock.getElapsedTime());
      this.raf = requestAnimationFrame(this.render);
    };
  }

  if (!customElements.get("rb-404-gl")) customElements.define("rb-404-gl", BlackHoleGL);

  // ── Copy choreography ─────────────────────────────────────────────────────
  const page = document.querySelector(".not-found");
  if (page) {
    document.querySelectorAll<HTMLElement>("[data-decode-in]").forEach((el, i) => {
      // decodeText, not decode(el, el.textContent): the subtitle's <br> has to
      // survive, or "DRIFTED / INTO" collapses into "DRIFTEDINTO".
      gsap.delayedCall(0.35 + i * 0.06, () => decodeText(el, { duration: 700 }));
    });

    if (!prefersCalm()) {
      gsap.fromTo(".top-text-group", { opacity: 0, y: -18 }, { opacity: 1, y: 0, duration: 1.4, ease: "power3.out", delay: 0.15 });
      gsap.fromTo(".center-button-group", { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 1.4, ease: "power3.out", delay: 0.6 });
      gsap.fromTo(".hud-item", { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 1, stagger: 0.09, ease: "power3.out", delay: 0.8 });
      gsap.fromTo(".scroll-stabilize", { opacity: 0 }, { opacity: 0.55, duration: 1.4, ease: "none", delay: 1.5 });

      // The gravity readout drifts, because nothing here is stable.
      const gravity = document.querySelector<HTMLElement>("[data-gravity]");
      if (gravity) {
        const jitter = () => {
          gravity.textContent = (1.38 + Math.random() * 0.09).toFixed(2);
          gsap.delayedCall(0.9 + Math.random() * 1.6, jitter);
        };
        jitter();
      }
    }
  }
</script>

