---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Signal Lost" description="The page you are looking for has drifted into the void." noindex={true} noWebgl={true}>
  <div class="bg-parallax-wrapper">
    <div class="bg-parallax-image" style="background-image: url('/404-bg.png')"></div>
  </div>

  <section class="not-found" aria-labelledby="not-found-heading">
    <div class="not-found__content">
      <div class="error-label">ERROR</div>
      <h1 id="not-found-heading" class="smooth-text">404</h1>
      <p class="subtitle main-subtitle" data-decode>THE ARCHIVE HAS DRIFTED<br/>INTO THE VOID</p>
      
      <div class="return-btn-wrapper">
        <a href="/" class="return-btn">RETURN TO STUDIO <span class="arrow">→</span></a>
      </div>
    </div>
    
    <div class="hud-container">
      <div class="hud-item">
        <div class="hud-label">GRAVITY</div>
        <div class="hud-value">1.42 &times; 10&sup1;&sup1; m/s&sup2;</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">DISTANCE</div>
        <div class="hud-value">&infin; LY</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">EVENT HORIZON</div>
        <div class="hud-value">UNKNOWN</div>
      </div>
      <div class="hud-item">
        <div class="hud-label">SIGNAL</div>
        <div class="hud-value">NONE</div>
      </div>
    </div>

    <div class="scroll-stabilize">
      <div class="scroll-dot"></div>
      SCROLL TO STABILIZE
    </div>

    <div class="cosmic-backdrop" aria-hidden="true">
      <rb-404-gl></rb-404-gl>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from "three";
  import gsap from "gsap";
  import { decode } from "../utils/decode";

  // Trigger decode on subtitles
  const subs = document.querySelectorAll(".subtitle, .hud-label, .hud-value, .scroll-stabilize, .error-label");
  subs.forEach((sub) => {
    decode(sub as HTMLElement, sub.textContent!, { duration: 800 });
  });

  class GlitchGL extends HTMLElement {
    private renderer?: THREE.WebGLRenderer;
    private scene = new THREE.Scene();
    private camera = new THREE.PerspectiveCamera(58, 1, 0.1, 110);
    private starLayers: THREE.Points[] = [];
    private clock = new THREE.Clock();
    private raf = 0;
    private mouse = new THREE.Vector2();
    private mouseTarget = new THREE.Vector2();
    private lowPower = matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    private visible = true;
    private bgImage: HTMLElement | null = null;

    connectedCallback() {
      this.renderer = new THREE.WebGLRenderer({ alpha: true, antialias: !this.lowPower, powerPreference: "high-performance" });
      this.renderer.setPixelRatio(this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.3));
      this.renderer.setClearColor(0x000000, 0);
      this.append(this.renderer.domElement);

      this.camera.position.z = 7.2;
      this.bgImage = document.querySelector(".bg-parallax-image");

      // Build only stars, flying towards camera
      this.buildStars(this.lowPower ? 2200 : 4800, 1.25, 1.0, 0);
      this.buildStars(this.lowPower ? 780 : 1800, 2.35, 1.0, 1);

      this.resize();
      addEventListener("resize", this.resize, { passive: true });
      addEventListener("pointermove", this.onPointerMove, { passive: true });
      document.addEventListener("visibilitychange", this.onVisibility);
      this.raf = requestAnimationFrame(this.render);

      gsap.fromTo(".not-found__content", 
        { opacity: 0, scale: 0.95 }, 
        { opacity: 1, scale: 1, duration: 1.5, ease: "power3.out", delay: 0.2 }
      );
      gsap.fromTo(".hud-item", 
        { opacity: 0, y: 15 }, 
        { opacity: 1, y: 0, duration: 1.0, stagger: 0.1, ease: "power3.out", delay: 0.8 }
      );
      gsap.fromTo(".scroll-stabilize", 
        { opacity: 0 }, 
        { opacity: 0.5, duration: 1.5, ease: "none", delay: 1.5 }
      );
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.raf);
      removeEventListener("resize", this.resize);
      removeEventListener("pointermove", this.onPointerMove);
      document.removeEventListener("visibilitychange", this.onVisibility);
      this.starLayers.forEach(l => { l.geometry.dispose(); (l.material as THREE.Material).dispose(); });
      this.renderer?.dispose();
    }

    private buildStars(count: number, sizeMultiplier: number, opacity: number, layerIndex: number) {
      const positions = new Float32Array(count * 3);
      const sizes = new Float32Array(count);
      const alpha = new Float32Array(count);
      const phase = new Float32Array(count);

      for (let i = 0; i < count; i += 1) {
        const i3 = i * 3;
        const radius = 2.8 + Math.pow(Math.random(), 0.6) * 34;
        const angle = Math.random() * Math.PI * 2;
        positions[i3] = Math.cos(angle) * radius;
        positions[i3 + 1] = Math.sin(angle) * radius * 0.62;
        positions[i3 + 2] = -Math.random() * 76 + 4;
        sizes[i] = (0.6 + Math.random() * 2.2) * sizeMultiplier;
        alpha[i] = (0.28 + Math.random() * 0.72) * opacity;
        phase[i] = Math.random() * Math.PI * 2;
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute("aSize", new THREE.BufferAttribute(sizes, 1));
      geometry.setAttribute("aAlpha", new THREE.BufferAttribute(alpha, 1));
      geometry.setAttribute("aPhase", new THREE.BufferAttribute(phase, 1));

      const material = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: {
          uPixelRatio: { value: this.lowPower ? Math.min(devicePixelRatio || 1, 1) : Math.min(devicePixelRatio || 1, 1.3) },
          uTime: { value: 0 },
          uLayer: { value: layerIndex },
        },
        vertexShader: `
          attribute float aSize;
          attribute float aAlpha;
          attribute float aPhase;
          uniform float uPixelRatio;
          uniform float uTime;
          uniform float uLayer;
          varying float vAlpha;
          varying float vAngle;
          varying float vLayer;

          void main() {
            vec3 p = position;
            float speed = mix(0.12, 0.3, uLayer / 2.0);
            p.z = mod(p.z + uTime * speed + 80.0, 80.0) - 76.0;
            p.x += sin(uTime * 0.05 + aPhase) * 0.04;
            p.y += cos(uTime * 0.045 + aPhase) * 0.03;
            vec4 mv = modelViewMatrix * vec4(p, 1.0);
            vec4 projected = projectionMatrix * mv;
            gl_Position = projected;
            vec2 ndc = projected.xy / max(projected.w, 0.001);
            vAngle = atan(ndc.y, ndc.x);
            vLayer = uLayer;
            vAlpha = aAlpha * smoothstep(-76.0, -52.0, p.z) * smoothstep(4.0, -1.0, p.z);
            float perspective = clamp(16.0 / -mv.z, 0.48, 3.6);
            gl_PointSize = aSize * uPixelRatio * perspective;
          }
        `,
        fragmentShader: `
          precision highp float;
          varying float vAlpha;
          varying float vAngle;
          varying float vLayer;

          void main() {
            vec2 p = gl_PointCoord - 0.5;
            float d = length(p);
            float core = smoothstep(0.48, 0.018, d);
            if (core < 0.008) discard;
            vec3 silver = mix(vec3(0.78, 0.82, 0.85), vec3(1.0), core);
            gl_FragColor = vec4(silver * core, vAlpha * core);
          }
        `,
      });

      const layer = new THREE.Points(geometry, material);
      this.starLayers.push(layer);
      this.scene.add(layer);
    }

    private onPointerMove = (event: PointerEvent) => {
      this.mouseTarget.set(event.clientX / innerWidth - 0.5, 0.5 - event.clientY / innerHeight);
    };

    private onVisibility = () => {
      this.visible = !document.hidden;
      if (this.visible && !this.raf) this.raf = requestAnimationFrame(this.render);
    };

    private resize = () => {
      if (!this.renderer) return;
      this.renderer.setSize(innerWidth, innerHeight, false);
      this.camera.aspect = innerWidth / innerHeight;
      this.camera.updateProjectionMatrix();
    };

    private render = (now = performance.now()) => {
      this.raf = 0;
      if (!this.renderer || !this.visible) return;
      const elapsed = this.clock.getElapsedTime();
      this.mouse.lerp(this.mouseTarget, 0.05);

      this.camera.position.x += (this.mouse.x * 0.48 - this.camera.position.x) * 0.03;
      this.camera.position.y += (this.mouse.y * 0.34 - this.camera.position.y) * 0.03;

      this.starLayers.forEach((layer, index) => {
        const material = layer.material as THREE.ShaderMaterial;
        material.uniforms.uTime.value = elapsed;
        layer.rotation.y = this.mouse.x * (0.018 + index * 0.012);
        layer.rotation.x = -this.mouse.y * (0.012 + index * 0.008);
      });

      if (this.bgImage) {
        // Subtle mouse parallax for the background image
        this.bgImage.style.transform = `translate(${this.mouse.x * 3}%, ${-this.mouse.y * 3}%) scale(1.05)`;
      }

      this.renderer.render(this.scene, this.camera);
      this.raf = requestAnimationFrame(this.render);
    };
  }

  if (!customElements.get("rb-404-gl")) customElements.define("rb-404-gl", GlitchGL);
</script>

<style>
  .bg-parallax-wrapper {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: #000;
  }
  
  .bg-parallax-image {
    position: absolute;
    inset: -5%; /* buffer for parallax */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.05);
    will-change: transform;
    opacity: 0.85; /* slight dim for text readability */
  }

  .not-found {
    position: relative;
    z-index: 10;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  .not-found__content {
    text-align: center;
    position: relative;
    z-index: 2;
    pointer-events: none;
    max-width: 800px;
    margin-top: -5vh; 
  }

  .error-label {
    font-family: var(--font-inter);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .smooth-text {
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 18rem);
    font-weight: 400;
    line-height: 0.85;
    margin: 0;
    color: #ffffff;
    letter-spacing: -0.02em;
    text-shadow: 0 0 5rem rgba(255, 255, 255, 0.4), 0 0 10rem rgba(255, 255, 255, 0.2);
  }

  .subtitle {
    font-family: var(--font-inter);
    font-size: clamp(0.7rem, 1.5vw, 0.85rem);
    font-weight: 400;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    line-height: 1.6;
  }

  .main-subtitle {
    margin-top: 1.5rem;
    margin-bottom: 3rem;
  }

  .return-btn-wrapper {
    margin-top: 15vh;
  }

  .return-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 3.4rem;
    padding: 0 2rem 0 2.4rem;
    font-family: var(--font-inter);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(10, 10, 10, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2rem;
    text-decoration: none;
    pointer-events: auto;
    transition: transform 0.6s var(--ease-out-expo), background 0.6s, border-color 0.6s;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .return-btn .arrow {
    margin-left: 1rem;
    font-size: 1.1em;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .return-btn:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
  }

  .return-btn:hover .arrow {
    transform: translateX(4px);
  }

  /* HUD Layout */
  .hud-container {
    position: absolute;
    bottom: 5rem;
    left: 5%;
    right: 5%;
    display: flex;
    justify-content: space-between;
    z-index: 2;
    pointer-events: none;
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 2rem;
  }

  .hud-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
  }

  /* Add faint separator lines between hud items */
  .hud-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -25%;
    top: 0;
    height: 100%;
    width: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  .hud-label {
    font-family: var(--font-inter);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 0.75rem;
  }

  .hud-value {
    font-family: var(--font-inter);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Scroll to stabilize */
  .scroll-stabilize {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-inter);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 2;
  }

  .scroll-dot {
    width: 4px;
    height: 4px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 10px 2px rgba(255,255,255,0.8);
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.5); }
  }

  /* Responsive HUD */
  @media (max-width: 768px) {
    .hud-container {
      bottom: 6rem;
      flex-wrap: wrap;
      gap: 2rem;
      border-top: none;
      padding-top: 0;
    }
    .hud-item {
      width: 45%;
    }
    .hud-item:not(:last-child)::after {
      display: none;
    }
    .return-btn-wrapper {
      margin-top: 5vh;
    }
  }

  rb-404-gl {
    position: absolute;
    inset: 0;
    display: block;
    z-index: 1;
    pointer-events: none;
  }
  
  rb-404-gl canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .cosmic-backdrop {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: auto;
  }
</style>
